{% doc %}
  @prompt
    Create a featured Product section that we can select different products. I want this to be a grid design with the Product Info on the left side and the Product Image on the right. There should be a captive header on the top. Use the site colors and styles. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-featured-product-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-featured-product-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-featured-product-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
  }

  .ai-featured-product-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
  }

  .ai-featured-product-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-featured-product-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.product_title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-featured-product-vendor-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
    margin: 0;
  }

  .ai-featured-product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.text_color }};
    font-weight: 600;
  }

  .ai-featured-product-price-compare-{{ ai_gen_id }} {
    text-decoration: line-through;
    opacity: 0.6;
    margin-left: 8px;
  }

  .ai-featured-product-description-{{ ai_gen_id }} {
    font-size: 16px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
  }

  .ai-featured-product-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 32px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    text-align: center;
    transition: background-color 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-featured-product-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-featured-product-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-featured-product-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .ai-featured-product-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
    position: relative;
  }

  .ai-featured-product-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-featured-product-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-featured-product-badge-{{ ai_gen_id }} {
    display: inline-block;
    padding: 6px 12px;
    background-color: {{ block.settings.badge_background_color }};
    color: {{ block.settings.badge_text_color }};
    font-size: 12px;
    font-weight: 600;
    border-radius: 4px;
    text-transform: uppercase;
  }

  @media screen and (max-width: 768px) {
    .ai-featured-product-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .ai-featured-product-{{ ai_gen_id }} {
      padding: 30px 15px;
    }

    .ai-featured-product-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-featured-product-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.product_title_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<featured-product-{{ ai_gen_id }} class="ai-featured-product-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <div class="ai-featured-product-header-{{ ai_gen_id }}">
      <h2 class="ai-featured-product-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    </div>
  {% endif %}

  <div class="ai-featured-product-grid-{{ ai_gen_id }}">
    <div class="ai-featured-product-info-{{ ai_gen_id }}">
      {% if block.settings.product != blank %}
        {% assign product = block.settings.product %}
        
        {% if block.settings.show_vendor and product.vendor != blank %}
          <p class="ai-featured-product-vendor-{{ ai_gen_id }}">{{ product.vendor }}</p>
        {% endif %}

        <h3 class="ai-featured-product-title-{{ ai_gen_id }}">{{ product.title }}</h3>

        <div class="ai-featured-product-price-{{ ai_gen_id }}">
          {% if product.compare_at_price > product.price %}
            {% if block.settings.show_sale_badge %}
              <span class="ai-featured-product-badge-{{ ai_gen_id }}">Sale</span>
            {% endif %}
            <span>{{ product.price | money }}</span>
            <span class="ai-featured-product-price-compare-{{ ai_gen_id }}">{{ product.compare_at_price | money }}</span>
          {% else %}
            <span>{{ product.price | money }}</span>
          {% endif %}
        </div>

        {% if block.settings.show_description and product.description != blank %}
          <div class="ai-featured-product-description-{{ ai_gen_id }}">
            {{ product.description | strip_html | truncate: 200 }}
          </div>
        {% endif %}

        <div>
          <a href="{{ product.url }}" class="ai-featured-product-button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </a>
        </div>
      {% else %}
        <h3 class="ai-featured-product-title-{{ ai_gen_id }}">Product title</h3>
        <div class="ai-featured-product-price-{{ ai_gen_id }}">
          <span>$29.99</span>
        </div>
        <div class="ai-featured-product-description-{{ ai_gen_id }}">
          Select a product to display its details here. Add a compelling description to encourage customers to learn more.
        </div>
        <div>
          <a href="#" class="ai-featured-product-button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </a>
        </div>
      {% endif %}
    </div>

    <div class="ai-featured-product-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.product != blank and block.settings.product.featured_image %}
        <img
          src="{{ block.settings.product.featured_image | image_url: width: 800 }}"
          alt="{{ block.settings.product.featured_image.alt | escape }}"
          class="ai-featured-product-image-{{ ai_gen_id }}"
          loading="lazy"
          width="{{ block.settings.product.featured_image.width }}"
          height="{{ block.settings.product.featured_image.height }}"
        >
      {% else %}
        <div class="ai-featured-product-placeholder-{{ ai_gen_id }}">
          {{ 'product-1' | placeholder_svg_tag }}
          <div class="ai-featured-product-empty-state-{{ ai_gen_id }}">
            Next, select a product to feature
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</featured-product-{{ ai_gen_id }}>

<script>
  (function() {
    class FeaturedProduct{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('featured-product-{{ ai_gen_id }}', FeaturedProduct{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Featured product",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Featured product"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_sale_badge",
      "label": "Show sale badge",
      "default": true
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "View product"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Button font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#292929"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#7c7a7a"
    },
    {
      "type": "color",
      "id": "button_background_color",
      "label": "Button background",
      "default": "#e68b3c"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover background",
      "default": "#7d7d7d"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "badge_background_color",
      "label": "Sale badge background",
      "default": "#7d7d7d"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Sale badge text",
      "default": "#fafafa"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "open_sans_n6"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "product_title_size",
      "label": "Product title size",
      "min": 18,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "price_size",
      "label": "Price size",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Featured product"
    }
  ]
}
{% endschema %}
