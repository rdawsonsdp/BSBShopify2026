{% doc %}
  @prompt
    Create a featured Product section that we can select different products. I want this to be a grid design with the Product Info on the left side and the Product Image on the right. There should be a captive header on the top. Use the site colors and styles. Don't show the price. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-featured-product-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
    padding: 28px 16px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-featured-product__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 24px;
  }

  .ai-featured-product__heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    color: {{ block.settings.heading_color }};
    font-size: clamp(22px, 5vw, {{ block.settings.heading_size }}px);
    line-height: 1.2;
    margin: 0;
  }

  .ai-featured-product__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    align-items: center;
  }

  .ai-featured-product__info-{{ ai_gen_id }} {
    order: 2;
  }

  .ai-featured-product__image-wrapper-{{ ai_gen_id }} {
    order: 1;
    width: 100%;
  }

  .ai-featured-product__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-featured-product__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
    position: relative;
  }

  .ai-featured-product__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-featured-product__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-featured-product__title-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    color: {{ block.settings.text_color }};
    font-size: clamp(20px, 4.5vw, {{ block.settings.product_title_size }}px);
    line-height: 1.25;
    margin: 0 0 12px 0;
  }

  .ai-featured-product__vendor-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-style: {{ block.settings.body_font.style }};
    color: {{ block.settings.text_color }};
    opacity: 0.7;
    font-size: 14px;
    margin-bottom: 12px;
  }

  .ai-featured-product__description-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-style: {{ block.settings.body_font.style }};
    color: {{ block.settings.text_color }};
    font-size: clamp(15px, 3.6vw, {{ block.settings.description_size }}px);
    line-height: 1.6;
    margin-bottom: 20px;
  }

  .ai-featured-product__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 12px 28px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-size: {{ block.settings.button_text_size }}px;
    transition: background-color 0.3s ease;
  }

  .ai-featured-product__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-featured-product__empty-product-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #999;
    font-size: 16px;
    font-style: italic;
  }

  @media screen and (min-width: 750px) {
    .ai-featured-product-{{ ai_gen_id }} {
      width: {{ block.settings.desktop_width_percent }}%;
      padding: 40px 20px;
    }

    .ai-featured-product__header-{{ ai_gen_id }} {
      margin-bottom: 40px;
    }

    .ai-featured-product__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }

    .ai-featured-product__info-{{ ai_gen_id }} {
      order: 1;
    }

    .ai-featured-product__image-wrapper-{{ ai_gen_id }} {
      order: 2;
    }
  }
{% endstyle %}

<featured-product-{{ ai_gen_id }}
  class="ai-featured-product-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.heading != blank %}
    <div class="ai-featured-product__header-{{ ai_gen_id }}">
      <h2 class="ai-featured-product__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    </div>
  {% endif %}

  {% if block.settings.featured_product != blank %}
    {% assign product = block.settings.featured_product %}
    <div class="ai-featured-product__grid-{{ ai_gen_id }}">
      <div class="ai-featured-product__info-{{ ai_gen_id }}">
        <h3 class="ai-featured-product__title-{{ ai_gen_id }}">{{ product.title }}</h3>
        
        {% if block.settings.show_vendor and product.vendor != blank %}
          <div class="ai-featured-product__vendor-{{ ai_gen_id }}">{{ product.vendor }}</div>
        {% endif %}

        {% if product.description != blank %}
          <div class="ai-featured-product__description-{{ ai_gen_id }}">
            {{ product.description | strip_html | truncate: 200 }}
          </div>
        {% endif %}

        <a
          href="{{ product.url }}"
          class="ai-featured-product__button-{{ ai_gen_id }}"
        >
          {{ block.settings.button_text }}
        </a>
      </div>

      <div class="ai-featured-product__image-wrapper-{{ ai_gen_id }}">
        {% if product.featured_image %}
          <img
            src="{{ product.featured_image | image_url: width: 1000 }}"
            alt="{{ product.featured_image.alt | escape }}"
            loading="lazy"
            width="{{ product.featured_image.width }}"
            height="{{ product.featured_image.height }}"
            class="ai-featured-product__image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-featured-product__image-placeholder-{{ ai_gen_id }}">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
    </div>
  {% else %}
    <div class="ai-featured-product__empty-product-{{ ai_gen_id }}">
      Next, select a product to feature
    </div>
  {% endif %}
</featured-product-{{ ai_gen_id }}>

<script>
  (function() {
    class FeaturedProduct{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('featured-product-{{ ai_gen_id }}', FeaturedProduct{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Featured product",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Featured product"
    },
    {
      "type": "product",
      "id": "featured_product",
      "label": "Product"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop now"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#292929"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#7c7a7a"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#e68b3c"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Button hover background",
      "default": "#7d7d7d"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "open_sans_n6"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "font_picker",
      "id": "body_font",
      "label": "Body font",
      "default": "tenor_sans_n4"
    },
    {
      "type": "range",
      "id": "product_title_size",
      "label": "Product title size",
      "min": 18,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Description size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_text_size",
      "label": "Button text size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Featured product"
    }
  ]
}
{% endschema %}
