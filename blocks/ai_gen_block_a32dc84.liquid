{% doc %}
  @prompt
    Create a section that say. Same day ordering for Pickup? Download the clover app. Have a link to the Clover App for Apple and Android. , Please have the Apple and. Android logo at the bottom with a link the the store. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-clover-app-banner-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: 100%;
    padding: 20px 16px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    text-align: center;
  }

  .ai-clover-app-banner__content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }

  .ai-clover-app-banner__heading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: clamp(20px, 5vw, {{ block.settings.heading_size }}px);
    margin: 0;
    line-height: 1.25;
  }

  .ai-clover-app-banner__subtext-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: clamp(14px, 3.6vw, {{ block.settings.subtext_size }}px);
    margin: 0;
    line-height: 1.5;
  }

  .ai-clover-app-banner__logos-{{ ai_gen_id }} {
    display: flex;
    flex-direction: row;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    margin-top: 6px;
  }

  .ai-clover-app-banner__logo-link-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    min-width: 44px;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .ai-clover-app-banner__logo-link-{{ ai_gen_id }}:hover {
    opacity: 0.8;
    transform: scale(1.05);
  }

  .ai-clover-app-banner__logo-{{ ai_gen_id }} {
    height: {{ block.settings.logo_height }}px;
    width: auto;
    display: block;
  }

  @media screen and (min-width: 750px) {
    .ai-clover-app-banner-{{ ai_gen_id }} {
      width: {{ block.settings.desktop_width_percent }}%;
      padding: {{ block.settings.padding }}px;
    }

    .ai-clover-app-banner__content-{{ ai_gen_id }} {
      gap: {{ block.settings.content_gap }}px;
    }

    .ai-clover-app-banner__logos-{{ ai_gen_id }} {
      gap: {{ block.settings.logo_gap }}px;
      margin-top: {{ block.settings.logo_top_spacing }}px;
    }
  }
{% endstyle %}

<div class="ai-clover-app-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-clover-app-banner__content-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-clover-app-banner__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% if block.settings.subtext != blank %}
      <p class="ai-clover-app-banner__subtext-{{ ai_gen_id }}">{{ block.settings.subtext }}</p>
    {% endif %}

    <div class="ai-clover-app-banner__logos-{{ ai_gen_id }}">
      {% if block.settings.apple_app_link != blank %}
        <a
          href="{{ block.settings.apple_app_link }}"
          class="ai-clover-app-banner__logo-link-{{ ai_gen_id }}"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Download on the App Store"
        >
          <svg
            class="ai-clover-app-banner__logo-{{ ai_gen_id }}"
            viewBox="0 0 120 40"
            xmlns="http://www.w3.org/2000/svg"
          >
            <rect width="120" height="40" rx="5" fill="#000000"/>
            <path d="M24.769 20.301c-.024-2.555 2.087-3.787 2.182-3.848-1.188-1.738-3.04-1.977-3.697-2.003-1.574-.16-3.072.927-3.87.927-.798 0-2.031-.903-3.338-.878-1.717.025-3.298 1-4.184 2.539-1.783 3.091-.456 7.673 1.281 10.181.85 1.227 1.863 2.605 3.195 2.556 1.282-.051 1.766-.829 3.315-.829 1.549 0 1.982.829 3.338.803 1.379-.025 2.244-1.248 3.084-2.48.971-1.426 1.371-2.806 1.396-2.878-.03-.013-2.679-1.028-2.702-4.09z" fill="#ffffff"/>
            <path d="M22.037 12.211c.707-.857 1.184-2.048 1.054-3.234-1.018.041-2.251.678-2.981 1.534-.655.757-1.228 1.967-1.074 3.128 1.136.088 2.295-.577 3.001-1.428z" fill="#ffffff"/>
            <text x="40" y="13" font-family="Arial, sans-serif" font-size="9" fill="#ffffff">Download on the</text>
            <text x="40" y="26" font-family="Arial, sans-serif" font-size="13" font-weight="bold" fill="#ffffff">App Store</text>
          </svg>
        </a>
      {% endif %}

      {% if block.settings.android_app_link != blank %}
        <a
          href="{{ block.settings.android_app_link }}"
          class="ai-clover-app-banner__logo-link-{{ ai_gen_id }}"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Get it on Google Play"
        >
          <svg
            class="ai-clover-app-banner__logo-{{ ai_gen_id }}"
            viewBox="0 0 135 40"
            xmlns="http://www.w3.org/2000/svg"
          >
            <rect width="135" height="40" rx="5" fill="#000000"/>
            <path d="M8.084 7.865c-.247.247-.395.642-.395 1.148v21.974c0 .506.148.9.395 1.148l.062.06 12.308-12.308v-.29L8.146 7.805l-.062.06z" fill="url(#a)"/>
            <path d="M24.558 23.703l-4.104-4.104v-.29l4.104-4.104.092.053 4.862 2.762c1.39.79 1.39 2.082 0 2.871l-4.862 2.762-.092.05z" fill="url(#b)"/>
            <path d="M24.65 23.65l-4.196-4.196-12.37 12.37c.457.482 1.214.543 2.08.09l14.486-8.264" fill="url(#c)"/>
            <path d="M24.65 15.896L10.164 7.632c-.866-.453-1.623-.392-2.08.09l12.37 12.37 4.196-4.196z" fill="url(#d)"/>
            <defs>
              <linearGradient id="a" x1="21.8" y1="8.71" x2="5.017" y2="25.492" gradientUnits="userSpaceOnUse">
                <stop stop-color="#00A0FF"/>
                <stop offset=".007" stop-color="#00A1FF"/>
                <stop offset=".26" stop-color="#00BEFF"/>
                <stop offset=".512" stop-color="#00D2FF"/>
                <stop offset=".76" stop-color="#00DFFF"/>
                <stop offset="1" stop-color="#00E3FF"/>
              </linearGradient>
              <linearGradient id="b" x1="33.834" y1="19.773" x2="7.637" y2="19.773" gradientUnits="userSpaceOnUse">
                <stop stop-color="#FFE000"/>
                <stop offset=".409" stop-color="#FFBD00"/>
                <stop offset=".775" stop-color="#FFA500"/>
                <stop offset="1" stop-color="#FF9C00"/>
              </linearGradient>
              <linearGradient id="c" x1="24.827" y1="21.773" x2="2.069" y2="44.531" gradientUnits="userSpaceOnUse">
                <stop stop-color="#FF3A44"/>
                <stop offset="1" stop-color="#C31162"/>
              </linearGradient>
              <linearGradient id="d" x1="7.297" y1=".176" x2="17.46" y2="10.339" gradientUnits="userSpaceOnUse">
                <stop stop-color="#32A071"/>
                <stop offset=".069" stop-color="#2DA771"/>
                <stop offset=".476" stop-color="#15CF74"/>
                <stop offset=".801" stop-color="#06E775"/>
                <stop offset="1" stop-color="#00F076"/>
              </linearGradient>
            </defs>
            <text x="42" y="12" font-family="Arial, sans-serif" font-size="7" fill="#ffffff">GET IT ON</text>
            <text x="42" y="24" font-family="Arial, sans-serif" font-size="11" font-weight="bold" fill="#ffffff">Google Play</text>
          </svg>
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Clover app banner",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Same day ordering for Pickup?"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Download the Clover app"
    },
    {
      "type": "header",
      "content": "Apple App Store"
    },
    {
      "type": "url",
      "id": "apple_app_link",
      "label": "Apple App Store link"
    },
    {
      "type": "header",
      "content": "Google Play Store"
    },
    {
      "type": "url",
      "id": "android_app_link",
      "label": "Google Play Store link"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#e98d3d"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "content_gap",
      "label": "Content spacing",
      "min": 10,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "subtext_size",
      "label": "Subtext size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "App store logos"
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo height",
      "min": 30,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "logo_gap",
      "label": "Space between logos",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "logo_top_spacing",
      "label": "Top spacing",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 10
    }
  ],
  "presets": [
    {
      "name": "Clover app banner"
    }
  ]
}
{% endschema %}
