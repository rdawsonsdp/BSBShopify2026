{% doc %}
  @prompt
    We want info box to say Cakes leave our factory the day you pick shipping and we want this to be really obvious so something like a bright notice like please realize Cakes leave our factory at the date you pick it maybe pick is please allow say something please allow for shipping when requesting your cake or something. Let's see what you come up with.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-shipping-notice-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-shipping-notice-container-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.padding }}px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .ai-shipping-notice-icon-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    background-color: {{ block.settings.icon_background }};
    border-radius: 50%;
    margin-bottom: 12px;
  }

  .ai-shipping-notice-icon-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.icon_size }}px * 0.6);
    height: calc({{ block.settings.icon_size }}px * 0.6);
    fill: {{ block.settings.icon_color }};
  }

  .ai-shipping-notice-heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 700;
    margin: 0 0 8px 0;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-shipping-notice-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.5;
    margin: 0;
  }

  .ai-shipping-notice-text-{{ ai_gen_id }} strong {
    font-weight: 700;
  }

  @media screen and (max-width: 749px) {
    .ai-shipping-notice-container-{{ ai_gen_id }} {
      padding: {{ block.settings.padding | times: 0.8 }}px;
    }

    .ai-shipping-notice-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.9 }}px;
    }

    .ai-shipping-notice-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<shipping-notice-{{ ai_gen_id }}
  class="ai-shipping-notice-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-shipping-notice-container-{{ ai_gen_id }}">
    {% if block.settings.show_icon %}
      <div class="ai-shipping-notice-icon-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
        </svg>
      </div>
    {% endif %}

    {% if block.settings.heading != blank %}
      <h3 class="ai-shipping-notice-heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h3>
    {% endif %}

    {% if block.settings.message != blank %}
      <div class="ai-shipping-notice-text-{{ ai_gen_id }}">
        {{ block.settings.message }}
      </div>
    {% endif %}
  </div>
</shipping-notice-{{ ai_gen_id }}>

<script>
  (function() {
    class ShippingNotice{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('shipping-notice-{{ ai_gen_id }}', ShippingNotice{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Shipping notice",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Important Shipping Information"
    },
    {
      "type": "richtext",
      "id": "message",
      "label": "Message",
      "default": "<p><strong>Please allow for shipping time when requesting your cake.</strong> Cakes leave our factory on the date you select for shipping.</p>"
    },
    {
      "type": "header",
      "content": "Icon"
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Show icon",
      "default": true
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 30,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "color",
      "id": "icon_background",
      "label": "Icon background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#D62426"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#FFF3CD"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#FFC107"
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Border width",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 3
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 15,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#856404"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#856404"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Shipping notice"
    }
  ]
}
{% endschema %}
