{% doc %}
  @prompt
    i want a grid that will hold the postcard images and each image points to a product. , The images and landscape. The images must fit inside each container. Allow for image customization. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-postcard-grid-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 40px 20px;
  }

  .ai-postcard-grid__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .ai-postcard-grid__item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    {% if block.settings.enable_border %}
      border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    {% endif %}
  }

  .ai-postcard-grid__item-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
  }

  .ai-postcard-grid__link-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: 100%;
    height: 100%;
    text-decoration: none;
  }

  .ai-postcard-grid__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 66.67%;
    overflow: hidden;
    background-color: {{ block.settings.image_background_color }};
  }

  .ai-postcard-grid__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    {% if block.settings.image_fit == 'contain' %}
      object-fit: contain;
      padding: {{ block.settings.image_padding }}px;
    {% else %}
      object-fit: cover;
    {% endif %}
  }

  .ai-postcard-grid__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.image_background_color }};
  }

  .ai-postcard-grid__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-postcard-grid__overlay-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, {{ block.settings.overlay_opacity }}), transparent);
    padding: 20px;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .ai-postcard-grid__item-{{ ai_gen_id }}:hover .ai-postcard-grid__overlay-{{ ai_gen_id }} {
    opacity: 1;
  }

  .ai-postcard-grid__product-title-{{ ai_gen_id }} {
    color: {{ block.settings.overlay_text_color }};
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 5px;
  }

  .ai-postcard-grid__product-price-{{ ai_gen_id }} {
    color: {{ block.settings.overlay_text_color }};
    font-size: 14px;
    margin: 0;
  }

  .ai-postcard-grid__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 989px) {
    .ai-postcard-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-postcard-grid-{{ ai_gen_id }} {
      padding: 30px 15px;
    }

    .ai-postcard-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.grid_gap | times: 0.7 }}px;
    }

    .ai-postcard-grid__product-title-{{ ai_gen_id }} {
      font-size: 14px;
    }

    .ai-postcard-grid__product-price-{{ ai_gen_id }} {
      font-size: 12px;
    }
  }
{% endstyle %}

<postcard-grid-{{ ai_gen_id }}
  class="ai-postcard-grid-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-postcard-grid__container-{{ ai_gen_id }}">
    {% for i in (1..12) %}
      {% liquid
        assign product_key = 'product_' | append: i
        assign image_key = 'image_' | append: i
        assign product = block.settings[product_key]
        assign image = block.settings[image_key]
      %}

      {% if product != blank or image != blank %}
        <div class="ai-postcard-grid__item-{{ ai_gen_id }}">
          {% if product != blank %}
            <a href="{{ product.url }}" class="ai-postcard-grid__link-{{ ai_gen_id }}">
              <div class="ai-postcard-grid__image-wrapper-{{ ai_gen_id }}">
                {% if image != blank %}
                  <img
                    src="{{ image | image_url: width: 800 }}"
                    alt="{{ image.alt | escape }}"
                    loading="lazy"
                    width="{{ image.width }}"
                    height="{{ image.height }}"
                    class="ai-postcard-grid__image-{{ ai_gen_id }}"
                  >
                {% elsif product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 800 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    loading="lazy"
                    width="{{ product.featured_image.width }}"
                    height="{{ product.featured_image.height }}"
                    class="ai-postcard-grid__image-{{ ai_gen_id }}"
                  >
                {% else %}
                  <div class="ai-postcard-grid__placeholder-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>

              {% if block.settings.show_product_info %}
                <div class="ai-postcard-grid__overlay-{{ ai_gen_id }}">
                  <h3 class="ai-postcard-grid__product-title-{{ ai_gen_id }}">{{ product.title }}</h3>
                  <p class="ai-postcard-grid__product-price-{{ ai_gen_id }}">{{ product.price | money }}</p>
                </div>
              {% endif %}
            </a>
          {% else %}
            <div class="ai-postcard-grid__link-{{ ai_gen_id }}">
              <div class="ai-postcard-grid__image-wrapper-{{ ai_gen_id }}">
                {% if image != blank %}
                  <img
                    src="{{ image | image_url: width: 800 }}"
                    alt="{{ image.alt | escape }}"
                    loading="lazy"
                    width="{{ image.width }}"
                    height="{{ image.height }}"
                    class="ai-postcard-grid__image-{{ ai_gen_id }}"
                  >
                {% else %}
                  <div class="ai-postcard-grid__placeholder-{{ ai_gen_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                    <div class="ai-postcard-grid__empty-state-{{ ai_gen_id }}">
                      Add a product or image
                    </div>
                  </div>
                {% endif %}
              </div>
            </div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</postcard-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class PostcardGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAccessibility();
      }

      setupAccessibility() {
        const links = this.querySelectorAll('.ai-postcard-grid__link-{{ ai_gen_id }}');
        links.forEach((link) => {
          if (link.href) {
            link.setAttribute('aria-label', 'View product details');
          }
        });
      }
    }

    customElements.define('postcard-grid-{{ ai_gen_id }}', PostcardGrid{{ ai_gen_id }});
  })();
</script>

