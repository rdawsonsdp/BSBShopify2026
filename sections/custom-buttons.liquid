{% comment %}
  LIFT: Relevance + Value — image-first nav tiles. Cream-banded section creates
  separation from the hero above; editorial eyebrow + heading set hierarchy;
  big confident labels carry the brand. Featured tile gets a caramel underline.
{% endcomment %}

<style>
  .custom-buttons-section {
    background: #f7ead6;
    padding: 32px 0 16px;
    margin: 0;
  }

  .custom-buttons-header {
    max-width: 1200px;
    margin: 0 auto 16px;
    padding: 0 16px;
    text-align: center;
  }

  .custom-buttons-eyebrow {
    display: block;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 800;
    color: #ba5b28;
    margin: 0 0 12px;
  }

  .custom-buttons-heading {
    font-family: 'Allura', 'Brush Script MT', cursive;
    font-size: clamp(40px, 9vw, 68px);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: 0;
    color: #570522;
    margin: 0;
    quotes: '\201C' '\201D';
  }
  .custom-buttons-heading::before {
    content: open-quote;
    margin-right: 2px;
  }
  .custom-buttons-heading::after {
    content: close-quote;
    margin-left: 2px;
  }
  .custom-buttons-attribution {
    display: block;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 700;
    color: #570522;
    opacity: 0.7;
    margin: 10px 0 0;
  }

  .custom-buttons-container {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
    margin: 0 auto;
    max-width: 1200px;
    padding: 0 16px;
  }

  .custom-button-wrapper {
    position: relative;
    display: block;
    border-radius: 10px;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    background: #fffaf2;
    box-shadow:
      0 4px 14px rgba(87, 5, 34, 0.16),
      0 1px 0 rgba(255, 255, 255, 0.55) inset;
    transform: translateY(0);
    transition:
      transform 320ms cubic-bezier(0.2, 0.8, 0.2, 1),
      box-shadow 320ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .custom-button-wrapper:hover,
  .custom-button-wrapper:focus-within {
    transform: translateY(-6px);
    box-shadow:
      0 18px 44px rgba(87, 5, 34, 0.34),
      0 2px 0 rgba(255, 255, 255, 0.55) inset;
  }

  .custom-button {
    display: block;
    position: relative;
    width: 100%;
    height: 100%;
    text-decoration: none;
    color: #fffaf2;
  }

  .custom-button__media {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .custom-button__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 700ms cubic-bezier(0.2, 0.8, 0.2, 1);
    will-change: transform;
  }

  .custom-button__placeholder {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(120% 80% at 30% 25%, rgba(255, 255, 255, 0.20), transparent 60%),
      linear-gradient(135deg, #570522 0%, #ba5b28 100%);
  }

  .custom-button-wrapper:hover .custom-button__image,
  .custom-button-wrapper:focus-within .custom-button__image {
    transform: scale(1.05);
  }

  .custom-button:focus-visible {
    outline: 2px solid #e68c3b;
    outline-offset: 3px;
  }

  /* Dark gradient at the bottom only — keeps the photo bright but locks in legibility */
  .custom-button__media::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0) 45%,
      rgba(0, 0, 0, 0.30) 70%,
      rgba(29, 10, 4, 0.78) 100%
    );
    pointer-events: none;
  }

  .custom-button__content {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 14px 16px 16px;
    z-index: 2;
    text-align: left;
  }

  .custom-button__label {
    display: block;
    font-size: clamp(20px, 5vw, 26px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: #fffaf2;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.55);
    margin: 0;
  }

  .custom-button__label::after {
    content: "";
    display: block;
    width: 28px;
    height: 2px;
    background: #e68c3b;
    margin-top: 8px;
    border-radius: 2px;
    box-shadow: 0 0 10px rgba(230, 140, 59, 0.5);
  }

  .custom-button__sub {
    display: block;
    margin-top: 8px;
    font-size: clamp(12px, 2.8vw, 14px);
    font-weight: 500;
    line-height: 1.4;
    color: rgba(255, 250, 242, 0.94);
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.55);
  }

  /* Featured tile — caramel underline strip at the top of the gradient */
  .custom-button-wrapper--featured::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 3px;
    background: #e68c3b;
    z-index: 3;
  }

  .custom-button__featured-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: #570522;
    color: #fffaf2;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.10em;
    padding: 5px 10px;
    border-radius: 999px;
    text-transform: uppercase;
    z-index: 3;
  }

  @media screen and (min-width: 768px) {
    .custom-buttons-section {
      padding: 56px 0 32px;
    }
    .custom-buttons-header {
      margin: 0 auto 28px;
    }
    .custom-buttons-container {
      grid-template-columns: repeat(3, 1fr);
      gap: 22px;
      padding: 0 24px;
    }

    .custom-button__content {
      padding: 20px 22px 24px;
    }

    .custom-button__label {
      font-size: 26px;
    }
    .custom-button__label::after {
      width: 36px;
      margin-top: 10px;
    }

    .custom-button__sub {
      font-size: 14px;
      margin-top: 10px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .custom-button__image {
      transition: none;
      transform: none;
    }
  }

  /* Zoom-into-sign for the Same Day Orders tile — focuses on the storefront sign */
  .custom-button-wrapper--zoom-sign .custom-button__image {
    object-position: center top;
    transform: scale(1.7);
    transform-origin: 50% 6%;
  }
  .custom-button-wrapper--zoom-sign:hover .custom-button__image,
  .custom-button-wrapper--zoom-sign:focus-within .custom-button__image {
    transform: scale(1.78);
  }

  /* Delivery partners — minimized footnote (most customers come through the apps) */
  .delivery-buttons {
    max-width: 1200px;
    margin: 0 auto 24px;
    padding: 0 20px;
    text-align: center;
    font-size: 12px;
    line-height: 1.5;
    color: #570522;
    opacity: 0.65;
  }
  .delivery-buttons__label {
    display: inline;
    margin: 0 6px 0 0;
    font-size: 12px;
    letter-spacing: 0;
    text-transform: none;
    color: inherit;
    opacity: 1;
    font-weight: 500;
  }
  .delivery-buttons__row {
    display: inline;
  }
  .delivery-buttons__row {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .delivery-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent !important;
    padding: 4px 8px;
    height: auto;
    transition: opacity 160ms ease, transform 160ms ease;
  }
  .delivery-button:hover,
  .delivery-button:focus-visible {
    opacity: 0.8;
    transform: translateY(-1px);
    outline: none;
  }
  .delivery-button__logo {
    display: block;
    height: 28px;
    width: auto;
    max-width: 140px;
    object-fit: contain;
  }
</style>

<section class="custom-buttons-section" aria-label="{{ section.settings.heading | default: 'Browse our cake collections' | escape }}">
  {% if section.settings.eyebrow != blank or section.settings.heading != blank %}
    <header class="custom-buttons-header">
      {% if section.settings.eyebrow != blank %}
        <p class="custom-buttons-eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="custom-buttons-heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}
      {% if section.settings.attribution != blank %}
        <p class="custom-buttons-attribution">— {{ section.settings.attribution | escape }}</p>
      {% endif %}
    </header>
  {% endif %}
  <div class="custom-buttons-container">
  {% comment %} Pickup (Order for Pickup) — moved to top {% endcomment %}
  <div class="custom-button-wrapper">
    <a href="{{ section.settings.pickup_url }}" class="custom-button">
      <span class="custom-button__media">
        {% if section.settings.pickup_image != blank %}
          <img class="custom-button__image" src="{{ section.settings.pickup_image | image_url: width: 800 }}" alt="{{ section.settings.pickup_label | escape }}" loading="lazy" width="800" height="800">
        {% else %}
          <img class="custom-button__image" src="{{ 'birthday-caramel-loaded.jpg' | asset_url }}" alt="{{ section.settings.pickup_label | escape }}" loading="lazy" width="800" height="800">
        {% endif %}
      </span>
      <span class="custom-button__content">
        <span class="custom-button__label">{{ section.settings.pickup_label }}</span>
        {% if section.settings.pickup_sub != blank %}
          <span class="custom-button__sub">{{ section.settings.pickup_sub | escape }}</span>
        {% endif %}
      </span>
    </a>
  </div>

  {% comment %} Events (featured) {% endcomment %}
  <div class="custom-button-wrapper custom-button-wrapper--featured">
    <a href="{{ section.settings.events_url }}" class="custom-button">
      <span class="custom-button__media">
        {% if section.settings.events_badge != blank %}
          <span class="custom-button__featured-badge">{{ section.settings.events_badge | escape }}</span>
        {% endif %}
        {% if section.settings.events_image != blank %}
          <img class="custom-button__image" src="{{ section.settings.events_image | image_url: width: 800 }}" alt="{{ section.settings.events_label | escape }}" loading="lazy" width="800" height="800">
        {% else %}
          <img class="custom-button__image" src="{{ 'events-white-tier-red-roses.jpg' | asset_url }}" alt="{{ section.settings.events_label | escape }}" loading="lazy" width="800" height="800">
        {% endif %}
      </span>
      <span class="custom-button__content">
        <span class="custom-button__label">{{ section.settings.events_label }}</span>
        {% if section.settings.events_sub != blank %}
          <span class="custom-button__sub">{{ section.settings.events_sub | escape }}</span>
        {% endif %}
      </span>
    </a>
  </div>

  {% comment %} Shipping {% endcomment %}
  <div class="custom-button-wrapper">
    <a href="{{ section.settings.shipping_url }}" class="custom-button">
      <span class="custom-button__media">
        {% if section.settings.shipping_image != blank %}
          <img class="custom-button__image" src="{{ section.settings.shipping_image | image_url: width: 800 }}" alt="{{ section.settings.shipping_label | escape }}" loading="lazy" width="800" height="800">
        {% else %}
          <img class="custom-button__image" src="{{ 'birthday-caramel-drip.jpg' | asset_url }}" alt="{{ section.settings.shipping_label | escape }}" loading="lazy" width="800" height="800">
        {% endif %}
      </span>
      <span class="custom-button__content">
        <span class="custom-button__label">{{ section.settings.shipping_label }}</span>
        {% if section.settings.shipping_sub != blank %}
          <span class="custom-button__sub">{{ section.settings.shipping_sub | escape }}</span>
        {% endif %}
      </span>
    </a>
  </div>

  {% comment %} Candy {% endcomment %}
  <div class="custom-button-wrapper">
    <a href="{{ section.settings.candy_url }}" class="custom-button">
      <span class="custom-button__media">
        {% if section.settings.candy_image != blank %}
          <img class="custom-button__image" src="{{ section.settings.candy_image | image_url: width: 800 }}" alt="{{ section.settings.candy_label | escape }}" loading="lazy" width="800" height="800">
        {% else %}
          <img class="custom-button__image" src="{{ 'candy-assorted-creams-feature.jpg' | asset_url }}" alt="{{ section.settings.candy_label | escape }}" loading="lazy" width="800" height="800">
        {% endif %}
      </span>
      <span class="custom-button__content">
        <span class="custom-button__label">{{ section.settings.candy_label }}</span>
        {% if section.settings.candy_sub != blank %}
          <span class="custom-button__sub">{{ section.settings.candy_sub | escape }}</span>
        {% endif %}
      </span>
    </a>
  </div>

  {% comment %} Same-Day In-Store {% endcomment %}
  <div class="custom-button-wrapper custom-button-wrapper--zoom-sign">
    <a href="{{ section.settings.instore_url }}" class="custom-button"{% if section.settings.instore_url contains '://' %} target="_blank" rel="noopener"{% endif %}>
      <span class="custom-button__media">
        {% if section.settings.instore_image != blank %}
          <img class="custom-button__image" src="{{ section.settings.instore_image | image_url: width: 800 }}" alt="{{ section.settings.instore_label | escape }}" loading="lazy" width="800" height="800">
        {% else %}
          <img class="custom-button__image" src="{{ 'bsb-storefront-stephanie.jpg' | asset_url }}" alt="{{ section.settings.instore_label | escape }}" loading="lazy" width="800" height="800">
        {% endif %}
      </span>
      <span class="custom-button__content">
        <span class="custom-button__label">{{ section.settings.instore_label }}</span>
        {% if section.settings.instore_sub != blank %}
          <span class="custom-button__sub">{{ section.settings.instore_sub | escape }}</span>
        {% endif %}
      </span>
    </a>
  </div>

  {% comment %} Birthdays {% endcomment %}
  <div class="custom-button-wrapper">
    <a href="{{ section.settings.birthday_url }}" class="custom-button">
      <span class="custom-button__media">
        {% if section.settings.birthday_image != blank %}
          <img class="custom-button__image" src="{{ section.settings.birthday_image | image_url: width: 800 }}" alt="{{ section.settings.birthday_label | escape }}" loading="lazy" width="800" height="800">
        {% else %}
          <img class="custom-button__image" src="{{ 'birthday-blue-caramel.jpg' | asset_url }}" alt="{{ section.settings.birthday_label | escape }}" loading="lazy" width="800" height="800">
        {% endif %}
      </span>
      <span class="custom-button__content">
        <span class="custom-button__label">{{ section.settings.birthday_label }}</span>
        {% if section.settings.birthday_sub != blank %}
          <span class="custom-button__sub">{{ section.settings.birthday_sub | escape }}</span>
        {% endif %}
      </span>
    </a>
  </div>
  </div>
</section>

{% if section.settings.uber_url != blank or section.settings.doordash_url != blank %}
<div class="delivery-buttons">
  {% if section.settings.delivery_label != blank %}
    <p class="delivery-buttons__label">{{ section.settings.delivery_label | escape }}</p>
  {% endif %}
  <div class="delivery-buttons__row">
    {% if section.settings.uber_url != blank %}
      <a href="{{ section.settings.uber_url }}" class="delivery-button delivery-button--uber" target="_blank" rel="noopener" aria-label="Order on Uber Eats">
        <img class="delivery-button__logo" src="{{ 'ubereats-logo.png' | asset_url }}" alt="Uber Eats" loading="lazy" width="140" height="40">
      </a>
    {% endif %}
    {% if section.settings.doordash_url != blank %}
      <a href="{{ section.settings.doordash_url }}" class="delivery-button delivery-button--doordash" target="_blank" rel="noopener" aria-label="Order on DoorDash">
        <img class="delivery-button__logo" src="{{ 'doordash-logo.png' | asset_url }}" alt="DoorDash" loading="lazy" width="140" height="40">
      </a>
    {% endif %}
  </div>
</div>
{% endif %}

