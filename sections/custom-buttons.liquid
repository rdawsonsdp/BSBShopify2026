{% comment %}
  Custom Responsive Buttons Section
  Intent-based buttons that direct shoppers to the collection matching their reason for visiting.
{% endcomment %}

{% assign btn_class = 'btn' %}
{% if settings.button_style %}
  {% assign btn_class = btn_class | append: ' btn--' | append: settings.button_style %}
{% endif %}

<style>
  .custom-buttons-container {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    margin: 24px auto;
    max-width: 1200px;
    padding: 0 20px;
  }

  .custom-button-wrapper {
    display: flex;
    min-width: 0;
  }

  .custom-button-wrapper.is-full-row {
    grid-column: 1 / -1;
  }

  .custom-button {
    width: 100%;
    min-width: 0;
    height: 56px;
    min-height: 56px;
    text-align: center;
    padding: 14px 8px;
    font-weight: 700;
    font-size: 13px;
    line-height: 1.2;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    white-space: nowrap;
    overflow: hidden;
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    box-shadow:
      0 2px 4px rgba(91, 37, 18, 0.12),
      0 6px 14px rgba(91, 37, 18, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.18);
    transform: translateY(0);
    transition:
      transform 220ms cubic-bezier(0.2, 0.8, 0.2, 1),
      box-shadow 220ms cubic-bezier(0.2, 0.8, 0.2, 1),
      filter 220ms ease;
    will-change: transform, box-shadow;
  }

  .custom-button::before {
    content: "";
    position: absolute;
    top: 0;
    left: -120%;
    width: 60%;
    height: 100%;
    background: linear-gradient(
      120deg,
      transparent 0%,
      rgba(255, 255, 255, 0.28) 50%,
      transparent 100%
    );
    transform: skewX(-20deg);
    transition: left 600ms ease;
    pointer-events: none;
  }

  .custom-button svg {
    flex-shrink: 0;
    transition: transform 220ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .custom-button:hover,
  .custom-button:focus-visible {
    transform: translateY(-3px);
    background-color: #570522;
    border-color: #570522;
    color: #ffffff;
    box-shadow:
      0 6px 10px rgba(87, 5, 34, 0.24),
      0 14px 28px rgba(87, 5, 34, 0.34),
      inset 0 1px 0 rgba(255, 255, 255, 0.18);
    outline: none;
  }

  .custom-button:hover::before,
  .custom-button:focus-visible::before {
    left: 130%;
  }

  .custom-button:hover svg,
  .custom-button:focus-visible svg {
    transform: scale(1.12);
  }

  .custom-button:active {
    transform: translateY(-1px);
    box-shadow:
      0 2px 4px rgba(91, 37, 18, 0.18),
      0 4px 10px rgba(91, 37, 18, 0.18);
    transition-duration: 80ms;
  }

  /* Featured button (e.g., Mother's Day during the seasonal window) */
  .custom-button-wrapper {
    flex-direction: column;
    align-items: stretch;
  }

  .custom-button__sub {
    display: block;
    text-align: center;
    font-size: 11px;
    line-height: 1.3;
    color: #570522;
    opacity: 0.72;
    margin: 6px 4px 0;
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  @media screen and (max-width: 575px) {
    .custom-button__sub {
      font-size: 10px;
      margin-top: 4px;
    }
  }

  .custom-button.custom-button--featured {
    background-color: #e68c3b;
    color: #570522;
    border-color: #e68c3b;
    box-shadow:
      0 3px 6px rgba(230, 140, 59, 0.30),
      0 10px 22px rgba(230, 140, 59, 0.32),
      inset 0 1px 0 rgba(255, 255, 255, 0.30);
    animation: custom-button-pulse 2.4s ease-in-out infinite;
  }

  .custom-button.custom-button--featured:hover,
  .custom-button.custom-button--featured:focus-visible {
    background-color: #570522;
    color: #ffffff;
    border-color: #570522;
    animation: none;
  }

  .custom-button__featured-badge {
    position: absolute;
    top: -8px;
    right: -8px;
    background-color: #e6432b;
    color: #ffffff;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.06em;
    padding: 4px 8px;
    border-radius: 999px;
    text-transform: uppercase;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.25);
    z-index: 2;
  }

  @keyframes custom-button-pulse {
    0%, 100% {
      box-shadow:
        0 3px 6px rgba(230, 140, 59, 0.30),
        0 10px 22px rgba(230, 140, 59, 0.32),
        inset 0 1px 0 rgba(255, 255, 255, 0.30);
    }
    50% {
      box-shadow:
        0 4px 10px rgba(230, 140, 59, 0.45),
        0 14px 30px rgba(230, 140, 59, 0.48),
        inset 0 1px 0 rgba(255, 255, 255, 0.35);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .custom-button.custom-button--featured {
      animation: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .custom-button,
    .custom-button::before,
    .custom-button svg {
      transition: none;
    }
    .custom-button:hover,
    .custom-button:focus-visible {
      transform: none;
    }
  }

  @media screen and (min-width: 768px) {
    .custom-buttons-container {
      grid-template-columns: repeat(3, 1fr);
      gap: 15px;
      margin: 30px auto;
    }

    .custom-button-wrapper.is-full-row {
      grid-column: auto;
    }

    .custom-button {
      padding: 14px 16px;
      font-size: 15px;
    }
  }
</style>

<div class="custom-buttons-container">
  <div class="custom-button-wrapper">
    <a href="{{ section.settings.birthday_url }}" class="custom-button {{ btn_class }}">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M20 21v-8a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v8"></path>
        <path d="M4 16s.5-1 2-1 2.5 2 4 2 2.5-2 4-2 2.5 2 4 2 2-1 2-1"></path>
        <path d="M2 21h20"></path>
        <path d="M7 8v3"></path>
        <path d="M12 8v3"></path>
        <path d="M17 8v3"></path>
        <path d="M7 4c0 1-1 1-1 2s1 1 1 2"></path>
        <path d="M12 4c0 1-1 1-1 2s1 1 1 2"></path>
        <path d="M17 4c0 1-1 1-1 2s1 1 1 2"></path>
      </svg>
      {{ section.settings.birthday_label }}
    </a>
    {% if section.settings.birthday_sub != blank %}<span class="custom-button__sub">{{ section.settings.birthday_sub | escape }}</span>{% endif %}
  </div>

  <div class="custom-button-wrapper">
    <a href="{{ section.settings.events_url }}" class="custom-button custom-button--featured {{ btn_class }}">
      {% if section.settings.events_badge != blank %}
        <span class="custom-button__featured-badge">{{ section.settings.events_badge | escape }}</span>
      {% endif %}
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="12" y1="2" x2="12" y2="5"></line>
        <circle cx="12" cy="2" r="0.7" fill="currentColor"></circle>
        <rect x="9" y="5" width="6" height="5"></rect>
        <rect x="6" y="10" width="12" height="5"></rect>
        <rect x="3" y="15" width="18" height="5"></rect>
        <line x1="2" y1="20" x2="22" y2="20"></line>
      </svg>
      {{ section.settings.events_label }}
    </a>
    {% if section.settings.events_sub != blank %}<span class="custom-button__sub">{{ section.settings.events_sub | escape }}</span>{% endif %}
  </div>

  <div class="custom-button-wrapper">
    <a href="{{ section.settings.shipping_url }}" class="custom-button {{ btn_class }}">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="1" y="3" width="15" height="13"></rect>
        <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
        <circle cx="5.5" cy="18.5" r="2.5"></circle>
        <circle cx="18.5" cy="18.5" r="2.5"></circle>
      </svg>
      {{ section.settings.shipping_label }}
    </a>
    {% if section.settings.shipping_sub != blank %}<span class="custom-button__sub">{{ section.settings.shipping_sub | escape }}</span>{% endif %}
  </div>

  <div class="custom-button-wrapper">
    <a href="{{ section.settings.candy_url }}" class="custom-button {{ btn_class }}">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M14.5 9.5 9.5 14.5"></path>
        <path d="m8.5 8.5 7 7"></path>
        <circle cx="12" cy="12" r="4"></circle>
        <path d="M8 8 4 4"></path>
        <path d="M4 4v4h4"></path>
        <path d="m16 16 4 4"></path>
        <path d="M20 20v-4h-4"></path>
      </svg>
      {{ section.settings.candy_label }}
    </a>
    {% if section.settings.candy_sub != blank %}<span class="custom-button__sub">{{ section.settings.candy_sub | escape }}</span>{% endif %}
  </div>

  <div class="custom-button-wrapper">
    <a href="{{ section.settings.pickup_url }}" class="custom-button {{ btn_class }}">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <path d="M16 10a4 4 0 0 1-8 0"></path>
      </svg>
      {{ section.settings.pickup_label }}
    </a>
    {% if section.settings.pickup_sub != blank %}<span class="custom-button__sub">{{ section.settings.pickup_sub | escape }}</span>{% endif %}
  </div>

  <div class="custom-button-wrapper">
    <a href="{{ section.settings.instore_url }}" class="custom-button {{ btn_class }}"{% if section.settings.instore_url contains '://' %} target="_blank" rel="noopener"{% endif %}>
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 9l1-5h16l1 5"></path>
        <path d="M4 9v11a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1V9"></path>
        <path d="M9 21V14h6v7"></path>
        <circle cx="12" cy="12" r="0.5" fill="currentColor"></circle>
      </svg>
      {{ section.settings.instore_label }}
    </a>
    {% if section.settings.instore_sub != blank %}<span class="custom-button__sub">{{ section.settings.instore_sub | escape }}</span>{% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Custom Buttons",
  "settings": [
    {
      "type": "header",
      "content": "Birthday Cakes"
    },
    {
      "type": "text",
      "id": "birthday_label",
      "label": "Button Label",
      "default": "Birthdays"
    },
    {
      "type": "url",
      "id": "birthday_url",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "birthday_sub",
      "label": "Sub-text (optional)",
      "info": "Small line under the button. e.g., \"Order 3 days ahead for pickup\""
    },
    {
      "type": "header",
      "content": "Events & Catering (featured / pulsing)"
    },
    {
      "type": "text",
      "id": "events_label",
      "label": "Button Label",
      "default": "Events"
    },
    {
      "type": "text",
      "id": "events_badge",
      "label": "Corner badge (optional)",
      "info": "Empty to hide. Useful for promos like \"NEW\" or \"INQUIRE\"."
    },
    {
      "type": "url",
      "id": "events_url",
      "label": "Button Link",
      "info": "Recommend a dedicated /pages/events page with weddings, corporate, and bulk-order info."
    },
    {
      "type": "text",
      "id": "events_sub",
      "label": "Sub-text (optional)",
      "info": "Small line under the button. e.g., \"Weddings, corporate, custom orders\""
    },
    {
      "type": "header",
      "content": "Nationwide Shipping"
    },
    {
      "type": "text",
      "id": "shipping_label",
      "label": "Button Label",
      "default": "Shipping"
    },
    {
      "type": "url",
      "id": "shipping_url",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "shipping_sub",
      "label": "Sub-text (optional)",
      "info": "Small line under the button. e.g., \"Arrives fresh in 2-3 days\""
    },
    {
      "type": "header",
      "content": "Candy"
    },
    {
      "type": "text",
      "id": "candy_label",
      "label": "Button Label",
      "default": "Shop Candy"
    },
    {
      "type": "url",
      "id": "candy_url",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "candy_sub",
      "label": "Sub-text (optional)",
      "info": "Small line under the button. e.g., \"Hand-poured & boxed daily\""
    },
    {
      "type": "header",
      "content": "Pickup (Shopify pickup-eligible)"
    },
    {
      "type": "text",
      "id": "pickup_label",
      "label": "Button Label",
      "default": "Pre Order"
    },
    {
      "type": "url",
      "id": "pickup_url",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "pickup_sub",
      "label": "Sub-text (optional)",
      "info": "Small line under the button. e.g., \"Order ahead, skip the line\""
    },
    {
      "type": "header",
      "content": "Pick Up Today In Store (Clover)"
    },
    {
      "type": "text",
      "id": "instore_label",
      "label": "Button Label",
      "default": "Same Day"
    },
    {
      "type": "url",
      "id": "instore_url",
      "label": "Button Link",
      "info": "Link to the Clover online ordering page or future in-store-only collection"
    },
    {
      "type": "text",
      "id": "instore_sub",
      "label": "Sub-text (optional)",
      "info": "Small line under the button. e.g., \"From in-store inventory\""
    }
  ],
  "presets": [
    {
      "name": "Custom Buttons",
      "category": "Custom Content"
    }
  ]
}
{% endschema %}
