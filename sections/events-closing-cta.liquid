{% comment %}
  LIFT: Clarity — repeats the single action the page wants the visitor to take
  (submit the inquiry form). The caramel band visually breaks the cream rhythm
  of the page so this is the obvious last call.
{% endcomment %}

<section class="events-cta events-cta--{{ section.id }}">
  <div class="events-cta__inner">
    {% if section.settings.eyebrow != blank %}
      <p class="events-cta__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2 class="events-cta__heading">{{ section.settings.heading | escape }}</h2>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p class="events-cta__subheading">{{ section.settings.subheading | escape }}</p>
    {% endif %}
    {% if section.settings.button_label != blank and section.settings.button_link != blank %}
      <a href="{{ section.settings.button_link }}" class="events-cta__button">{{ section.settings.button_label | escape }}</a>
    {% endif %}
    {% if section.settings.microcopy != blank %}
      <p class="events-cta__microcopy">{{ section.settings.microcopy | escape }}</p>
    {% endif %}
  </div>
</section>

<style>
  .events-cta--{{ section.id }} {
    background: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding: 40px 16px;
  }
  .events-cta--{{ section.id }} .events-cta__inner {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }
  .events-cta--{{ section.id }} .events-cta__eyebrow {
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 700;
    margin: 0 0 8px;
    color: {{ section.settings.text_color }};
    opacity: 0.8;
  }
  .events-cta--{{ section.id }} .events-cta__heading {
    font-size: clamp(26px, 5vw, 38px);
    font-weight: 800;
    line-height: 1.1;
    margin: 0 0 12px;
    color: {{ section.settings.text_color }};
    text-align: center;
  }
  .events-cta--{{ section.id }} .events-cta__subheading {
    font-size: clamp(15px, 2.2vw, 18px);
    line-height: 1.5;
    margin: 0 0 22px;
    color: {{ section.settings.text_color }};
    opacity: 0.9;
    text-align: center;
  }
  .events-cta--{{ section.id }} .events-cta__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 4px;
    padding: 16px 32px;
    background: linear-gradient(180deg, #6c0a2e 0%, {{ section.settings.button_bg_color }} 60%, #45041b 100%);
    color: {{ section.settings.button_text_color }};
    border: 1px solid #2e0212;
    border-radius: 5px;
    font-weight: 700;
    font-size: 15px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.22),
      inset 0 -1px 0 rgba(0, 0, 0, 0.28),
      0 2px 0 rgba(46, 2, 18, 0.5),
      0 3px 6px rgba(46, 2, 18, 0.22);
    text-shadow: 0 1px 0 rgba(0, 0, 0, 0.35);
    transition: background 180ms ease, border-color 180ms ease, transform 80ms ease, box-shadow 180ms ease;
  }
  .events-cta--{{ section.id }} .events-cta__button:hover {
    background: linear-gradient(180deg, #f0a25a 0%, #e68c3b 60%, #c5731f 100%);
    border-color: #8a4a16;
    color: #570522;
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.25);
  }
  .events-cta--{{ section.id }} .events-cta__button:active {
    transform: translateY(2px);
    box-shadow:
      inset 0 1px 2px rgba(0, 0, 0, 0.35),
      0 0 0 rgba(46, 2, 18, 0),
      0 1px 2px rgba(46, 2, 18, 0.18);
  }
  .events-cta--{{ section.id }} .events-cta__microcopy {
    font-size: 13px;
    font-style: italic;
    line-height: 1.4;
    margin: 14px 0 0;
    color: {{ section.settings.text_color }};
    opacity: 0.7;
    text-align: center;
  }

  @media screen and (min-width: 768px) {
    .events-cta--{{ section.id }} {
      padding: 64px 24px;
    }
    .events-cta--{{ section.id }} .events-cta__microcopy {
      font-size: 14px;
    }
  }
</style>

{% schema %}
{
  "name": "Events closing CTA",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow (optional)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Whatever you're planning, we can bake it."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Tell us your date — we'll do the rest."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Send my event details"
    },
    {
      "type": "text",
      "id": "button_link",
      "label": "Button link",
      "default": "#event-inquiry",
      "info": "Use #event-inquiry to scroll to the form on this page, or paste any full URL."
    },
    {
      "type": "text",
      "id": "microcopy",
      "label": "Microcopy below CTA",
      "default": "We will respond within 48 hours."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ba5b28"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#f7ead6"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button background (mid-stop)",
      "default": "#570522"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Events closing CTA",
      "category": "Text"
    }
  ]
}
{% endschema %}
