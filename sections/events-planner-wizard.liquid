<script>
  (function () {
    var sectionEl = document.querySelector('.events-planner--{{ section.id }}');
    if (!sectionEl) return;
    var form = sectionEl.querySelector('.events-planner__form');
    var steps = sectionEl.querySelectorAll('[data-events-planner-step]');
    var progressItems = sectionEl.querySelectorAll('[data-events-planner-progress]');
    var nextBtns = sectionEl.querySelectorAll('[data-events-planner-next]');
    var prevBtns = sectionEl.querySelectorAll('[data-events-planner-prev]');
    var retryBtn = sectionEl.querySelector('[data-events-planner-retry]');
    var openBtn = sectionEl.querySelector('[data-events-planner-open]');
    var modal = sectionEl.querySelector('[data-events-planner-modal]');
    var closeBtns = sectionEl.querySelectorAll('[data-events-planner-close]');
    var current = 1;

    function openModal() {
      if (!modal) return;
      modal.hidden = false;
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }
    function closeModal() {
      if (!modal) return;
      modal.hidden = true;
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }
    if (openBtn) openBtn.addEventListener('click', openModal);
    closeBtns.forEach(function (b) { b.addEventListener('click', closeModal); });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && modal && !modal.hidden) closeModal();
    });

    function showStep(stepKey) {
      steps.forEach(function (s) {
        var key = s.getAttribute('data-events-planner-step');
        if (String(key) === String(stepKey)) {
          s.hidden = false;
          s.classList.add('is-active');
        } else {
          s.hidden = true;
          s.classList.remove('is-active');
        }
      });
      progressItems.forEach(function (p) {
        var n = parseInt(p.getAttribute('data-events-planner-progress'), 10);
        p.classList.remove('is-active', 'is-done');
        if (typeof stepKey === 'number') {
          if (n < stepKey) p.classList.add('is-done');
          if (n === stepKey) p.classList.add('is-active');
        }
      });
      // Scroll the section into view smoothly when stepping
      sectionEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function validateStep(n) {
      var step = sectionEl.querySelector('[data-events-planner-step="' + n + '"]');
      if (!step) return true;
      var fields = step.querySelectorAll('input[required], select[required], textarea[required]');
      for (var i = 0; i < fields.length; i++) {
        if (!fields[i].value || (fields[i].type === 'radio' && !sectionEl.querySelector('input[name="' + fields[i].name + '"]:checked'))) {
          fields[i].reportValidity ? fields[i].reportValidity() : fields[i].focus();
          return false;
        }
        if (fields[i].type === 'email' && !/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(fields[i].value)) {
          fields[i].reportValidity ? fields[i].reportValidity() : fields[i].focus();
          return false;
        }
      }
      return true;
    }

    // Enable Continue on step 1 when an event_type is chosen
    var step1Radios = sectionEl.querySelectorAll('input[name="event_type"]');
    var step1Continue = sectionEl.querySelector('[data-events-planner-step="1"] [data-events-planner-next]');
    step1Radios.forEach(function (r) {
      r.addEventListener('change', function () {
        if (step1Continue) step1Continue.disabled = false;
      });
    });

    nextBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        if (!validateStep(current)) return;
        current = Math.min(current + 1, 4);
        showStep(current);
      });
    });
    prevBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        current = Math.max(current - 1, 1);
        showStep(current);
      });
    });
    if (retryBtn) {
      retryBtn.addEventListener('click', function () {
        current = 1;
        showStep(1);
      });
    }

    // Submit handler
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      if (!validateStep(4)) return;
      // Honeypot
      if (form.querySelector('input[name="website"]').value) {
        showStep('success');
        return;
      }
      var data = {};
      Array.prototype.forEach.call(form.elements, function (el) {
        if (!el.name || el.type === 'submit' || el.name === 'website') return;
        if (el.type === 'radio' && !el.checked) return;
        data[el.name] = el.value;
      });

      var endpoint = form.getAttribute('data-endpoint');
      var anonKey = form.getAttribute('data-anon-key');

      // No endpoint configured → simulate success (UI review mode)
      if (!endpoint || endpoint.indexOf('placeholder') !== -1) {
        console.log('[events-planner] simulated submission:', data);
        showStep('success');
        return;
      }

      var headers = { 'Content-Type': 'application/json' };
      if (anonKey) {
        headers['Authorization'] = 'Bearer ' + anonKey;
        headers['apikey'] = anonKey;
      }
      var submitBtn = form.querySelector('button[type="submit"]');
      if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Sending…'; }

      fetch(endpoint, { method: 'POST', headers: headers, body: JSON.stringify(data) })
        .then(function (r) {
          if (!r.ok) throw new Error('Request failed');
          return r.json().catch(function () { return {}; });
        })
        .then(function () { showStep('success'); })
        .catch(function (err) {
          console.error('[events-planner] submission error:', err);
          showStep('error');
        })
        .finally(function () {
          if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Send my event details'; }
        });
    });
  })();
</script>

