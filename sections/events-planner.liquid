{% comment %}
  Events Planner — invitation-card modal.
  Trigger button on the page; clicking opens an envelope-style modal with the
  full conversational form inside. Event-type dropdown drives conditional
  follow-up fields. Submits to Supabase Edge Function `submit-event-inquiry`.
{% endcomment %}

<section class="events-planner events-planner--{{ section.id }}" data-events-planner aria-label="{{ section.settings.heading | default: 'Plan your event' | escape }}">

  {% comment %} ─── Trigger envelope — sealed shut, click to open ─── {% endcomment %}
  <button type="button" class="events-planner__trigger-card" data-events-planner-open aria-label="{{ section.settings.trigger_aria | default: 'Open invitation to plan your event' | escape }}">
    {% comment %} Triangular flap pointing DOWN from top — sealed {% endcomment %}
    <span class="events-planner__envelope-flap" aria-hidden="true"></span>
    <span class="events-planner__envelope-flap-shadow" aria-hidden="true"></span>

    {% comment %} Postage stamp + postmark on the front {% endcomment %}
    <span class="events-planner__trigger-stamp" aria-hidden="true">
      <span class="events-planner__trigger-stamp-inner">
        <span class="events-planner__trigger-stamp-mono">B</span>
        <span class="events-planner__trigger-stamp-text">BROWN SUGAR<br>BAKERY · CHGO</span>
      </span>
    </span>
    <span class="events-planner__trigger-postmark" aria-hidden="true">
      <span class="events-planner__trigger-postmark-arc">CHICAGO · IL · 75TH ST</span>
      <span class="events-planner__trigger-postmark-date">SINCE 2004</span>
    </span>

    {% comment %} BSB stamp seal at the flap apex (sealing it shut) {% endcomment %}
    <span class="events-planner__envelope-seal" aria-hidden="true">
      <span class="events-planner__envelope-seal-mono">B</span>
    </span>

    {% comment %} Address-style label centered below the seal {% endcomment %}
    <span class="events-planner__envelope-address">
      <span class="events-planner__envelope-address-line1">{{ section.settings.trigger_eyebrow | default: 'YOU ARE INVITED' | escape }}</span>
      <span class="events-planner__envelope-address-line2">{{ section.settings.trigger_btn_label | default: 'Tap to open' | escape }}</span>
    </span>
  </button>

  {% comment %} ─── Modal (initially hidden) ─── {% endcomment %}
  <div class="events-planner__modal" data-events-planner-modal aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="events-planner-title-{{ section.id }}">
    <div class="events-planner__modal-overlay" data-events-planner-close></div>

    <div class="events-planner__envelope" data-events-planner-envelope>
      <div class="events-planner__envelope-flap" aria-hidden="true"></div>
      <div class="events-planner__envelope-seal" aria-hidden="true">B</div>

      <div class="events-planner__card">
        <button type="button" class="events-planner__close" data-events-planner-close aria-label="Close planner">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>

        <div class="events-planner__card-inner">

          {% comment %} Invitation header inside the card {% endcomment %}
          <header class="events-planner__card-header">
            <p class="events-planner__card-eyebrow">{{ section.settings.eyebrow | default: 'PLAN YOUR EVENT' | escape }}</p>
            <h2 class="events-planner__card-title" id="events-planner-title-{{ section.id }}">{{ section.settings.heading | default: 'Tell me about your day.' | escape }}</h2>
            {% if section.settings.intro_quote != blank %}
              <p class="events-planner__card-quote">{{ section.settings.intro_quote }}</p>
            {% endif %}
            {% if section.settings.persona_name != blank %}
              <p class="events-planner__card-attribution">— {{ section.settings.persona_name | escape }}{% if section.settings.persona_title != blank %}, <em>{{ section.settings.persona_title | escape }}</em>{% endif %}</p>
            {% endif %}
            <span class="events-planner__divider" aria-hidden="true"></span>
          </header>

          <form
            class="events-planner__form"
            data-events-planner-form
            enctype="multipart/form-data"
            novalidate
            data-endpoint="{{ section.settings.endpoint_url | default: 'https://rdmosawrnjqbhhihnagj.supabase.co/functions/v1/submit-event-inquiry' }}"
            data-source-url="{{ canonical_url | default: shop.url }}"
          >
            {% comment %} Honeypot {% endcomment %}
            <div class="events-planner__honeypot" aria-hidden="true">
              <label>Website <input type="text" name="website" tabindex="-1" autocomplete="off"></label>
            </div>

            {% comment %} ─── Step 1: Event type ─── {% endcomment %}
            <fieldset class="events-planner__panel" data-events-planner-panel="event">
              <legend class="events-planner__panel-label">What are we celebrating?</legend>
              <div class="events-planner__field">
                <label for="event_type-{{ section.id }}" class="sr-only">Event type</label>
                <select name="event_type" id="event_type-{{ section.id }}" required data-events-planner-event-type>
                  <option value="" disabled selected>Pick one to get started…</option>
                  <option value="Wedding">Wedding</option>
                  <option value="Corporate event">Corporate event</option>
                  <option value="Birthday milestone">Birthday milestone</option>
                  <option value="Anniversary">Anniversary</option>
                  <option value="Holiday party">Holiday party</option>
                  <option value="Memorial / celebration of life">Memorial / celebration of life</option>
                  <option value="Other">Something else</option>
                </select>
              </div>
              <p class="events-planner__hint">No commitment — this is just a conversation start.</p>
            </fieldset>

            {% comment %} ─── Step 2: Details + conditional ─── {% endcomment %}
            <fieldset class="events-planner__panel" data-events-planner-panel="details" hidden>
              <legend class="events-planner__panel-label">Tell me about it.</legend>

              <div class="events-planner__row">
                <div class="events-planner__field">
                  <label for="event_date-{{ section.id }}">When?</label>
                  <input type="date" name="event_date" id="event_date-{{ section.id }}">
                  <label class="events-planner__inline-check">
                    <input type="checkbox" name="date_flexible" value="true">
                    <span>Flexible</span>
                  </label>
                </div>
                <div class="events-planner__field">
                  <label for="location-{{ section.id }}">Where?</label>
                  <input type="text" name="location" id="location-{{ section.id }}" placeholder="Chicago / suburb / out of town">
                </div>
              </div>

              <div class="events-planner__row">
                <div class="events-planner__field">
                  <label for="guest_count-{{ section.id }}">How many guests?</label>
                  <input type="number" name="guest_count" id="guest_count-{{ section.id }}" min="1" placeholder="e.g. 80">
                  <label class="events-planner__inline-check">
                    <input type="checkbox" name="guest_unknown" value="true">
                    <span>Not sure yet</span>
                  </label>
                </div>
                <div class="events-planner__field">
                  <label for="budget_range-{{ section.id }}">Budget range?</label>
                  <select name="budget_range" id="budget_range-{{ section.id }}">
                    <option value="">Pick one…</option>
                    <option value="$300–$750">$300 – $750</option>
                    <option value="$750–$1,500">$750 – $1,500</option>
                    <option value="$1,500–$3,000">$1,500 – $3,000</option>
                    <option value="$3,000+">$3,000+</option>
                    <option value="Help me figure this out">Help me figure this out</option>
                  </select>
                </div>
              </div>

              <div class="events-planner__conditional" data-events-planner-conditional-for="Wedding" hidden>
                <h4 class="events-planner__conditional-label">A couple wedding specifics</h4>
                <div class="events-planner__row">
                  <div class="events-planner__field">
                    <label>Cutting cake or dessert table?</label>
                    <select name="cond_format" data-conditional-key="cake_or_table">
                      <option value="">Pick one…</option>
                      <option value="Cutting cake">Cutting cake</option>
                      <option value="Dessert table">Dessert table</option>
                      <option value="Both">Both</option>
                      <option value="Not sure yet">Not sure yet</option>
                    </select>
                  </div>
                  <div class="events-planner__field">
                    <label>Will the venue provide plates?</label>
                    <select name="cond_plates" data-conditional-key="venue_plates">
                      <option value="">Pick one…</option>
                      <option value="Yes">Yes</option>
                      <option value="No, I need them">No, I need them</option>
                      <option value="Not sure">Not sure</option>
                    </select>
                  </div>
                </div>
              </div>

              <div class="events-planner__conditional" data-events-planner-conditional-for="Corporate event" hidden>
                <h4 class="events-planner__conditional-label">A couple corporate specifics</h4>
                <div class="events-planner__row">
                  <div class="events-planner__field">
                    <label>One-time or recurring?</label>
                    <select name="cond_cadence" data-conditional-key="cadence">
                      <option value="">Pick one…</option>
                      <option value="One-time event">One-time event</option>
                      <option value="Recurring (monthly)">Recurring (monthly)</option>
                      <option value="Recurring (quarterly)">Recurring (quarterly)</option>
                      <option value="Recurring (annual)">Recurring (annual)</option>
                    </select>
                  </div>
                  <div class="events-planner__field">
                    <label>Branded or themed?</label>
                    <select name="cond_branded" data-conditional-key="branded">
                      <option value="">Pick one…</option>
                      <option value="Logo / company colors">Logo / company colors</option>
                      <option value="Themed (not branded)">Themed (not branded)</option>
                      <option value="Plain — just delicious">Plain — just delicious</option>
                    </select>
                  </div>
                </div>
              </div>

              <div class="events-planner__conditional" data-events-planner-conditional-for="Birthday milestone" hidden>
                <h4 class="events-planner__conditional-label">A couple birthday specifics</h4>
                <div class="events-planner__row">
                  <div class="events-planner__field">
                    <label>Whose birthday?</label>
                    <input type="text" name="cond_honoree" data-conditional-key="honoree" placeholder="Name + age">
                  </div>
                  <div class="events-planner__field">
                    <label>Is it a surprise?</label>
                    <select name="cond_surprise" data-conditional-key="surprise">
                      <option value="">Pick one…</option>
                      <option value="Yes — surprise!">Yes — surprise!</option>
                      <option value="No, they know">No, they know</option>
                    </select>
                  </div>
                </div>
              </div>

              <div class="events-planner__conditional" data-events-planner-conditional-for="Anniversary" hidden>
                <h4 class="events-planner__conditional-label">A couple anniversary specifics</h4>
                <div class="events-planner__row">
                  <div class="events-planner__field">
                    <label>Years celebrating?</label>
                    <input type="number" name="cond_years" data-conditional-key="years" min="1" placeholder="e.g. 25">
                  </div>
                  <div class="events-planner__field">
                    <label>Recreating a wedding cake?</label>
                    <select name="cond_recreate" data-conditional-key="recreate_wedding_cake">
                      <option value="">Pick one…</option>
                      <option value="Yes — I have a photo">Yes — I have a photo</option>
                      <option value="Inspired by it">Inspired by it</option>
                      <option value="No, something new">No, something new</option>
                    </select>
                  </div>
                </div>
              </div>

              <div class="events-planner__conditional" data-events-planner-conditional-for="Holiday party" hidden>
                <h4 class="events-planner__conditional-label">A couple holiday specifics</h4>
                <div class="events-planner__row">
                  <div class="events-planner__field">
                    <label>Which holiday?</label>
                    <select name="cond_holiday" data-conditional-key="holiday">
                      <option value="">Pick one…</option>
                      <option value="Christmas">Christmas</option>
                      <option value="Juneteenth">Juneteenth</option>
                      <option value="Easter">Easter</option>
                      <option value="Thanksgiving">Thanksgiving</option>
                      <option value="New Year">New Year</option>
                      <option value="Mother's Day">Mother's Day</option>
                      <option value="Father's Day">Father's Day</option>
                      <option value="Other">Other</option>
                    </select>
                  </div>
                  <div class="events-planner__field">
                    <label>Mostly cake or assorted?</label>
                    <select name="cond_assortment" data-conditional-key="assortment">
                      <option value="">Pick one…</option>
                      <option value="Mostly cake">Mostly cake</option>
                      <option value="Assorted desserts">Assorted desserts</option>
                      <option value="Both">Both</option>
                    </select>
                  </div>
                </div>
              </div>

              <div class="events-planner__conditional" data-events-planner-conditional-for="Memorial / celebration of life" hidden>
                <h4 class="events-planner__conditional-label">A few gentle questions</h4>
                <div class="events-planner__row">
                  <div class="events-planner__field">
                    <label>Single sitting or ongoing reception?</label>
                    <select name="cond_format" data-conditional-key="format">
                      <option value="">Pick one…</option>
                      <option value="Single sitting (post-service)">Single sitting (post-service)</option>
                      <option value="Ongoing reception">Ongoing reception</option>
                    </select>
                  </div>
                  <div class="events-planner__field">
                    <label>A specific recipe to honor?</label>
                    <input type="text" name="cond_honor_recipe" data-conditional-key="honor_recipe" placeholder="e.g. her grandmother's pound cake">
                  </div>
                </div>
              </div>

              <div class="events-planner__conditional" data-events-planner-conditional-for="Other" hidden>
                <h4 class="events-planner__conditional-label">Tell me a bit more</h4>
                <div class="events-planner__field">
                  <label>What kind of event is it?</label>
                  <input type="text" name="cond_other_type" data-conditional-key="other_type" placeholder="Graduation, baby shower, retirement, fundraiser…">
                </div>
              </div>
            </fieldset>

            {% comment %} ─── Step 3: Vision ─── {% endcomment %}
            <fieldset class="events-planner__panel" data-events-planner-panel="vision" hidden>
              <legend class="events-planner__panel-label">What are you picturing?</legend>

              <div class="events-planner__field">
                <label for="vision_text-{{ section.id }}">In your own words…</label>
                <textarea
                  name="vision_text"
                  id="vision_text-{{ section.id }}"
                  rows="4"
                  placeholder="Colors, theme, vibe, must-haves — or just &quot;caramel cake for 80, plus mini cupcakes&quot;. Whatever you've got."
                ></textarea>
              </div>

              <div class="events-planner__field">
                <label>Any of these jump out?</label>
                <div class="events-planner__chips" data-events-planner-chips="preferences">
                  {%- assign pref_options = 'Tiered cake|Single layer|Caramel|German chocolate|Strawberry|Pineapple|Lemon|Custom flavor|Mini desserts|Plated dessert|Cupcakes|Candy table' | split: '|' -%}
                  {% for opt in pref_options %}
                    <button type="button" class="events-planner__chip" data-chip-value="{{ opt | escape }}">{{ opt | escape }}</button>
                  {% endfor %}
                </div>
                <input type="hidden" name="preferences" data-events-planner-chips-input value="">
              </div>

              <div class="events-planner__field">
                <label>Dietary restrictions?</label>
                <div class="events-planner__chips" data-events-planner-chips="dietary">
                  {%- assign diet_options = 'Gluten-free|Nut-free|Dairy-free|Vegan|Egg-free|Other' | split: '|' -%}
                  {% for opt in diet_options %}
                    <button type="button" class="events-planner__chip" data-chip-value="{{ opt | escape }}">{{ opt | escape }}</button>
                  {% endfor %}
                </div>
                <input type="hidden" name="dietary" data-events-planner-chips-input value="">
              </div>

              <div class="events-planner__field">
                <label>Inspiration photos? <small>(optional, up to 5 — each ≤5MB)</small></label>
                <div class="events-planner__upload" data-events-planner-upload>
                  <input type="file" name="inspiration_image" accept="image/jpeg,image/png,image/webp,image/heic,image/heif" multiple data-events-planner-upload-input>
                  <div class="events-planner__upload-cta">
                    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                      <polyline points="17 8 12 3 7 8"></polyline>
                      <line x1="12" y1="3" x2="12" y2="15"></line>
                    </svg>
                    <span>Click or drag photos here</span>
                  </div>
                  <ul class="events-planner__upload-list" data-events-planner-upload-list></ul>
                </div>
              </div>
            </fieldset>

            {% comment %} ─── Step 4: Contact ─── {% endcomment %}
            <fieldset class="events-planner__panel" data-events-planner-panel="contact" hidden>
              <legend class="events-planner__panel-label">How can I reach you?</legend>
              <div class="events-planner__row">
                <div class="events-planner__field">
                  <label for="contact_name-{{ section.id }}">Your name <span aria-hidden="true">*</span></label>
                  <input type="text" name="contact_name" id="contact_name-{{ section.id }}" required>
                </div>
                <div class="events-planner__field">
                  <label for="contact_phone-{{ section.id }}">Phone</label>
                  <input type="tel" name="contact_phone" id="contact_phone-{{ section.id }}" placeholder="(773) 555-0123">
                </div>
              </div>
              <div class="events-planner__row">
                <div class="events-planner__field">
                  <label for="contact_email-{{ section.id }}">Email <span aria-hidden="true">*</span></label>
                  <input type="email" name="contact_email" id="contact_email-{{ section.id }}" required autocomplete="email">
                  <p class="events-planner__hint">I will email you within 24 hours. No spam.</p>
                </div>
                <div class="events-planner__field">
                  <label for="preferred_contact-{{ section.id }}">Best way to reach you</label>
                  <select name="preferred_contact" id="preferred_contact-{{ section.id }}">
                    <option value="">Pick one…</option>
                    <option value="email">Email</option>
                    <option value="phone">Phone call</option>
                    <option value="text">Text</option>
                  </select>
                </div>
              </div>

              <button type="submit" class="events-planner__submit" data-events-planner-submit>
                <span class="events-planner__submit-label">Send to {{ section.settings.persona_name | default: 'the events team' | escape }}</span>
                <span class="events-planner__submit-spinner" hidden>Sending…</span>
              </button>
              <p class="events-planner__error" data-events-planner-error hidden role="alert"></p>
            </fieldset>
          </form>

          {% comment %} ─── Confirmation panel ─── {% endcomment %}
          <div class="events-planner__success" data-events-planner-success hidden>
            <div class="events-planner__success-seal" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </div>
            <h3 class="events-planner__success-heading">Got it. Thanks <span data-events-planner-success-name>friend</span>.</h3>
            <p class="events-planner__success-lede">{{ section.settings.success_lede | default: "Your inquiry is in. Here is what happens next." | escape }}</p>
            <ol class="events-planner__success-steps">
              <li>
                <span class="events-planner__success-step-when">Within 24 hours</span>
                <span class="events-planner__success-step-what">{{ section.settings.next_step_1 | default: "I will review your inquiry personally and email you back." | escape }}</span>
              </li>
              <li>
                <span class="events-planner__success-step-when">Within 48 hours</span>
                <span class="events-planner__success-step-what">{{ section.settings.next_step_2 | default: "You will get a custom quote with cake options for your budget, photos of comparable cakes, and a hold on your date if you want it." | escape }}</span>
              </li>
              <li>
                <span class="events-planner__success-step-when">When you are ready</span>
                <span class="events-planner__success-step-what">{{ section.settings.next_step_3 | default: "We confirm with a 50% deposit. The other 50% is due a week before pickup or delivery." | escape }}</span>
              </li>
            </ol>
            {% if section.settings.persona_name != blank %}
              <p class="events-planner__success-signoff">
                — {{ section.settings.persona_name | escape }}{% if section.settings.persona_title != blank %}, {{ section.settings.persona_title | escape }}{% endif %}<br>
                {% if section.settings.persona_email != blank %}<a href="mailto:{{ section.settings.persona_email }}">{{ section.settings.persona_email | escape }}</a>{% endif %}
                {% if section.settings.persona_phone != blank %} · {{ section.settings.persona_phone | escape }}{% endif %}
              </p>
            {% endif %}
            <button type="button" class="events-planner__success-close" data-events-planner-close>Close</button>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .events-planner--{{ section.id }} {
    background: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding: 36px 16px;
    font-family: 'Arsenal', sans-serif;
  }
  .events-planner--{{ section.id }} .sr-only {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0;
  }

  /* ─── Trigger card — back of a sealed envelope ─── */
  .events-planner--{{ section.id }} .events-planner__trigger-card {
    position: relative;
    max-width: 560px;
    margin: 0 auto;
    background:
      radial-gradient(120% 80% at 50% 100%, rgba(91, 37, 18, 0.04), transparent 60%),
      linear-gradient(180deg, #fffaf2 0%, #f7ead6 100%);
    border: 1px solid rgba(91, 37, 18, 0.30);
    border-radius: 6px;
    padding: 0;
    box-shadow:
      0 8px 24px rgba(91, 37, 18, 0.18),
      0 1px 0 rgba(255, 255, 255, 0.7) inset;
    overflow: hidden;
    cursor: pointer;
    transition: transform 200ms ease, box-shadow 200ms ease;
  }
  .events-planner--{{ section.id }} .events-planner__trigger-card:hover,
  .events-planner--{{ section.id }} .events-planner__trigger-card:focus-within {
    transform: translateY(-2px);
    box-shadow:
      0 12px 32px rgba(91, 37, 18, 0.26),
      0 1px 0 rgba(255, 255, 255, 0.7) inset;
  }

  /* Triangular flap pointing DOWN from top — caramel, like back of envelope.
     Uses padding-bottom for height (resolves against parent's WIDTH, so the
     flap stays proportional regardless of the card's content height). */
  .events-planner--{{ section.id }} .events-planner__envelope-flap {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 0;
    padding-bottom: 32%;
    background: linear-gradient(180deg, #ba5b28 0%, #8d4422 100%);
    clip-path: polygon(0 0, 100% 0, 50% 100%);
    pointer-events: none;
    z-index: 1;
    box-shadow: inset 0 -1px 0 rgba(91, 37, 18, 0.20);
  }
  /* Subtle dark line down the seam of the flap (the fold line) */
  .events-planner--{{ section.id }} .events-planner__envelope-flap::after {
    content: "";
    position: absolute;
    top: 0;
    left: 50%;
    width: 1px;
    height: 100%;
    background: linear-gradient(180deg, rgba(91, 37, 18, 0.18), transparent);
    transform: translateX(-50%);
  }
  /* Soft shadow line UNDER the flap apex (where it meets the lower envelope) */
  .events-planner--{{ section.id }} .events-planner__envelope-flap-shadow {
    position: absolute;
    top: 32%;
    left: 0;
    right: 0;
    height: 14px;
    background: radial-gradient(ellipse at 50% 0%, rgba(91, 37, 18, 0.22) 0%, transparent 70%);
    pointer-events: none;
    z-index: 2;
  }

  /* BSB stamp seal — outlined rectangle sitting at the flap apex.
     Position: just below the apex of the triangle (32% of width from top). */
  .events-planner--{{ section.id }} .events-planner__envelope-seal {
    position: absolute;
    top: calc(32% - 28px);
