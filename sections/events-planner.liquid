    border-radius: 50%;
    background: rgba(29, 10, 4, 0.78);
    color: #fff;
    border: none;
    font-size: 12px;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .events-planner--{{ section.id }} .events-planner__submit {
    display: block;
    width: 100%;
    margin: 22px 0 0;
    padding: 14px 20px;
    font-family: 'Arsenal', sans-serif;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #fffaf2;
    background: linear-gradient(180deg, #6c0a2e 0%, #570522 60%, #45041b 100%);
    border: 1px solid #2e0212;
    border-radius: 4px;
    cursor: pointer;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.20),
      inset 0 -1px 0 rgba(0, 0, 0, 0.28),
      0 2px 0 rgba(46, 2, 18, 0.5);
    text-shadow: 0 1px 0 rgba(0, 0, 0, 0.35);
    transition: filter 160ms ease;
  }
  .events-planner--{{ section.id }} .events-planner__submit:hover {
    filter: brightness(1.06);
  }
  .events-planner--{{ section.id }} .events-planner__submit:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }
  .events-planner--{{ section.id }} .events-planner__error {
    margin: 12px 0 0;
    padding: 10px 14px;
    background: #fff5f5;
    border-left: 3px solid #d82c0d;
    color: #b32200;
    font-size: 13px;
    border-radius: 4px;
  }

  /* ─── Confirmation ─── */
  .events-planner--{{ section.id }} .events-planner__success {
    text-align: center;
    padding: 16px 4px 4px;
  }
  .events-planner--{{ section.id }} .events-planner__success-seal {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #570522;
    color: #fffaf2;
    margin: 0 auto 14px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .events-planner--{{ section.id }} .events-planner__success-heading {
    font-family: 'Allura', 'Brush Script MT', cursive;
    font-weight: 400;
    font-size: clamp(36px, 6vw, 52px);
    line-height: 1.05;
    color: #570522;
    margin: 0 0 8px;
  }
  .events-planner--{{ section.id }} .events-planner__success-lede {
    margin: 0 auto 22px;
    font-size: 15px;
    color: rgba(91, 37, 18, 0.85);
    max-width: 460px;
    line-height: 1.5;
  }
  .events-planner--{{ section.id }} .events-planner__success-steps {
    list-style: none;
    counter-reset: succ;
    margin: 0 auto 18px;
    padding: 0;
    text-align: left;
    max-width: 480px;
  }
  .events-planner--{{ section.id }} .events-planner__success-steps li {
    counter-increment: succ;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 14px;
    align-items: baseline;
    padding: 12px 0;
    border-top: 1px solid rgba(91, 37, 18, 0.10);
  }
  .events-planner--{{ section.id }} .events-planner__success-steps li::before {
    content: counter(succ, decimal-leading-zero);
    font-family: 'Arsenal', sans-serif;
    font-weight: 700;
    color: {{ section.settings.accent_color }};
    font-size: 16px;
    min-width: 28px;
  }
  .events-planner--{{ section.id }} .events-planner__success-step-when {
    display: block;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 700;
    color: #570522;
    margin-bottom: 4px;
  }
  .events-planner--{{ section.id }} .events-planner__success-step-what {
    display: block;
    font-size: 14px;
    color: rgba(91, 37, 18, 0.85);
    line-height: 1.5;
  }
  .events-planner--{{ section.id }} .events-planner__success-signoff {
    margin: 18px 0 14px;
    padding: 14px 0 0;
    border-top: 1px solid rgba(91, 37, 18, 0.12);
    font-size: 13px;
    color: rgba(91, 37, 18, 0.85);
    line-height: 1.5;
  }
  .events-planner--{{ section.id }} .events-planner__success-signoff a {
    color: {{ section.settings.accent_color }};
  }
  .events-planner--{{ section.id }} .events-planner__success-close {
    margin-top: 6px;
    padding: 10px 22px;
    font-family: 'Arsenal', sans-serif;
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #570522;
    background: transparent;
    border: 1px solid #570522;
    border-radius: 4px;
    cursor: pointer;
    transition: background 140ms ease;
  }
  .events-planner--{{ section.id }} .events-planner__success-close:hover {
    background: rgba(91, 37, 18, 0.06);
  }

  @media (max-width: 480px) {
    .events-planner--{{ section.id }} .events-planner__card-inner {
      padding: 48px 22px 22px;
    }
    .events-planner--{{ section.id }} .events-planner__envelope-flap {
      height: 50px;
    }
    .events-planner--{{ section.id }} .events-planner__envelope-seal {
      top: 22px;
      width: 36px; height: 36px; line-height: 36px;
      font-size: 24px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .events-planner--{{ section.id }} .events-planner__envelope,
    .events-planner--{{ section.id }} .events-planner__envelope-flap,
    .events-planner--{{ section.id }} .events-planner__envelope-seal,
    .events-planner--{{ section.id }} .events-planner__modal-overlay {
      transition: none;
    }
  }
</style>

<script>
(function () {
  var root = document.querySelector('.events-planner--{{ section.id }}');
  if (!root) return;

  var modal = root.querySelector('[data-events-planner-modal]');
  var openBtn = root.querySelector('[data-events-planner-open]');
  var closers = root.querySelectorAll('[data-events-planner-close]');
  var form = root.querySelector('[data-events-planner-form]');
  var eventTypeSelect = root.querySelector('[data-events-planner-event-type]');
  var panels = {
    event: root.querySelector('[data-events-planner-panel="event"]'),
    details: root.querySelector('[data-events-planner-panel="details"]'),
    vision: root.querySelector('[data-events-planner-panel="vision"]'),
    contact: root.querySelector('[data-events-planner-panel="contact"]'),
  };
  var conditionals = root.querySelectorAll('[data-events-planner-conditional-for]');
  var successPanel = root.querySelector('[data-events-planner-success]');
  var submitBtn = root.querySelector('[data-events-planner-submit]');
  var errorBox = root.querySelector('[data-events-planner-error]');

  function openModal() {
    document.body.classList.add('events-planner-open');
    document.documentElement.style.overflow = 'hidden';
    modal.setAttribute('aria-hidden', 'false');
  }
  function closeModal() {
    document.body.classList.remove('events-planner-open');
    document.documentElement.style.overflow = '';
    modal.setAttribute('aria-hidden', 'true');
  }
  openBtn.addEventListener('click', openModal);
  closers.forEach(function (c) { c.addEventListener('click', closeModal); });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && document.body.classList.contains('events-planner-open')) {
      closeModal();
    }
  });

  function onEventTypeChange() {
    var v = eventTypeSelect.value;
    var has = !!v;
    panels.details.hidden = !has;
    panels.vision.hidden = !has;
    panels.contact.hidden = !has;
    conditionals.forEach(function (el) {
      el.hidden = el.getAttribute('data-events-planner-conditional-for') !== v;
    });
  }
  eventTypeSelect.addEventListener('change', onEventTypeChange);

  root.querySelectorAll('[data-events-planner-chips]').forEach(function (group) {
    var hiddenInput = group.parentElement.querySelector('[data-events-planner-chips-input]');
    group.addEventListener('click', function (e) {
      var chip = e.target.closest('.events-planner__chip');
      if (!chip) return;
      chip.classList.toggle('is-selected');
      var sel = Array.from(group.querySelectorAll('.is-selected'))
        .map(function (c) { return c.getAttribute('data-chip-value'); });
      hiddenInput.value = sel.join(',');
    });
  });

  var uploadHost = root.querySelector('[data-events-planner-upload]');
  var uploadInput = root.querySelector('[data-events-planner-upload-input]');
  var uploadList = root.querySelector('[data-events-planner-upload-list]');
  var uploadFiles = [];

  function rebuildInputFiles() {
    var dt = new DataTransfer();
    uploadFiles.forEach(function (f) { dt.items.add(f.file); });
    uploadInput.files = dt.files;
  }
  function renderThumbs() {
    uploadList.innerHTML = '';
    uploadFiles.forEach(function (f, idx) {
      var li = document.createElement('li');
      li.className = 'events-planner__upload-thumb';
      li.innerHTML = '<img src="' + f.url + '" alt=""><button type="button" class="events-planner__upload-remove" aria-label="Remove" data-remove-idx="' + idx + '">×</button>';
      uploadList.appendChild(li);
    });
  }
  function addFiles(fileList) {
    var added = 0;
    Array.from(fileList).forEach(function (file) {
      if (uploadFiles.length >= 5) return;
      if (!/^image\//.test(file.type)) return;
      if (file.size > 5 * 1024 * 1024) return;
      uploadFiles.push({ file: file, url: URL.createObjectURL(file) });
      added++;
    });
    if (added) { rebuildInputFiles(); renderThumbs(); }
  }
  uploadInput.addEventListener('change', function () { addFiles(uploadInput.files); });
  uploadList.addEventListener('click', function (e) {
    var btn = e.target.closest('[data-remove-idx]');
    if (!btn) return;
    var idx = parseInt(btn.getAttribute('data-remove-idx'), 10);
    URL.revokeObjectURL(uploadFiles[idx].url);
    uploadFiles.splice(idx, 1);
    rebuildInputFiles();
    renderThumbs();
  });
  ['dragenter', 'dragover'].forEach(function (ev) {
    uploadHost.addEventListener(ev, function (e) {
      e.preventDefault();
      uploadHost.classList.add('is-dragging');
    });
  });
  ['dragleave', 'drop'].forEach(function (ev) {
    uploadHost.addEventListener(ev, function (e) {
      e.preventDefault();
      uploadHost.classList.remove('is-dragging');
    });
  });
  uploadHost.addEventListener('drop', function (e) {
    if (e.dataTransfer && e.dataTransfer.files) addFiles(e.dataTransfer.files);
  });

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    errorBox.hidden = true;
    errorBox.textContent = '';
    var fd = new FormData(form);
    var conditional = {};
    var toDelete = [];
    fd.forEach(function (val, key) {
      if (key.indexOf('cond_') === 0) {
        var input = form.querySelector('[name="' + key + '"]');
        var jsonKey = (input && input.getAttribute('data-conditional-key')) || key.replace('cond_', '');
        if (val) conditional[jsonKey] = val;
        toDelete.push(key);
      }
    });
    toDelete.forEach(function (k) { fd.delete(k); });
    fd.set('conditional', JSON.stringify(conditional));
    fd.set('source_url', form.getAttribute('data-source-url') || '');

    submitBtn.disabled = true;
    submitBtn.querySelector('.events-planner__submit-label').hidden = true;
    submitBtn.querySelector('.events-planner__submit-spinner').hidden = false;

    var endpoint = form.getAttribute('data-endpoint');
    fetch(endpoint, { method: 'POST', body: fd })
      .then(function (res) { return res.json().then(function (b) { return { ok: res.ok, body: b }; }); })
      .then(function (out) {
        if (!out.ok || out.body.error) throw new Error(out.body.error || 'Submission failed');
        var firstName = (form.querySelector('[name="contact_name"]').value || '').split(' ')[0] || 'friend';
        var nameEl = root.querySelector('[data-events-planner-success-name]');
        if (nameEl) nameEl.textContent = firstName;
        form.hidden = true;
        successPanel.hidden = false;
      })
      .catch(function (err) {
        errorBox.textContent = 'Something didn’t go through — please try again, or email events@brownsugarbakery.com directly. (' + (err.message || err) + ')';
        errorBox.hidden = false;
        submitBtn.disabled = false;
        submitBtn.querySelector('.events-planner__submit-label').hidden = false;
        submitBtn.querySelector('.events-planner__submit-spinner').hidden = true;
      });
  });
})();
</script>

