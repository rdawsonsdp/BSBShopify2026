{% comment %}
  LIFT: Anxiety reduction — neutralizes the "this will be long and complicated"
  fear by showing the full journey is three simple steps. Human-first language
  in step 02 ("a real person — not a chatbot") explicitly defuses ghost/hard-sell anxiety.
{% endcomment %}

{%- liquid
  assign step_blocks = section.blocks | where: 'type', 'step'
-%}

<section class="events-process events-process--{{ section.id }}" aria-label="{{ section.settings.heading | default: 'How it works' | escape }}">
  <div class="events-process__inner">
    {% if section.settings.eyebrow != blank %}
      <p class="events-process__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2 class="events-process__heading">{{ section.settings.heading | escape }}</h2>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p class="events-process__subheading">{{ section.settings.subheading | escape }}</p>
    {% endif %}

    <ol class="events-process__steps">
      {%- for block in step_blocks -%}
        {%- liquid
          assign step_num = forloop.index
          if step_num < 10
            assign step_label = step_num | prepend: '0'
          else
            assign step_label = step_num | append: ''
          endif
        -%}
        <li class="events-process__step" {{ block.shopify_attributes }}>
          {% if block.settings.icon != blank %}
            <span class="events-process__icon" aria-hidden="true">{{ block.settings.icon }}</span>
          {% endif %}
          <span class="events-process__number" aria-hidden="true">{{ step_label }}</span>
          {% if block.settings.title != blank %}
            <h3 class="events-process__title">{{ block.settings.title | escape }}</h3>
          {% endif %}
          {% if block.settings.body != blank %}
            <div class="events-process__body rte">{{ block.settings.body }}</div>
          {% endif %}
        </li>
      {%- endfor -%}
    </ol>
  </div>
</section>

<style>
  .events-process--{{ section.id }} {
    background: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding: 36px 16px;
  }
  .events-process--{{ section.id }} .events-process__inner {
    max-width: 1100px;
    margin: 0 auto;
  }
  .events-process--{{ section.id }} .events-process__eyebrow {
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 700;
    margin: 0 0 8px;
    opacity: 0.75;
    text-align: center;
  }
  .events-process--{{ section.id }} .events-process__heading {
    font-size: clamp(22px, 4vw, 32px);
    font-weight: 800;
    margin: 0 0 8px;
    text-align: center;
    color: inherit;
  }
  .events-process--{{ section.id }} .events-process__subheading {
    margin: 0 auto 28px;
    max-width: 560px;
    text-align: center;
    font-size: 15px;
    line-height: 1.5;
    opacity: 0.85;
  }
  .events-process--{{ section.id }} .events-process__steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }
  .events-process--{{ section.id }} .events-process__step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 8px;
  }
  .events-process--{{ section.id }} .events-process__icon {
    font-size: 30px;
    line-height: 1;
    margin-bottom: 12px;
    display: inline-block;
  }
  .events-process--{{ section.id }} .events-process__number {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: #570522;
    color: #fffaf2;
    font-weight: 800;
    font-size: 22px;
    letter-spacing: 0.04em;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    /* Beveled enamelware: inset top highlight + bottom maroon shadow + soft drop shadow */
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.25),
      inset 0 -2px 0 rgba(0, 0, 0, 0.18),
      0 2px 6px rgba(91, 37, 18, 0.22);
  }
  .events-process--{{ section.id }} .events-process__title {
    font-size: 17px;
    font-weight: 700;
    color: #570522;
    margin: 14px 0 6px;
    line-height: 1.3;
  }
  .events-process--{{ section.id }} .events-process__body {
    font-size: 14px;
    line-height: 1.55;
    color: rgba(91, 37, 18, 0.78);
    max-width: 280px;
    margin: 0 auto;
  }
  .events-process--{{ section.id }} .events-process__body p {
    margin: 0 0 8px;
  }
  .events-process--{{ section.id }} .events-process__body p:last-child {
    margin-bottom: 0;
  }

  @media screen and (min-width: 768px) {
    .events-process--{{ section.id }} {
      padding: 56px 24px;
    }
    .events-process--{{ section.id }} .events-process__steps {
      grid-template-columns: repeat(3, 1fr);
      gap: 32px;
    }
    .events-process--{{ section.id }} .events-process__title {
      font-size: 18px;
    }
  }
</style>

{% schema %}
{
  "name": "Events process",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Take the worry out of your event planning."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Three steps. No surprises. We handle the rest."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f7ead6"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#570522"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (emoji or short text)" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "richtext", "id": "body", "label": "Body" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Events process",
      "category": "Storytelling",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "icon": "📅",
            "title": "Tell us about your date",
            "body": "<p>Two minutes. Pick a date, tell us the occasion, give us a guest count.</p>"
          }
        },
        {
          "type": "step",
          "settings": {
            "icon": "📞",
            "title": "We'll reach out within 48 hours",
            "body": "<p>A real person from our team — not a chatbot — will call or email to walk through your concept, pricing, and timeline.</p>"
          }
        },
        {
          "type": "step",
          "settings": {
            "icon": "🎂",
            "title": "We bake. You enjoy your event.",
            "body": "<p>We confirm the design, deliver or arrange pickup, and you focus on your guests.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
