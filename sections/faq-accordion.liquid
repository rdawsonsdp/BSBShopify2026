{%- comment -%}
  FAQ accordion — collapsible Q&A list using the beveled enamelware pillbox style.
  Configurable via "qa" blocks.
{%- endcomment -%}

{%- liquid
  assign qa_blocks = section.blocks | where: 'type', 'qa'
-%}

<section class="bsb-faq bsb-faq--{{ section.id }}" aria-label="{{ section.settings.heading | default: 'Frequently asked questions' | escape }}">
  <div class="bsb-faq__inner">
    {% if section.settings.eyebrow != blank %}
      <p class="bsb-faq__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2 class="bsb-faq__heading">{{ section.settings.heading | escape }}</h2>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p class="bsb-faq__subheading">{{ section.settings.subheading | escape }}</p>
    {% endif %}

    <div class="bsb-faq__list">
      {%- for block in qa_blocks -%}
        <details class="bsb-faq__item" {{ block.shopify_attributes }}>
          <summary class="bsb-faq__question">
            <span class="bsb-faq__q-text">{{ block.settings.question | escape }}</span>
            <span class="bsb-faq__chevron" aria-hidden="true">▾</span>
          </summary>
          <div class="bsb-faq__answer rte">
            {{ block.settings.answer }}
          </div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .bsb-faq--{{ section.id }} {
    background: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding: 36px 16px;
  }
  .bsb-faq--{{ section.id }} .bsb-faq__inner {
    max-width: 760px;
    margin: 0 auto;
  }
  .bsb-faq--{{ section.id }} .bsb-faq__eyebrow {
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 700;
    margin: 0 0 8px;
    opacity: 0.75;
    text-align: center;
  }
  .bsb-faq--{{ section.id }} .bsb-faq__heading {
    font-size: clamp(22px, 4vw, 32px);
    font-weight: 800;
    margin: 0 0 8px;
    text-align: center;
    color: inherit;
  }
  .bsb-faq--{{ section.id }} .bsb-faq__subheading {
    margin: 0 auto 22px;
    max-width: 560px;
    text-align: center;
    font-size: 15px;
    line-height: 1.5;
    opacity: 0.85;
  }
  .bsb-faq--{{ section.id }} .bsb-faq__list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  /* Beveled enamelware (matches .bsb-info-box) */
  .bsb-faq--{{ section.id }} .bsb-faq__item {
    background: #f7ead6;
    color: #5b2512;
    border: 1px solid rgba(91, 37, 18, 0.32);
    border-radius: 4px;
    overflow: hidden;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.55),
      inset 0 -1px 0 rgba(91, 37, 18, 0.10),
      0 1px 2px rgba(91, 37, 18, 0.10);
    transition: background 180ms ease, border-color 180ms ease, box-shadow 180ms ease, transform 80ms ease;
  }
  .bsb-faq--{{ section.id }} .bsb-faq__item:hover {
    background: #f0dec0;
    border-color: rgba(91, 37, 18, 0.45);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.6),
      inset 0 -1px 0 rgba(91, 37, 18, 0.14),
      0 2px 5px rgba(91, 37, 18, 0.16);
  }
  .bsb-faq--{{ section.id }} .bsb-faq__item[open] {
    background: #f0dec0;
    border-color: rgba(91, 37, 18, 0.4);
  }
  .bsb-faq--{{ section.id }} .bsb-faq__question {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    font-weight: 600;
    font-size: 15px;
    line-height: 1.35;
    user-select: none;
  }
  .bsb-faq--{{ section.id }} .bsb-faq__question::-webkit-details-marker { display: none; }
  .bsb-faq--{{ section.id }} .bsb-faq__question:focus-visible {
    outline: 2px solid rgba(186, 91, 40, 0.5);
    outline-offset: -2px;
  }
  .bsb-faq--{{ section.id }} .bsb-faq__q-text { flex: 1; }
  .bsb-faq--{{ section.id }} .bsb-faq__chevron {
    transition: transform 200ms ease;
    font-size: 12px;
    opacity: 0.55;
    flex-shrink: 0;
  }
  .bsb-faq--{{ section.id }} .bsb-faq__item[open] .bsb-faq__chevron {
    transform: rotate(180deg);
  }
  .bsb-faq--{{ section.id }} .bsb-faq__answer {
    padding: 0 16px 14px;
    font-size: 14px;
    line-height: 1.55;
    color: rgba(91, 37, 18, 0.82);
    animation: bsb-faq-fade 200ms ease;
  }
  .bsb-faq--{{ section.id }} .bsb-faq__answer p { margin: 0 0 8px; }
  .bsb-faq--{{ section.id }} .bsb-faq__answer p:last-child { margin-bottom: 0; }
  @keyframes bsb-faq-fade {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media screen and (min-width: 768px) {
    .bsb-faq--{{ section.id }} {
      padding: 56px 24px;
    }
  }
</style>

{% schema %}
{
  "name": "FAQ accordion",
  "max_blocks": 20,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently asked"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#fffaf2"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#570522"
    }
  ],
  "blocks": [
    {
      "type": "qa",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "richtext", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ accordion",
      "category": "Text"
    }
  ]
}
{% endschema %}
