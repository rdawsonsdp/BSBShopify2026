{%- comment -%} Footer-bottom is homepage-only — subsequent pages get a minimal layout. {%- endcomment -%}
{%- if request.page_type == 'index' -%}
<div class="footer-bottom footer-bottom--compact">
  <div class="container">
    <div class="footer-bottom__localization-forms {% unless section.settings.show_methods_of_payment %} payment-methods-disabled{% endunless %}">
      {% render 'localization-form' with show_currency_selector: section.settings.show_currency_selector, show_locale_selector: section.settings.show_locale_selector %}
    </div>

    {% if section.settings.show_methods_of_payment or section.settings.show_ebt %}
      <ul id="footer-payment-methods" class="inline-list footer-bottom__payment-icons footer-bottom__payment-icons--with-ebt">
        {% if section.settings.show_methods_of_payment %}
          {% unless shop.enabled_payment_types == empty %}
            {% for type in shop.enabled_payment_types %}
              <li>{{ type | payment_type_svg_tag: class: 'payment-icon' }}</li>
            {% endfor %}
          {% endunless %}
        {% endif %}
        {% if section.settings.show_ebt %}
          <li class="footer-bottom__ebt-item" aria-label="EBT accepted">
            {% if section.settings.ebt_image != blank %}
              <img
                src="{{ section.settings.ebt_image | image_url: width: 120 }}"
                alt="EBT accepted"
                height="auto"
                loading="lazy"
                class="footer-bottom__ebt-logo"
              >
            {% else %}
              <span class="footer-bottom__ebt-badge" aria-hidden="true">EBT</span>
            {% endif %}
          </li>
        {% endif %}
      </ul>
    {% endif %}

    <div class="footer-bottom__copyright">
      <p>
        <a href="{{ routes.root_url }}">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}</a>
        | {{ powered_by_link }}
      </p>
    </div>
  </div>
</div>

<style>
  .footer-bottom--compact {
    padding: 10px 0 12px;
  }
  .footer-bottom--compact .container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }
  .footer-bottom--compact .footer-bottom__payment-icons--with-ebt {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 6px 8px;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .footer-bottom--compact .footer-bottom__payment-icons--with-ebt li {
    margin: 0;
    line-height: 0;
  }
  .footer-bottom--compact .payment-icon {
    height: 22px;
    width: auto;
    display: block;
  }
  .footer-bottom--compact .footer-bottom__ebt-item {
    display: inline-flex;
    align-items: center;
    line-height: 0;
  }
  .footer-bottom--compact .footer-bottom__ebt-logo {
    height: 22px;
    width: auto;
    display: block;
  }
  .footer-bottom--compact .footer-bottom__ebt-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 38px;
    height: 22px;
    padding: 0 8px;
    background-color: #003E7E;
    color: #ffffff;
    font-weight: 800;
    font-size: 11px;
    letter-spacing: 0.08em;
    border-radius: 3px;
    font-family: Arial, Helvetica, sans-serif;
  }
  .footer-bottom--compact .footer-bottom__copyright {
    margin: 0;
  }
  .footer-bottom--compact .footer-bottom__copyright p {
    margin: 0;
    font-size: 12px;
    opacity: 0.7;
    text-align: center;
  }
</style>
{%- endif -%}

{% schema %}
  {
    "name": {
      "en": "Footer bottom"
    },
    "settings": [
      {
        "type": "checkbox",
        "id": "show_methods_of_payment",
        "label": {
          "en": "Show payment icons",
          "de": "Zahlungssymbole anzeigen",
          "es": "Mostrar los íconos de pago",
          "fr": "Afficher les icônes de paiement",
          "pt-PT": "Mostrar os ícones de pagamento"
        },
        "default": true
      },
      {
        "type": "header",
        "content": {
          "en": "Country\/region selector",
          "de": "Auswahl für Land\/Region",
          "es": "Selector de país\/región",
          "fr": "Sélecteur de pays\/région",
          "pt-PT": "Seletor de país\/região"
        },
        "info": {
          "en": "To add a country\/region, go to your [market settings.](\/admin\/settings\/markets)",
          "de": "Gehe zu den [Markteinstellungen](\/admin\/settings\/markets), um ein Land \/ eine Region hinzuzufügen.",
          "es": "Para agregar un país\/región, ve a tu [configuración de mercado.](\/admin\/settings\/markets)",
          "fr": "Pour ajouter un pays\/une région, allez à vos [paramètres du marché.](\/admin\/settings\/markets)",
          "pt-PT": "Para adicionar um país\/região, vá a [configurações de mercado.](\/admin\/settings\/markets)"
        }
      },
      {
        "type": "checkbox",
        "id": "show_currency_selector",
        "label": {
          "en": "Enable country\/region selector",
          "de": "Auswahl für Land\/Region aktivieren",
          "es": "Activar selector de país\/región",
          "fr": "Activer le sélecteur de pays\/région",
          "pt-PT": "Ativar seletor de país\/região"
        },
        "default": true
      },
      {
        "type": "header",
        "content": {
          "en": "Language selector",
          "de": "Sprachauswahl",
          "es": "Selector de idioma",
          "fr": "Sélecteur de langue",
          "pt-PT": "Seletor de idioma"
        },
        "info": {
          "en": "To add a language, go to your [language settings.](\/admin\/settings\/languages)",
          "de": "Gehe zu den [Spracheinstellungen](\/admin\/settings\/languages), um eine Sprache hinzuzufügen.",
          "es": "Para agregar un idioma, ve a tu [configuración de idiomas.](\/admin\/settings\/languages)",
          "fr": "Pour ajouter une langue, allez à vos [paramètres de langue.](\/admin\/settings\/languages)",
          "pt-PT": "Para adicionar um idioma, vá a [definições de idioma.](\/admin\/settings\/languages)"
        }
      }, {
        "type": "checkbox",
        "id": "show_locale_selector",
        "label": {
          "en": "Enable language selector",
          "de": "Sprachauswahl aktivieren",
          "es": "Activar selector de idioma",
          "fr": "Activer le sélecteur de langue",
          "pt-PT": "Ativar seletor de idioma"
        },
        "default": true
      },
      {
        "type": "header",
        "content": {
          "en": "EBT / SNAP Acceptance"
        }
      },
      {
        "type": "checkbox",
        "id": "show_ebt",
        "label": {
          "en": "Show EBT acceptance notice"
        },
        "default": true
      },
      {
        "type": "image_picker",
        "id": "ebt_image",
        "label": {
          "en": "EBT Logo (optional — uses styled badge if empty)"
        }
      },
      {
        "type": "text",
        "id": "ebt_text",
        "label": {
          "en": "EBT Text"
        },
        "default": {
          "en": "We proudly accept EBT / SNAP in our store"
        }
      }
    ]
  }
{% endschema %}