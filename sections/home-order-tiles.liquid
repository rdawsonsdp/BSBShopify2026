{%- comment -%}
  LIFT: Clarity — single-decision entry point to the four buying paths.
  Sits under the homepage hero. 4 tiles in a responsive grid (4-up desktop,
  2x2 tablet/mobile). Each tile is a full-bleed photo with a bottom gradient
  overlay and a centered white title. Block-driven; reuse before fork.
{%- endcomment -%}

<section
  class="home-order-tiles home-order-tiles--{{ section.id }}"
  aria-label="{{ section.settings.heading | default: 'Choose your path' | escape }}"
>
  <div class="home-order-tiles__inner">
    {% if section.settings.heading != blank %}
      <h2 class="home-order-tiles__heading">{{ section.settings.heading | escape }}</h2>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p class="home-order-tiles__subheading">{{ section.settings.subheading | escape }}</p>
    {% endif %}

    <div class="home-order-tiles__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'tile' -%}
          {%- assign tile_link = block.settings.link | default: '#' -%}
          <a
            class="home-order-tiles__tile"
            href="{{ tile_link }}"
            {{ block.shopify_attributes }}
            aria-label="{{ block.settings.title | escape }}"
          >
            <div class="home-order-tiles__media">
              {% if block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 800 | image_tag:
                  loading: 'lazy',
                  alt: block.settings.title,
                  class: 'home-order-tiles__photo'
                }}
              {% else %}
                <div class="home-order-tiles__placeholder" aria-hidden="true"></div>
              {% endif %}
              <span class="home-order-tiles__overlay" aria-hidden="true"></span>
              <span class="home-order-tiles__title">{{ block.settings.title | escape }}</span>
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .home-order-tiles--{{ section.id }} {
    background: {{ section.settings.background_color }};
    padding: 32px 16px;
  }
  .home-order-tiles--{{ section.id }} .home-order-tiles__inner {
    max-width: 1280px;
    margin: 0 auto;
  }
  .home-order-tiles--{{ section.id }} .home-order-tiles__heading {
    font-size: clamp(24px, 4vw, 34px);
    font-weight: 900;
    letter-spacing: 0.04em;
    color: #570522;
    text-align: center;
    margin: 0 0 8px;
  }
  .home-order-tiles--{{ section.id }} .home-order-tiles__subheading {
    text-align: center;
    color: #570522;
    font-size: 16px;
    line-height: 1.4;
    margin: 0 auto 20px;
    max-width: 640px;
    opacity: 0.85;
  }
  .home-order-tiles--{{ section.id }} .home-order-tiles__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  .home-order-tiles--{{ section.id }} .home-order-tiles__tile {
    display: block;
    position: relative;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid rgba(87, 5, 34, 0.18);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.35),
      0 2px 8px rgba(87, 5, 34, 0.14);
    transition: transform 220ms ease, box-shadow 220ms ease;
    will-change: transform;
  }
  .home-order-tiles--{{ section.id }} .home-order-tiles__tile:hover,
  .home-order-tiles--{{ section.id }} .home-order-tiles__tile:focus-visible {
    transform: scale(1.02);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.45),
      0 8px 18px rgba(87, 5, 34, 0.22);
    outline: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .home-order-tiles--{{ section.id }} .home-order-tiles__tile,
    .home-order-tiles--{{ section.id }} .home-order-tiles__tile:hover,
    .home-order-tiles--{{ section.id }} .home-order-tiles__tile:focus-visible {
      transform: none;
      transition: none;
    }
  }
  .home-order-tiles--{{ section.id }} .home-order-tiles__media {
    position: relative;
    aspect-ratio: 1 / 1;
    width: 100%;
    overflow: hidden;
    background: rgba(87, 5, 34, 0.08);
  }
  .home-order-tiles--{{ section.id }} .home-order-tiles__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .home-order-tiles--{{ section.id }} .home-order-tiles__placeholder {
    width: 100%;
    height: 100%;
    background:
      linear-gradient(135deg, rgba(87, 5, 34, 0.12), rgba(186, 91, 40, 0.18));
  }
  .home-order-tiles--{{ section.id }} .home-order-tiles__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0) 50%,
      rgba(0, 0, 0, 0.65) 100%
    );
    pointer-events: none;
  }
  .home-order-tiles--{{ section.id }} .home-order-tiles__title {
    position: absolute;
    left: 50%;
    bottom: 14%;
    transform: translateX(-50%);
    width: calc(100% - 24px);
    text-align: center;
    color: #ffffff;
    font-family: inherit;
    font-weight: 800;
    font-size: clamp(18px, 4.5vw, 22px);
    letter-spacing: 0.03em;
    line-height: 1.15;
    text-shadow: 0 2px 6px rgba(0, 0, 0, 0.45);
  }

  @media screen and (min-width: 768px) {
    .home-order-tiles--{{ section.id }} {
      padding: 44px 24px;
    }
    .home-order-tiles--{{ section.id }} .home-order-tiles__grid {
      gap: 16px;
    }
  }

  @media screen and (min-width: 1024px) {
    .home-order-tiles--{{ section.id }} .home-order-tiles__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 18px;
    }
    .home-order-tiles--{{ section.id }} .home-order-tiles__title {
      font-size: 28px;
      bottom: 16%;
    }
  }
</style>

{% schema %}
{
  "name": "Home order tiles",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Choose your path"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading (optional)"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#fffaf2"
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Tile",
      "limit": 4,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Order" },
        { "type": "text", "id": "link", "label": "Link (path, URL, anchor or query string)", "default": "/" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Choose your path",
      "category": "Storytelling",
      "blocks": [
        { "type": "tile", "settings": { "title": "Order", "link": "/pages/order" } },
        { "type": "tile", "settings": { "title": "Nationwide Shipping", "link": "/pages/ship-nationwide" } },
        { "type": "tile", "settings": { "title": "Special Events", "link": "/pages/events" } },
        { "type": "tile", "settings": { "title": "Candy", "link": "/pages/candy" } }
      ]
    }
  ]
}
{% endschema %}
