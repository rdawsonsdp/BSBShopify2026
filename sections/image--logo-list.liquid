{{ 'section-logo-list.min.css' | asset_url | stylesheet_tag }}

<section class="homepage-sections-wrapper">

    <style>
    /* Mobile: compact single-row scrollable strip ----------------------- */
    @media screen and (max-width: 767px) {
        .logo-bar-section--{{ section.id }} {
            padding-top: 18px;
            padding-bottom: 18px;
        }
        .logo-bar-section--{{ section.id }} .title-bar {
            margin-bottom: 8px;
        }
        .logo-bar-section--{{ section.id }} .title-bar h2 {
            font-size: 11px;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            opacity: 0.7;
            margin: 0;
        }
        .logo-bar-section--{{ section.id }} .title-bar h3.type-subheading {
            display: none;
        }
        .logo-bar-section--{{ section.id }} .logo-bar {
            display: flex;
            flex-wrap: nowrap;
            overflow-x: auto;
            gap: 18px;
            margin: 0;
            padding: 4px 12px 12px;
            scroll-snap-type: x mandatory;
            -webkit-overflow-scrolling: touch;
            scrollbar-width: none;
        }
        .logo-bar-section--{{ section.id }} .logo-bar::-webkit-scrollbar {
            display: none;
        }
        .logo-bar-section--{{ section.id }} .logo-bar__item {
            flex: 0 0 auto;
            width: auto;
            margin: 0;
            scroll-snap-align: start;
            display: flex;
            align-items: center;
        }
        .logo-bar-section--{{ section.id }} .logo-bar__item img {
            height: 36px;
            width: auto;
            max-width: none;
            object-fit: contain;
            opacity: 0.75;
            filter: grayscale(0.2);
            transition: opacity 0.2s ease;
        }
        .logo-bar-section--{{ section.id }} .logo-bar__item:hover img {
            opacity: 1;
        }
    }

    /* Desktop: original behavior, capped width ------------------------- */
    @media screen and (min-width: 768px) {
        .logo-bar-section--{{ section.id }} .logo-bar__item {
            width: {{ section.settings.width }}px;
        }
    }
    </style>

    <div class="container logo-bar-section--{{ section.id }}">
        <div class="row">
            <div class="page-width col-md-12">

                {% if section.settings.title != blank or section.settings.subheading != blank %}
                <div class="title-bar custom-font">
                    {% if section.settings.subheading != blank %}
                        <h3 class="type-subheading type-subheading--1 wow{% if section.settings.title != blank %} typography--padding-bottom{% endif %}">{{ section.settings.subheading | escape }}</h3>
                    {% endif %}
                    {% if section.settings.title != blank %}
                        <h2 class="wow">{{ section.settings.title | escape }}</h2>
                    {% endif %}
                </div>
                {% endif %}

                {% if section.blocks.size > 0 %}
                <div class="logo-bar">
                    {% for block in section.blocks %}
                        <div class="logo-bar__item wow" 
                            {{ block.shopify_attributes }}>
                            {% if block.settings.link != blank %}
                                <a href="{{ block.settings.link }}" class="logo-bar__link">
                            {% endif %}

                            {% if block.settings.image != blank %}
                                {% capture image_styles %}max-width: {{ block.settings.image.width }}px;{% endcapture %}
                                {% render 'responsive-image' with block.settings.image, alt: block.settings.image.alt, class: 'logo-bar__image', styles: image_styles, default_size: '240x' %}
                            {% else %}
                                {{ 'logo' | placeholder_svg_tag: 'icon--placeholder' }}
                            {% endif %}

                            {% if block.settings.link != blank %}
                                </a>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
                {% endif %}

                {% if section.blocks.size == 0 %}
                    <div class="placeholder-noblocks">
                        {{ 'general.onboarding.no_content' | t }}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</section>

{% schema %}
{
    "name": {
        "en": "Featured logos",
        "de": "Vorgestellte Logos",
        "es": "Logotipos destacados",
        "fr": "Logos en vedette",
        "pt-PT": "Logótipos em destaque"
    },
    "class": "homepage-section--logo-bar-wrapper",
    "max_blocks": 20,
    "settings": [
        {
            "type": "range",
            "id": "width",
            "label": {
                "en": "Logo width",
                "de": "Logobreite",
                "es": "Ancho del logotipo",
                "fr": "Largeur du logo",
                "pt-PT": "Largura do logótipo"
            },
            "min": 100,
            "max": 240,
            "step": 10,
            "unit": {
                "en": "px",
                "de": "px",
                "es": "px",
                "fr": "px",
                "pt-PT": "px"
            },
            "default": 150
        },
        {
            "type": "text",
            "id": "subheading",
            "label": {
              "en": "Subheading",
              "de": "Unterüberschrift",
              "es": "Subencabezado",
              "fr": "Sous-rubrique",
              "pt-PT": "Subtítulo"
            }
        },
        {
            "type": "text",
            "id": "title",
            "label": {
                "en": "Heading",
                "de": "Überschrift",
                "es": "Encabezado",
                "fr": "Rubrique",
                "pt-PT": "Título"
            },
            "default": {
                "en": "As seen in",
                "de": "Wie gesehen in",
                "es": "Visto en",
                "fr": "Comme on peut le voir dans",
                "pt-PT": "Conforme visto em"
            }
        }
    ],
    "blocks": [
        {
            "type": "logo_image",
            "name": {
                "en": "Logo",
                "de": "Logo",
                "es": "Logotipo",
                "fr": "Logo",
                "pt-PT": "Logótipo"
            },
            "settings": [
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": {
                        "en": "Image",
                        "de": "Bild",
                        "es": "Imagen",
                        "fr": "Image",
                        "pt-PT": "Imagem"
                    }
                },
                {
                    "type": "url",
                    "id": "link",
                    "label": {
                        "en": "Link",
                        "de": "Link",
                        "es": "Enlace",
                        "fr": "Lien",
                        "pt-PT": "Ligação"
                    },
                    "info": {
                        "en": "Optional",
                        "de": "Optional",
                        "es": "Opcional",
                        "fr": "Facultatif",
                        "pt-PT": "Opcional"
                    }
                }
            ]
        }
    ],
    "presets": [
        {
            "name": {
                "en": "Logo list",
                "de": "Logoliste",
                "es": "Lista de logotipos",
                "fr": "Liste des logos",
                "pt-PT": "Lista de logótipos"
            },
            "category": {
                "en": "Image",
                "de": "Bild",
                "es": "Imagen",
                "fr": "Image",
                "pt-PT": "Imagem"
            },
            "blocks": [
                {
                    "type": "logo_image"
                },
                {
                    "type": "logo_image"
                },
                {
                    "type": "logo_image"
                },
                {
                    "type": "logo_image"
                }
            ]
        }
    ],
    "disabled_on": {
        "groups": ["header"]
    }
}
{% endschema %}
