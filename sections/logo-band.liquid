{%- comment -%}
  Logo band — up to 8 logos in a tidy grid. Each block accepts image_picker or
  fallback_filename. Renders a numbered placeholder when neither is set.
  Reusable: "as featured in" press logos, partner / client logos, sponsor logos, etc.
{%- endcomment -%}

{%- liquid
  assign logo_blocks = section.blocks | where: 'type', 'logo'
-%}

<section class="logo-band logo-band--{{ section.id }}" aria-label="{{ section.settings.heading | default: 'Logos' | escape }}">
  <div class="logo-band__inner">
    {% if section.settings.eyebrow != blank %}
      <p class="logo-band__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2 class="logo-band__heading">{{ section.settings.heading | escape }}</h2>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p class="logo-band__subheading">{{ section.settings.subheading | escape }}</p>
    {% endif %}

    <div class="logo-band__grid" data-count="{{ logo_blocks.size }}">
      {%- for block in logo_blocks -%}
        {%- assign idx = forloop.index -%}
        {%- assign tile_link = block.settings.link -%}
        {% if tile_link != blank %}
          <a href="{{ tile_link }}" class="logo-band__cell" target="_blank" rel="noopener" aria-label="{{ block.settings.alt | default: 'Logo' | escape }}" {{ block.shopify_attributes }}>
        {% else %}
          <div class="logo-band__cell" {{ block.shopify_attributes }}>
        {% endif %}
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 400 | image_tag:
              loading: 'lazy',
              alt: block.settings.alt | default: 'Partner logo',
              class: 'logo-band__logo'
            }}
          {% elsif block.settings.fallback_filename != blank %}
            <img src="{{ block.settings.fallback_filename | asset_url }}" alt="{{ block.settings.alt | default: 'Partner logo' | escape }}" class="logo-band__logo" loading="lazy">
          {% else %}
            <span class="logo-band__placeholder" aria-label="Logo placeholder {{ idx }}">Logo {{ idx }}</span>
          {% endif %}
        {% if tile_link != blank %}
          </a>
        {% else %}
          </div>
        {% endif %}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .logo-band--{{ section.id }} {
    background: {{ section.settings.background_color | default: '#fffaf2' }};
    color: {{ section.settings.text_color | default: '#570522' }};
    padding: 36px 16px;
  }
  .logo-band--{{ section.id }} .logo-band__inner {
    max-width: 1200px;
    margin: 0 auto;
  }
  .logo-band--{{ section.id }} .logo-band__eyebrow {
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 700;
    margin: 0 0 8px;
    opacity: 0.75;
    text-align: center;
  }
  .logo-band--{{ section.id }} .logo-band__heading {
    font-size: clamp(20px, 3.4vw, 28px);
    font-weight: 800;
    margin: 0 0 8px;
    text-align: center;
    color: inherit;
  }
  .logo-band--{{ section.id }} .logo-band__subheading {
    font-size: 14px;
    line-height: 1.5;
    margin: 0 auto 24px;
    max-width: 560px;
    text-align: center;
    opacity: 0.85;
  }
  .logo-band--{{ section.id }} .logo-band__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 18px;
    align-items: center;
    margin-top: 16px;
  }
  .logo-band--{{ section.id }} .logo-band__cell {
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: inherit;
    transition: opacity 200ms ease, transform 200ms ease;
    padding: 8px;
  }
  .logo-band--{{ section.id }} a.logo-band__cell:hover {
    opacity: 0.7;
    transform: translateY(-2px);
  }
  .logo-band--{{ section.id }} .logo-band__logo {
    max-height: 100%;
    max-width: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    {% if section.settings.grayscale %}
    filter: grayscale(100%);
    opacity: 0.85;
    transition: filter 200ms, opacity 200ms;
    {% endif %}
  }
  {% if section.settings.grayscale %}
  .logo-band--{{ section.id }} .logo-band__cell:hover .logo-band__logo {
    filter: grayscale(0%);
    opacity: 1;
  }
  {% endif %}
  .logo-band--{{ section.id }} .logo-band__placeholder {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    border: 2px dashed rgba(91, 37, 18, 0.25);
    border-radius: 6px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(91, 37, 18, 0.45);
    background: rgba(91, 37, 18, 0.03);
  }
  @media screen and (min-width: 768px) {
    .logo-band--{{ section.id }} {
      padding: 48px 24px;
    }
    .logo-band--{{ section.id }} .logo-band__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 28px;
    }
    .logo-band--{{ section.id }} .logo-band__cell {
      height: 90px;
    }
  }
</style>

{% schema %}
{
  "name": "Logo band",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "checkbox",
      "id": "grayscale",
      "label": "Grayscale logos (color on hover)",
      "default": false
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#fffaf2"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#570522"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Logo image (PNG with transparency or SVG preferred)" },
        { "type": "text", "id": "fallback_filename", "label": "Fallback asset filename (e.g. logo-dusable.png)" },
        { "type": "text", "id": "alt", "label": "Alt text (organization or publication name)" },
        { "type": "url", "id": "link", "label": "Link (optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Logo band",
      "category": "Storytelling",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
