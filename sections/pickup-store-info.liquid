{% comment %}
  LIFT: Anxiety reduction — closing-soon indicator answers "do I have time to
  get there before they close?" Map iframe + Get Directions pillbox provide
  a one-tap path from "I see what I want" to "I'm in the car." Phone number
  on its own line is thumb-tappable on mobile.
{% endcomment %}

{%- liquid
  assign hours_blocks = section.blocks | where: 'type', 'hours_row'
-%}

<section
  class="pickup-store-info pickup-store-info--{{ section.id }}"
  data-section-id="{{ section.id }}"
  aria-label="Visit us"
>
  <div class="pickup-store-info__inner">
    {% if section.settings.eyebrow != blank %}
      <p class="pickup-store-info__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2 class="pickup-store-info__heading">{{ section.settings.heading | escape }}</h2>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p class="pickup-store-info__subheading">{{ section.settings.subheading | escape }}</p>
    {% endif %}

    <div class="pickup-store-info__grid">
      <div class="pickup-store-info__col pickup-store-info__col--info">
        <div class="bsb-info-box pickup-store-info__card">
          {%- if section.settings.address_line_1 != blank or section.settings.address_line_2 != blank -%}
            <p class="pickup-store-info__address">
              {%- if section.settings.address_line_1 != blank -%}
                {{ section.settings.address_line_1 | escape }}
              {%- endif -%}
              {%- if section.settings.address_line_2 != blank -%}
                <br>{{ section.settings.address_line_2 | escape }}
              {%- endif -%}
            </p>
          {%- endif -%}

          {%- if section.settings.phone_display != blank -%}
            <p class="pickup-store-info__phone-line">
              <a
                class="pickup-store-info__phone"
                href="tel:{{ section.settings.phone_tel | default: section.settings.phone_display | replace: '-', '' | replace: ' ', '' | replace: '(', '' | replace: ')', '' }}"
                aria-label="Call {{ section.settings.phone_display | escape }}"
              >{{ section.settings.phone_display | escape }}</a>
            </p>
          {%- endif -%}

          <div
            class="pickup-store-info__status"
            role="status"
            aria-live="polite"
            data-status
          >
            <span class="pickup-store-info__status-dot" aria-hidden="true" data-status-dot></span>
            <span data-status-text>Loading&hellip;</span>
          </div>

          {% comment %} TODO: confirm actual store hours with Stephanie before publishing. {% endcomment %}
          {%- if hours_blocks.size > 0 -%}
            <ul class="pickup-store-info__hours" data-hours-list>
              {%- for block in hours_blocks -%}
                <li
                  class="pickup-store-info__hours-row"
                  data-day="{{ block.settings.day }}"
                  data-open-time="{{ block.settings.open_time }}"
                  data-close-time="{{ block.settings.close_time }}"
                  data-is-closed="{% if block.settings.is_closed %}true{% else %}false{% endif %}"
                  {{ block.shopify_attributes }}
                >
                  <span class="pickup-store-info__hours-day">
                    {%- if block.settings.display_label != blank -%}
                      {{ block.settings.display_label | escape }}
                    {%- else -%}
                      {{ block.settings.day }}
                    {%- endif -%}
                  </span>
                  <span class="pickup-store-info__hours-time" data-hours-time>
                    {%- if block.settings.is_closed -%}
                      Closed
                    {%- else -%}
                      {{ block.settings.open_time }} &ndash; {{ block.settings.close_time }}
                    {%- endif -%}
                  </span>
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}

          <div class="pickup-store-info__buttons">
            {%- if section.settings.phone_display != blank -%}
              <a
                class="pickup-store-info__btn pickup-store-info__btn--primary"
                href="tel:{{ section.settings.phone_tel | default: section.settings.phone_display | replace: '-', '' | replace: ' ', '' | replace: '(', '' | replace: ')', '' }}"
                aria-label="Call {{ section.settings.phone_display | escape }}"
              >
                <svg
                  class="pickup-store-info__btn-icon"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>
                </svg>
                <span>Call {{ section.settings.phone_display | escape }}</span>
              </a>
            {%- endif -%}

            {%- if section.settings.directions_url != blank -%}
              <a
                class="pickup-store-info__btn pickup-store-info__btn--outline"
                href="{{ section.settings.directions_url }}"
                target="_blank"
                rel="noopener"
                aria-label="Get directions in Google Maps (opens in new tab)"
              >
                <svg
                  class="pickup-store-info__btn-icon"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
                <span>Get Directions</span>
              </a>
            {%- endif -%}
          </div>
        </div>
      </div>

      <div class="pickup-store-info__col pickup-store-info__col--map">
        {%- if section.settings.map_embed_src != blank -%}
          <iframe
            class="pickup-store-info__map"
            title="Map showing Brown Sugar Bakery at {{ section.settings.address_line_1 | escape }}"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            src="{{ section.settings.map_embed_src }}"
            width="100%"
            height="320"
            style="border:0;"
            allowfullscreen
          ></iframe>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
  .pickup-store-info--{{ section.id }} {
    background: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding: 36px 16px;
  }
  .pickup-store-info--{{ section.id }} .pickup-store-info__inner {
    max-width: 1100px;
    margin: 0 auto;
  }
  .pickup-store-info--{{ section.id }} .pickup-store-info__eyebrow {
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 700;
    margin: 0 0 8px;
    opacity: 0.75;
    text-align: center;
    color: {{ section.settings.accent_color }};
  }
  .pickup-store-info--{{ section.id }} .pickup-store-info__heading {
    font-size: clamp(22px, 4vw, 32px);
    font-weight: 800;
    margin: 0 0 8px;
    text-align: center;
    color: inherit;
    line-height: 1.2;
  }
  .pickup-store-info--{{ section.id }} .pickup-store-info__subheading {
    margin: 0 auto 28px;
    max-width: 600px;
    text-align: center;
    font-size: 15px;
    line-height: 1.5;
    opacity: 0.85;
  }

  .pickup-store-info--{{ section.id }} .pickup-store-info__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }
  .pickup-store-info--{{ section.id }} .pickup-store-info__col {
    min-width: 0;
  }

  /* Beveled enamelware card (matches .bsb-info-box pattern) */
  .pickup-store-info--{{ section.id }} .pickup-store-info__card {
    background: {{ section.settings.card_color }};
    color: {{ section.settings.text_color }};
    border: 1px solid rgba(91, 37, 18, 0.18);
    border-radius: 4px;
    padding: 20px 18px;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.55),
      inset 0 -1px 0 rgba(91, 37, 18, 0.10),
      0 1px 2px rgba(91, 37, 18, 0.10),
      0 6px 16px rgba(91, 37, 18, 0.08);
  }

  .pickup-store-info--{{ section.id }} .pickup-store-info__address {
    margin: 0 0 8px;
    font-size: 16px;
    line-height: 1.45;
    font-weight: 600;
  }
  .pickup-store-info--{{ section.id }} .pickup-store-info__phone-line {
    margin: 0 0 14px;
  }
  .pickup-store-info--{{ section.id }} .pickup-store-info__phone {
    color: {{ section.settings.text_color }};
    text-decoration: underline;
    font-size: 15px;
    font-weight: 600;
  }
  .pickup-store-info--{{ section.id }} .pickup-store-info__phone:hover {
    color: {{ section.settings.accent_color }};
  }

  /* Status indicator */
  .pickup-store-info--{{ section.id }} .pickup-store-info__status {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    margin: 0 0 14px;
    background: rgba(91, 37, 18, 0.06);
    border: 1px solid rgba(91, 37, 18, 0.15);
    border-radius: 999px;
    font-size: 14px;
    font-weight: 600;
    color: {{ section.settings.text_color }};
  }
  .pickup-store-info--{{ section.id }} .pickup-store-info__status-dot {
    display: inline-block;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: rgba(91, 37, 18, 0.4);
    flex-shrink: 0;
  }
  .pickup-store-info--{{ section.id }} .pickup-store-info__status-dot.is-open {
    background: {{ section.settings.accent_color }};
    box-shadow: 0 0 0 2px rgba(186, 91, 40, 0.18);
  }
  .pickup-store-info--{{ section.id }} .pickup-store-info__status-dot.is-closing-soon {
    background: #e68c3b;
    box-shadow: 0 0 0 2px rgba(230, 140, 59, 0.22);
    animation: pickup-store-info-pulse-{{ section.id }} 1400ms ease-in-out infinite;
  }
  .pickup-store-info--{{ section.id }} .pickup-store-info__status-dot.is-closed {
    background: rgba(91, 37, 18, 0.4);
  }
  @keyframes pickup-store-info-pulse-{{ section.id }} {
    0%   { transform: scale(1);   opacity: 1; }
    50%  { transform: scale(1.25); opacity: 0.7; }
    100% { transform: scale(1);   opacity: 1; }
  }

  /* Hours list */
  .pickup-store-info--{{ section.id }} .pickup-store-info__hours {
    list-style: none;
    padding: 0;
    margin: 0 0 16px;
    border-top: 1px solid rgba(91, 37, 18, 0.12);
  }
  .pickup-store-info--{{ section.id }} .pickup-store-info__hours-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 7px 0;
    border-bottom: 1px solid rgba(91, 37, 18, 0.12);
    font-size: 14px;
    line-height: 1.4;
  }
  .pickup-store-info--{{ section.id }} .pickup-store-info__hours-row.is-today {
    font-weight: 800;
    color: {{ section.settings.text_color }};
  }
  .pickup-store-info--{{ section.id }} .pickup-store-info__hours-row.is-today .pickup-store-info__hours-day::before {
    content: "\2192\00a0";
    color: {{ section.settings.accent_color }};
  }
  .pickup-store-info--{{ section.id }} .pickup-store-info__hours-day {
    text-transform: capitalize;
  }
  .pickup-store-info--{{ section.id }} .pickup-store-info__hours-time {
    font-variant-numeric: tabular-nums;
  }

  /* Buttons row */
  .pickup-store-info--{{ section.id }} .pickup-store-info__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 4px;
  }
  .pickup-store-info--{{ section.id }} .pickup-store-info__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-decoration: none !important;
    transition: background 180ms ease, color 180ms ease, border-color 180ms ease, transform 80ms ease;
  }
  .pickup-store-info--{{ section.id }} .pickup-store-info__btn:active {
    transform: translateY(1px);
  }
  .pickup-store-info--{{ section.id }} .pickup-store-info__btn-icon {
    flex-shrink: 0;
  }
  .pickup-store-info--{{ section.id }} .pickup-store-info__btn--primary {
    background: #570522;
    color: #fffaf2 !important;
    border: 1px solid #2e0212;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.18),
      inset 0 -1px 0 rgba(0, 0, 0, 0.22),
      0 1px 0 rgba(46, 2, 18, 0.4),
      0 2px 4px rgba(46, 2, 18, 0.18);
    text-shadow: 0 1px 0 rgba(0, 0, 0, 0.3);
  }
  .pickup-store-info--{{ section.id }} .pickup-store-info__btn--primary:hover {
    background: {{ section.settings.accent_color }};
    border-color: #6e3514;
  }
  .pickup-store-info--{{ section.id }} .pickup-store-info__btn--primary:focus-visible {
    outline: 2px solid #2e0212;
    outline-offset: 2px;
  }
  .pickup-store-info--{{ section.id }} .pickup-store-info__btn--outline {
    background: transparent;
    color: #570522 !important;
    border: 1.5px solid #570522;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.35),
      inset 0 -1px 0 rgba(46, 2, 18, 0.10),
      0 1px 0 rgba(46, 2, 18, 0.18),
      0 2px 4px rgba(46, 2, 18, 0.10);
  }
  .pickup-store-info--{{ section.id }} .pickup-store-info__btn--outline:hover {
    background: #570522;
    color: #fffaf2 !important;
    border-color: #2e0212;
    text-shadow: 0 1px 0 rgba(0, 0, 0, 0.3);
  }
  .pickup-store-info--{{ section.id }} .pickup-store-info__btn--outline:focus-visible {
    outline: 2px solid #570522;
    outline-offset: 2px;
  }

  /* Map */
  .pickup-store-info--{{ section.id }} .pickup-store-info__map {
    display: block;
    width: 100%;
    height: 320px;
    border: 0;
    border-radius: 4px;
    box-shadow:
      0 1px 2px rgba(91, 37, 18, 0.10),
      0 6px 16px rgba(91, 37, 18, 0.08);
  }

  @media screen and (min-width: 768px) {
    .pickup-store-info--{{ section.id }} {
      padding: 56px 24px;
    }
    .pickup-store-info--{{ section.id }} .pickup-store-info__grid {
      grid-template-columns: 1fr 1fr;
      gap: 28px;
      align-items: stretch;
    }
    .pickup-store-info--{{ section.id }} .pickup-store-info__card {
      height: 100%;
      padding: 24px 22px;
    }
    .pickup-store-info--{{ section.id }} .pickup-store-info__map {
      height: 100%;
      min-height: 360px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pickup-store-info--{{ section.id }} .pickup-store-info__status-dot.is-closing-soon {
      animation: none;
    }
    .pickup-store-info--{{ section.id }} .pickup-store-info__btn {
      transition: none;
    }
  }
</style>

<script>
  (function () {
    var root = document.querySelector('.pickup-store-info[data-section-id="{{ section.id }}"]');
    if (!root) return;

    var statusTextEl = root.querySelector('[data-status-text]');
    var statusDotEl  = root.querySelector('[data-status-dot]');
    var hoursList    = root.querySelector('[data-hours-list]');
    if (!statusTextEl || !statusDotEl) return;

    // Map of weekday name (lowercase, full or short) → canonical short code
    var DAY_ALIASES = {
      sunday: 'sun', sun: 'sun',
      monday: 'mon', mon: 'mon',
      tuesday: 'tue', tue: 'tue', tues: 'tue',
      wednesday: 'wed', wed: 'wed',
      thursday: 'thu', thu: 'thu', thur: 'thu', thurs: 'thu',
      friday: 'fri', fri: 'fri',
      saturday: 'sat', sat: 'sat'
    };
    var DAY_FULL_NAMES = {
      sun: 'Sunday', mon: 'Monday', tue: 'Tuesday', wed: 'Wednesday',
      thu: 'Thursday', fri: 'Friday', sat: 'Saturday'
    };
    // Order so we can compute "next open day"
    var DAY_ORDER = ['sun', 'mon', 'tue', 'wed', 'thu', 'fri', 'sat'];

    function normalizeDay(raw) {
      if (!raw) return null;
      var key = String(raw).trim().toLowerCase();
      return DAY_ALIASES[key] || null;
    }

    function parseTime(hhmm) {
      if (!hhmm) return null;
      var parts = String(hhmm).trim().split(':');
      if (parts.length < 2) return null;
      var h = parseInt(parts[0], 10);
      var m = parseInt(parts[1], 10);
      if (isNaN(h) || isNaN(m)) return null;
      return { h: h, m: m, mins: h * 60 + m };
    }

    function formatTime12(hhmm) {
      var t = parseTime(hhmm);
      if (!t) return hhmm || '';
      var h = t.h;
      var m = t.m;
      var ampm = h >= 12 ? 'PM' : 'AM';
      var h12 = h % 12;
      if (h12 === 0) h12 = 12;
      var mm = m < 10 ? '0' + m : '' + m;
      if (m === 0) {
        return h12 + ':' + mm + ' ' + ampm;
      }
      return h12 + ':' + mm + ' ' + ampm;
    }

    // Build canonical hours table from blocks: { sun: {open, close, isClosed}, ... }
    var hoursByDay = {};
    if (hoursList) {
      var rows = hoursList.querySelectorAll('.pickup-store-info__hours-row');
      for (var i = 0; i < rows.length; i++) {
        var row = rows[i];
        var dayCode = normalizeDay(row.getAttribute('data-day'));
        if (!dayCode) continue;
        var isClosed = row.getAttribute('data-is-closed') === 'true';
        hoursByDay[dayCode] = {
          open: row.getAttribute('data-open-time') || '',
          close: row.getAttribute('data-close-time') || '',
          isClosed: isClosed,
          el: row
        };
      }
    }

    // Get current day-of-week + minutes-since-midnight in America/Chicago.
    function getCtNow() {
      try {
        var fmt = new Intl.DateTimeFormat('en-US', {
          timeZone: 'America/Chicago',
          weekday: 'long',
          hour: 'numeric',
          minute: 'numeric',
          hour12: false
        });
        var parts = fmt.formatToParts(new Date());
        var weekday = '';
        var hour = 0;
        var minute = 0;
        for (var i = 0; i < parts.length; i++) {
          var p = parts[i];
          if (p.type === 'weekday') weekday = p.value;
          else if (p.type === 'hour') hour = parseInt(p.value, 10);
          else if (p.type === 'minute') minute = parseInt(p.value, 10);
        }
        // hour12:false yields '24' for midnight in some browsers — coerce
        if (hour === 24) hour = 0;
        var dayCode = normalizeDay(weekday);
        return {
          dayCode: dayCode,
          mins: hour * 60 + minute
        };
      } catch (e) {
        // Fallback — local time
        var d = new Date();
        var localDays = ['sun','mon','tue','wed','thu','fri','sat'];
        return {
          dayCode: localDays[d.getDay()],
          mins: d.getHours() * 60 + d.getMinutes()
        };
      }
    }

    function nextOpenDay(fromDayCode) {
      if (!fromDayCode) return null;
      var startIdx = DAY_ORDER.indexOf(fromDayCode);
      if (startIdx < 0) return null;
      for (var step = 1; step <= 7; step++) {
        var idx = (startIdx + step) % 7;
        var code = DAY_ORDER[idx];
        var entry = hoursByDay[code];
        if (entry && !entry.isClosed && entry.open) {
          return { code: code, entry: entry, daysAhead: step };
        }
      }
      return null;
    }

    function setStatus(state, text) {
      statusDotEl.classList.remove('is-open', 'is-closing-soon', 'is-closed');
      statusDotEl.classList.add(state);
      if (statusTextEl) statusTextEl.textContent = text;
    }

    function highlightToday(dayCode) {
      if (!hoursList) return;
      var rows = hoursList.querySelectorAll('.pickup-store-info__hours-row');
      for (var i = 0; i < rows.length; i++) {
        var rowDay = normalizeDay(rows[i].getAttribute('data-day'));
        if (rowDay === dayCode) {
          rows[i].classList.add('is-today');
        } else {
          rows[i].classList.remove('is-today');
        }
      }
    }

    function compute() {
      var now = getCtNow();
      var dayCode = now.dayCode;
      var nowMins = now.mins;
      highlightToday(dayCode);

      var today = dayCode ? hoursByDay[dayCode] : null;

      // Closed today: no entry, marked closed, before open, or after close.
      var isCurrentlyOpen = false;
      var minsToClose = null;
      if (today && !today.isClosed) {
        var openT = parseTime(today.open);
        var closeT = parseTime(today.close);
        if (openT && closeT && nowMins >= openT.mins && nowMins < closeT.mins) {
          isCurrentlyOpen = true;
          minsToClose = closeT.mins - nowMins;
        }
      }

      if (isCurrentlyOpen && minsToClose != null) {
        if (minsToClose <= 60) {
          var label = minsToClose <= 1
            ? 'Closing in 1 minute'
            : 'Closing in ' + minsToClose + ' minutes';
          setStatus('is-closing-soon', label);
        } else {
          setStatus('is-open', 'Open until ' + formatTime12(today.close) + ' CT');
        }
        return;
      }

      // Closed — find next open day.
      var next = nextOpenDay(dayCode);
      if (next) {
        var prefix;
        if (next.daysAhead === 1) {
          prefix = 'Closed \u2014 opens tomorrow at ';
        } else {
          prefix = 'Closed \u2014 opens ' + DAY_FULL_NAMES[next.code] + ' at ';
        }
        setStatus('is-closed', prefix + formatTime12(next.entry.open));
      } else {
        setStatus('is-closed', 'Closed');
      }
    }

    compute();
    setInterval(compute, 60 * 1000);
  })();
</script>

{% schema %}
{
  "name": "Pickup store info",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "VISIT US"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Stop by 75th Street."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Same-day pickup, walk-in welcome. Here's how to find us."
    },
    {
      "type": "header",
      "content": "Address & contact"
    },
    {
      "type": "text",
      "id": "address_line_1",
      "label": "Address line 1",
      "default": "328 E 75th Street"
    },
    {
      "type": "text",
      "id": "address_line_2",
      "label": "Address line 2",
      "default": "Chicago, IL 60619"
    },
    {
      "type": "text",
      "id": "phone_display",
