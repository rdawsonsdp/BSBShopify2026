{% comment %}
  LIFT: Clarity + Anxiety — replaces the 7-day calendar widget with a clean
  three-row flow. Each row shows one shipping path: SHIPS [day] → ARRIVES [day].
  Same message as the calendar; far easier to scan.
{% endcomment %}

<section class="ship-rhythm ship-rhythm--{{ section.id }}" aria-label="{{ section.settings.heading | default: 'Our shipping rhythm' | escape }}">
  <div class="ship-rhythm__inner">
    {% if section.settings.eyebrow != blank %}
      <p class="ship-rhythm__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2 class="ship-rhythm__heading">{{ section.settings.heading | escape }}</h2>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p class="ship-rhythm__subheading">{{ section.settings.subheading | escape }}</p>
    {% endif %}

    <ol class="ship-rhythm__rows" role="list">
      <li class="ship-rhythm__row">
        <span class="ship-rhythm__day ship-rhythm__day--ship">Monday</span>
        <span class="ship-rhythm__arrow" aria-hidden="true">&rarr;</span>
        <span class="ship-rhythm__day ship-rhythm__day--arrival">Wednesday</span>
      </li>
      <li class="ship-rhythm__row">
        <span class="ship-rhythm__day ship-rhythm__day--ship">Tuesday</span>
        <span class="ship-rhythm__arrow" aria-hidden="true">&rarr;</span>
        <span class="ship-rhythm__day ship-rhythm__day--arrival">Thursday</span>
      </li>
      <li class="ship-rhythm__row">
        <span class="ship-rhythm__day ship-rhythm__day--ship">Wednesday</span>
        <span class="ship-rhythm__arrow" aria-hidden="true">&rarr;</span>
        <span class="ship-rhythm__day ship-rhythm__day--arrival">Friday</span>
      </li>
    </ol>
    <div class="ship-rhythm__legend" aria-hidden="true">
      <span class="ship-rhythm__legend-item"><span class="ship-rhythm__legend-dot ship-rhythm__legend-dot--ship"></span>Ship day</span>
      <span class="ship-rhythm__legend-item"><span class="ship-rhythm__legend-dot ship-rhythm__legend-dot--arrival"></span>Arrives</span>
    </div>

    {% if section.settings.note != blank %}
      <p class="ship-rhythm__note">{{ section.settings.note | escape }}</p>
    {% endif %}
  </div>
</section>

<style>
  .ship-rhythm--{{ section.id }} {
    background: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding: 36px 16px;
  }
  .ship-rhythm--{{ section.id }} .ship-rhythm__inner {
    max-width: 920px;
    margin: 0 auto;
  }
  .ship-rhythm--{{ section.id }} .ship-rhythm__eyebrow {
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 800;
    color: {{ section.settings.accent_color }};
    text-align: center;
    margin: 0 0 8px;
  }
  .ship-rhythm--{{ section.id }} .ship-rhythm__heading {
    font-size: clamp(22px, 5vw, 32px);
    font-weight: 800;
    text-align: center;
    margin: 0 0 8px;
    color: inherit;
    line-height: 1.15;
  }
  .ship-rhythm--{{ section.id }} .ship-rhythm__subheading {
    font-size: 15px;
    text-align: center;
    margin: 0 auto 28px;
    max-width: 600px;
    line-height: 1.5;
    opacity: 0.82;
  }

  /* Simpler flat rhythm — text-only rows, day → day, no pills, no SVG. */
  .ship-rhythm--{{ section.id }} .ship-rhythm__rows {
    list-style: none;
    padding: 0;
    margin: 0;
    max-width: 380px;
    margin-left: auto;
    margin-right: auto;
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid rgba(87, 5, 34, 0.12);
  }
  .ship-rhythm--{{ section.id }} .ship-rhythm__row {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 12px;
    padding: 14px 8px;
    border-bottom: 1px solid rgba(87, 5, 34, 0.12);
    font-size: clamp(18px, 4.5vw, 22px);
    font-weight: 700;
  }
  .ship-rhythm--{{ section.id }} .ship-rhythm__day {
    line-height: 1.15;
  }
  .ship-rhythm--{{ section.id }} .ship-rhythm__day--ship {
    text-align: right;
    color: {{ section.settings.ship_color }};
  }
  .ship-rhythm--{{ section.id }} .ship-rhythm__day--arrival {
    text-align: left;
    color: {{ section.settings.arrival_color }};
  }
  .ship-rhythm--{{ section.id }} .ship-rhythm__arrow {
    font-size: 18px;
    color: rgba(87, 5, 34, 0.45);
    font-weight: 600;
  }
  .ship-rhythm--{{ section.id }} .ship-rhythm__legend {
    display: flex;
    justify-content: center;
    gap: 18px;
    margin: 14px 0 0;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(87, 5, 34, 0.62);
  }
  .ship-rhythm--{{ section.id }} .ship-rhythm__legend-item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .ship-rhythm--{{ section.id }} .ship-rhythm__legend-dot {
    display: inline-block;
    width: 9px; height: 9px;
    border-radius: 999px;
  }
  .ship-rhythm--{{ section.id }} .ship-rhythm__legend-dot--ship {
    background: {{ section.settings.ship_color }};
  }
  .ship-rhythm--{{ section.id }} .ship-rhythm__legend-dot--arrival {
    background: {{ section.settings.arrival_color }};
  }
  .ship-rhythm--{{ section.id }} .ship-rhythm__note {
    text-align: center;
    margin: 18px auto 0;
    max-width: 600px;
    font-size: 14px;
    line-height: 1.55;
    color: inherit;
    opacity: 0.7;
  }

  @media (min-width: 768px) {
    .ship-rhythm--{{ section.id }} {
      padding: 48px 24px 48px;
    }
  }
</style>

{% schema %}
{
  "name": "Shipping Rhythm",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "BAKE DAY · SHIP DAY"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "We ship Monday, Tuesday, and Wednesday."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Why those three days? UPS doesn't deliver Sundays — your cake never sits in a warehouse."
    },
    {
      "type": "textarea",
      "id": "note",
      "label": "Footnote (optional)",
      "default": "Order by Sunday 6 PM CT for a Wednesday arrival. By Tuesday 6 PM for end-of-week."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f7ead6"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#570522"
    },
    {
      "type": "color",
      "id": "ship_color",
      "label": "Ship-day fill",
      "default": "#570522"
    },
    {
      "type": "color",
      "id": "arrival_color",
      "label": "Arrival-day fill",
      "default": "#ba5b28"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent (arrows + eyebrow)",
      "default": "#ba5b28"
    }
  ],
  "presets": [
    {
      "name": "Shipping Rhythm",
      "category": "Storytelling"
    }
  ]
}
{% endschema %}
