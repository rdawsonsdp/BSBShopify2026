{% if section.settings.enable and request.page_type == 'index' %}
  <section
    class="topical-announcement"
    aria-label="{{ section.settings.aria_label | default: 'Announcement' | escape }}"
    style="background-color: {{ section.settings.background_color }}; color: {{ section.settings.text_color }};"
  >
    <div class="topical-announcement__inner">
      {% if section.settings.eyebrow != blank %}
        <p class="topical-announcement__eyebrow" style="color: {{ section.settings.accent_color }};">
          {{ section.settings.eyebrow | escape }}
        </p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="topical-announcement__heading">
          {{ section.settings.heading | escape }}
        </h2>
      {% endif %}

      {% if section.settings.body != blank %}
        <div class="topical-announcement__body">
          {{ section.settings.body }}
        </div>
      {% endif %}

      {% if section.settings.highlight != blank %}
        <p class="topical-announcement__highlight" style="color: {{ section.settings.accent_color }};">
          {{ section.settings.highlight }}
        </p>
      {% endif %}

      {% if section.settings.button_label != blank and section.settings.button_link != blank %}
        <a
          href="{{ section.settings.button_link }}"
          class="topical-announcement__button"
          style="background-color: {{ section.settings.accent_color }}; color: {{ section.settings.button_text_color }};"
        >
          {{ section.settings.button_label | escape }}
        </a>
      {% endif %}
    </div>
  </section>

  <style>
    .topical-announcement {
      width: 100%;
      padding: 14px 20px;
      text-align: center;
    }
    .topical-announcement__inner {
      max-width: 720px;
      margin: 0 auto;
    }
    .topical-announcement__eyebrow {
      font-size: 10px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      font-weight: 700;
      margin: 0 0 4px;
    }
    .topical-announcement__heading {
      font-size: clamp(16px, 3.4vw, 22px);
      line-height: 1.2;
      font-weight: 800;
      margin: 0 0 4px;
      color: inherit;
    }
    .topical-announcement__body {
      font-size: clamp(12px, 1.8vw, 14px);
      line-height: 1.4;
      margin: 0 auto 4px;
      max-width: 580px;
    }
    .topical-announcement__body p {
      margin: 0;
    }
    .topical-announcement__highlight {
      font-size: clamp(12px, 1.8vw, 14px);
      font-weight: 700;
      line-height: 1.35;
      margin: 2px auto 0;
    }
    .topical-announcement__button {
      display: inline-block;
      margin-top: 8px;
      padding: 8px 18px;
      min-height: 0;
      font-weight: 700;
      font-size: 13px;
      border-radius: 5px;
      text-decoration: none;
      transition: transform 200ms ease, box-shadow 200ms ease, filter 200ms ease;
      box-shadow: 0 2px 6px rgba(0, 0, 0, 0.10);
    }
    .topical-announcement__button:hover,
    .topical-announcement__button:focus-visible {
      transform: translateY(-1px);
      filter: brightness(1.06);
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.16);
      outline: none;
    }
    @media screen and (max-width: 575px) {
      .topical-announcement {
        padding: 10px 14px;
      }
      .topical-announcement__body {
        display: none;
      }
    }
  </style>
{% endif %}

{% schema %}
{
  "name": "Topical Announcement",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable",
      "label": "Show announcement",
      "default": true
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow / Tag",
      "info": "Optional small label above heading (e.g., NEW, SEASONAL, SHIPPING)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Original Caramel Cake of Chicago"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body text",
      "default": "<p>We bake fresh and ship same-day, so cakes arrive ready to enjoy.</p>"
    },
    {
      "type": "text",
      "id": "highlight",
      "label": "Highlight line",
      "info": "Optional bold callout line (e.g., \"Free Shipping on orders over $75\")"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "ARIA label (accessibility)",
      "default": "Announcement"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#fffaf2"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#2D2D2D"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent (eyebrow + highlight + button bg)",
      "default": "#570522"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Topical Announcement",
      "category": "Promotional"
    }
  ]
}
{% endschema %}
