{{ 'section-video-with-text-overlay.min.css' | asset_url | stylesheet_tag }}

{% capture textalignment %}
    {% case section.settings.textAlignment %}
    {% when 'top-left' %}
        text-align-top-left
    {% when 'top-center' %}
        text-align-top-center
    {% when 'top-right' %}
        text-align-top-right
    {% when 'center-left' %}
        text-align-center-left
    {% when 'center' %}
        text-align-center
    {% when 'center-right' %}
        text-align-center-right
    {% when 'bottom-left' %}
        text-align-bottom-left
    {% when 'bottom-center' %}
        text-align-bottom-center
    {% when 'bottom-right' %}
        text-align-bottom-right
    {% endcase %}
{% endcapture %}

{% capture desktopheight %}
    {% case section.settings.desktopHeight %}
    {% when '450' %}
        desktop-height-450
    {% when '550' %}
        desktop-height-550
    {% when '650' %}
        desktop-height-650
    {% when '750' %}
        desktop-height-750
    {% when 'fullscreen' %}
        desktop-height-fullscreen
    {% endcase %}
{% endcapture %}

{% capture mobileheight %}
    {% case section.settings.mobileHeight %}
    {% when '250' %}
        mobile-height-250
    {% when '350' %}
        mobile-height-350
    {% when '450' %}
        mobile-height-450
    {% when '550' %}
        mobile-height-550
    {% when 'fullscreen' %}
        mobile-height-fullscreen
    {% when 'fit' %}
        mobile-height-fit
    {% endcase %}
{% endcapture %}

{% capture isplaceholder %}
    {% if section.settings.url contains "watch?v=_9VUPq3SxOc" %}
        is-placeholder
    {% endif %}
{% endcapture %}

<section
    class="homepage-sections-wrapper homepage-content--{{ section.id }} hero-video {{ desktopheight | strip }} {{ mobileheight | strip }} {{ isplaceholder | strip }}"
    data-wetheme-section-type="video--video-with-text-overlay"
    data-wetheme-section-id="{{ section.id }}"
    tabindex="0"
>
    <div class="hero-video--wrapper">
        {% assign type = 'invalid' %}
        {% if section.settings.url contains "youtube.com" %}
            {% assign type = 'youtube' %}
        {% elsif section.settings.url contains "youtu.be" %}
            {% assign type = 'youtube' %}
        {% elsif section.settings.url contains "vimeo.com" %}
            {% assign type = 'vimeo' %}
        {% elsif section.settings.url contains "cdn.shopify.com" %}
            {% unless section.settings.url contains ".mov" or section.settings.url contains ".wmv" or section.settings.url contains ".avi" %}
                {% assign type = 'mp4' %}
            {% endunless %}
        {% endif %}
        <div class="hero-video--media hero-video--{{ type }}"{% if type == "invalid"%} style="display: none;"{% endif %}> 
            <wetheme-video
                hero="true"
                video-type="{{ type }}"
                url="{{ section.settings.url }}"
                autoplay="true"
                loop="false"
                mute="true"
                hide-controls="true"
            >
            </wetheme-video>
            {%- if section.settings.clip_seconds and section.settings.clip_seconds > 0 or section.settings.start_seconds and section.settings.start_seconds > 0 or section.settings.disable_autoplay_mobile -%}
              <script>
                (function () {
                  var SECTION_ID = {{ section.id | json }};
                  var START = {{ section.settings.start_seconds | default: 0 | json }};
                  var CLIP = {{ section.settings.clip_seconds | default: 0 | json }};
                  var END = CLIP > 0 ? START + CLIP : 0;
                  var DISABLE_MOBILE = {{ section.settings.disable_autoplay_mobile | default: false | json }};
                  var IS_MOBILE = window.matchMedia && window.matchMedia('(max-width: 767px)').matches;
                  var TYPE = {{ type | json }};
                  var rootSelector = '.homepage-content--' + SECTION_ID;

                  function findIframe(retries) {
                    var root = document.querySelector(rootSelector);
                    if (!root) return retries > 0 ? setTimeout(function(){findIframe(retries-1);}, 200) : null;
                    var iframe = root.querySelector('iframe');
                    if (!iframe) return retries > 0 ? setTimeout(function(){findIframe(retries-1);}, 200) : null;
                    return wirePlayer(iframe);
                  }

                  function wirePlayer(iframe) {
                    if (TYPE === 'vimeo') {
                      // Add Vimeo Player API param so postMessage works cross-origin
                      try {
                        var src = iframe.getAttribute('src') || '';
                        if (src && src.indexOf('api=1') === -1) {
                          var sep = src.indexOf('?') === -1 ? '?' : '&';
                          iframe.setAttribute('src', src + sep + 'api=1&player_id=clip-' + SECTION_ID);
                        }
                      } catch (e) {}
                      loadVimeoApi(function () {
                        if (!window.Vimeo || !window.Vimeo.Player) return;
                        var player = new window.Vimeo.Player(iframe);
                        if (START > 0) {
                          player.ready().then(function () {
                            player.setCurrentTime(START).catch(function(){});
                          });
                        }
                        if (END > 0) {
                          var stopped = false;
                          player.on('timeupdate', function (data) {
                            if (!stopped && data && data.seconds >= END) {
                              stopped = true;
                              player.pause().catch(function(){});
                            }
                          });
                        }
                        if (DISABLE_MOBILE && IS_MOBILE) {
                          player.ready().then(function () {
                            player.pause().catch(function(){});
                          });
                        }
                      });
                    } else if (TYPE === 'youtube') {
                      // Use the YT IFrame API
                      try {
                        var src = iframe.getAttribute('src') || '';
                        if (src && src.indexOf('enablejsapi=1') === -1) {
                          var sep = src.indexOf('?') === -1 ? '?' : '&';
                          iframe.setAttribute('src', src + sep + 'enablejsapi=1');
                        }
                      } catch (e) {}
                      loadYouTubeApi(function () {
                        if (!window.YT || !window.YT.Player) return;
                        var player = new window.YT.Player(iframe, {
                          events: {
                            onReady: function () {
                              if (START > 0) {
                                try { player.seekTo(START, true); } catch (e) {}
                              }
                              if (DISABLE_MOBILE && IS_MOBILE) {
                                try { player.pauseVideo(); } catch (e) {}
                              }
                              if (END > 0) {
                                var ytStopped = false;
                                var ytTimer = setInterval(function () {
                                  try {
                                    if (!ytStopped && player.getCurrentTime() >= END) {
                                      ytStopped = true;
                                      player.pauseVideo();
                                      clearInterval(ytTimer);
                                    }
                                  } catch (e) {}
                                }, 250);
                              }
                            }
                          }
                        });
                      });
                    }
                  }

                  function loadVimeoApi(cb) {
                    if (window.Vimeo && window.Vimeo.Player) return cb();
                    var s = document.createElement('script');
                    s.src = 'https://player.vimeo.com/api/player.js';
                    s.onload = cb;
                    document.head.appendChild(s);
                  }

                  function loadYouTubeApi(cb) {
                    if (window.YT && window.YT.Player) return cb();
                    var prev = window.onYouTubeIframeAPIReady;
                    window.onYouTubeIframeAPIReady = function () {
                      if (prev) try { prev(); } catch (e) {}
                      cb();
                    };
                    if (!document.querySelector('script[src*="youtube.com/iframe_api"]')) {
                      var s = document.createElement('script');
                      s.src = 'https://www.youtube.com/iframe_api';
                      document.head.appendChild(s);
                    }
                  }

                  if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', function(){ findIframe(20); });
                  } else {
                    findIframe(20);
                  }
                })();
              </script>
            {%- endif -%}
            {% if section.settings.mobileHeight == 'fit' %}
                <div class="hero-video--mobile-image">
                    {% if section.settings.mobile_fallback_asset != blank %}
                        <img src="{{ section.settings.mobile_fallback_asset | asset_url }}" alt="" loading="eager" style="width:100%;height:auto;display:block;object-fit:cover;">
                    {% elsif section.settings.image != blank %}
                        {% render 'responsive-image' with section.settings.image, alt: section.settings.image.alt %}
                    {% else %}
                        {{ 'lifestyle-1' | placeholder_svg_tag: 'icon--placeholder' }}
                    {% endif %}
                </div>
                <style>
                    @media screen and (max-width: 769px) {
                        .homepage-content--{{ section.id }}.mobile-height-fit .hero-video--media,
                        .homepage-content--{{ section.id }} .hero-video--media {
                            position: relative !important;
                            height: auto !important;
                            min-height: 0 !important;
                            overflow: visible !important;
                        }
                        .homepage-content--{{ section.id }} .hero-video--mobile-image {
                            display: block;
                            width: 100%;
                        }
                        .homepage-content--{{ section.id }} .hero-video--mobile-image img {
                            width: 100% !important;
                            height: auto !important;
                            display: block !important;
                        }
                        .homepage-content--{{ section.id }} wetheme-video,
                        .homepage-content--{{ section.id }} .plyr,
                        .homepage-content--{{ section.id }} iframe {
                            display: none !important;
                        }
                    }
                </style>
            {% endif %}
        </div>
        <div class="hero-video--text">
            {% if section.settings.image == blank %}
                <div class="placeholder-background img"{% if type == "invalid" %} style="display: block;"{% endif %}>
                    {{ 'lifestyle-1' | placeholder_svg_tag: 'icon--placeholder' }}
                </div>
            {% else %}
                <div class="section-background img"{% if type == "invalid" %} style="display: block;"{% endif %}>
                </div>
            {% endif %}
            <div class="hero-video--text-content {{ textalignment | strip }}">
                <div class="text-content--inner{% if section.settings.textShadow %} text-shadow{% endif %} wow">
                    {% if section.settings.subheading != blank %}
                      <h3 class="type-subheading{% if section.settings.title != blank %} typography--padding-bottom {% endif %}"> {{ section.settings.subheading | escape }}</h3>
                    {% endif %}
                    {% if section.settings.title != blank %}
                      <div class="hero-video--text-title">
                        <h1 class="text-size-{{ section.settings.heading--text-size }}px wow">{{ section.settings.title }}</h1>
                      </div>
                    {% endif %}
                    {% if section.settings.text != blank %}
                      <div class="hero__text textarea rte">{{ section.settings.text }}</div>
                    {% endif %}
                    {% if section.settings.button_label != blank %}
                    <div class="hero-video--button">
                        <a class="btn" href="{{ section.settings.button_link }}" tabindex="0">{{ section.settings.button_label }}</a>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</section>

{% if section.settings.image != blank %}
	<style>
        {% capture selector %}.homepage-content--{{ section.id }} .section-background{% endcapture %}
        {% capture video_poster %}.homepage-content--{{ section.id }} .plyr--video{% endcapture %}
        {% render 'responsive-background-image' with section.settings.image, selector: selector %}
        {% render 'responsive-background-image' with section.settings.image, selector: video_poster %}

        .homepage-content--{{ section.id }} .section-background,
        .homepage-content--{{ section.id }} .plyr--video {
            background-repeat: no-repeat;
            background-size: cover;
            width: 100%;
            height: 100%;
            position: absolute;
        }

        {%- assign mobile_bg_url = '' -%}
        {%- if section.settings.mobile_image != blank -%}
            {%- assign mobile_bg_url = section.settings.mobile_image | image_url: width: 1600 -%}
        {%- else -%}
            {%- assign mobile_bg_url = 'Stephanie-Hero.png' | asset_url -%}
        {%- endif -%}
        @media screen and (max-width: 768px) {
            .homepage-content--{{ section.id }} .homepage-content,
            .homepage-content--{{ section.id }} .section-background,
            .homepage-content--{{ section.id }} .plyr--video,
            .homepage-content--{{ section.id }} iframe {
                background-image: url('{{ mobile_bg_url }}') !important;
                background-size: cover !important;
                background-position: center center !important;
                background-repeat: no-repeat !important;
                background-color: {{ section.settings.mobile_image_bg | default: '#570522' }} !important;
            }
            .homepage-content--{{ section.id }} iframe {
                opacity: 0 !important;
            }
            .homepage-content--{{ section.id }} {
                width: 100% !important;
            }
        }
	</style>
{% endif %}

<style>
    .homepage-content--{{ section.id }} .hero-video--text {
        color: {{ section.settings.textColor }};
    }

	.hero-video--text h3.type-subheading {
      font-size: {{ section.settings.subheading--text-size }}px;
      line-height: normal;
    }
</style>

