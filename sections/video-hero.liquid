{%- comment -%}
  Full-width video hero. Three sources, in priority order:
  1. Self-hosted MP4 (`video_filename`) → renders <video> tag, autoplay/muted/loop/playsinline.
     Best for mobile + desktop. No third-party tracking.
  2. Facebook video URL (`video_url`) → renders FB plugin iframe.
     Heavy on mobile; FB autoplay is unreliable. Use only if MP4 unavailable.
  3. Neither set → renders a styled placeholder block.
{%- endcomment -%}

{%- liquid
  assign video_filename = section.settings.video_filename
  assign video_url = section.settings.video_url
  assign poster_filename = section.settings.poster_filename
  assign fb_href = video_url | url_encode
-%}

<section class="video-hero video-hero--{{ section.id }}{% if section.settings.hide_on_mobile %} video-hero--desktop-only{% endif %}">
  <div class="video-hero__frame">
    {% if video_filename != blank %}
      <video
        class="video-hero__video"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        {% if poster_filename != blank %}poster="{{ poster_filename | asset_url }}"{% endif %}
      >
        <source src="{{ video_filename | asset_url }}" type="video/mp4">
      </video>
    {% elsif video_url != blank %}
      <iframe
        src="https://www.facebook.com/plugins/video.php?href={{ fb_href }}&show_text=false&autoplay=1&mute=1&loop=1"
        scrolling="no"
        frameborder="0"
        allowfullscreen="true"
        allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"
        loading="lazy"
      ></iframe>
    {% else %}
      <div class="video-hero__placeholder">
        <div class="video-hero__placeholder-icon" aria-hidden="true">▶</div>
        <p class="video-hero__placeholder-label">{{ section.settings.placeholder_label | default: 'Video coming soon' | escape }}</p>
        {% if section.settings.placeholder_caption != blank %}
          <p class="video-hero__placeholder-caption">{{ section.settings.placeholder_caption | escape }}</p>
        {% endif %}
      </div>
    {% endif %}
  </div>
</section>

<style>
  .video-hero--{{ section.id }} {
    background: {{ section.settings.background_color | default: '#000000' }};
    width: 100%;
    overflow: hidden;
  }
  .video-hero--{{ section.id }} .video-hero__frame {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    max-height: {{ section.settings.max_height | default: 70 }}vh;
  }
  .video-hero--{{ section.id }} iframe,
  .video-hero--{{ section.id }} .video-hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
    object-fit: cover;
  }
  .video-hero--{{ section.id }} .video-hero__placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 14px;
    color: #f7ead6;
    background: linear-gradient(135deg, #3a1612 0%, #570522 60%, #2e1208 100%);
    text-align: center;
    padding: 24px;
  }
  .video-hero--{{ section.id }} .video-hero__placeholder-icon {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    border: 3px solid rgba(247, 234, 214, 0.85);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 32px;
    padding-left: 6px;
    opacity: 0.85;
  }
  .video-hero--{{ section.id }} .video-hero__placeholder-label {
    font-size: clamp(18px, 2.4vw, 22px);
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0;
  }
  .video-hero--{{ section.id }} .video-hero__placeholder-caption {
    font-size: clamp(14px, 1.6vw, 16px);
    margin: 0;
    opacity: 0.85;
    max-width: 480px;
  }
  @media (max-width: 767px) {
    .video-hero--{{ section.id }}.video-hero--desktop-only {
      display: none;
    }
  }
</style>

{% schema %}
{
  "name": "Video hero",
  "settings": [
    {
      "type": "text",
      "id": "video_filename",
      "label": "Self-hosted MP4 filename (preferred)",
      "info": "Asset filename, e.g. unboxing-cake.mp4. Plays inline on mobile + desktop, autoplay muted loop. Takes priority over Facebook URL."
    },
    {
      "type": "text",
      "id": "poster_filename",
      "label": "Poster image filename (optional)",
      "info": "Asset filename shown before the video plays, e.g. unboxing-poster.jpg"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Facebook video URL (fallback)",
      "info": "Used only if no MP4 filename is set. Heavy on mobile."
    },
    {
      "type": "checkbox",
      "id": "hide_on_mobile",
      "label": "Hide on mobile (recommended)",
      "default": true
    },
    {
      "type": "range",
      "id": "max_height",
      "label": "Max height (% of viewport)",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 70
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Placeholder (when no video URL is set)"
    },
    {
      "type": "text",
      "id": "placeholder_label",
      "label": "Placeholder label",
      "default": "Video coming soon"
    },
    {
      "type": "text",
      "id": "placeholder_caption",
      "label": "Placeholder caption (optional)"
    }
  ],
  "presets": [
    { "name": "Video hero", "category": "Storytelling" }
  ]
}
{% endschema %}
