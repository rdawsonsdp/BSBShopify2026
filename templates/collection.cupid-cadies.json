    "advanced_layout_custom_html_wt3YC3": {
      "type": "advanced-layout--custom-html",
      "blocks": {
        "html_dnwLPM": {
          "type": "html",
          "settings": {
            "code": "<meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Sweet Chicago Legacy - Cupid Candies &amp; Brown Sugar Bakery</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&amp;display=swap\" rel=\"stylesheet\">\n  <style>\n    :root {\n      --cream: #fffaf2;\n      --brown-dark: #4A2C2A;\n      --brown-text: #2C1810;\n      --caramel: #D4A574;\n      --rose: #E8B4B8;\n    }\n\n    * {\n      box-sizing: border-box;\n      margin: 0;\n      padding: 0;\n    }\n\n    body {\n      font-family: 'Playfair Display', Georgia, serif;\n      background-color: var(--cream);\n      color: var(--brown-text);\n      line-height: 1.6;\n    }\n\n    /* Navigation */\n    .legacy-nav {\n      position: sticky;\n      top: 0;\n      background: var(--brown-dark);\n      padding: 15px 40px;\n      z-index: 100;\n      display: flex;\n      justify-content: center;\n      flex-wrap: wrap;\n      gap: 10px 30px;\n    }\n\n    .legacy-nav a {\n      color: var(--caramel);\n      text-decoration: none;\n      font-size: 14px;\n      font-weight: 600;\n      letter-spacing: 1px;\n      transition: color 0.3s ease;\n    }\n\n    .legacy-nav a:hover {\n      color: var(--cream);\n    }\n\n    /* Section Styles */\n    .legacy-section {\n      padding: 80px 60px;\n      max-width: 1400px;\n      margin: 0 auto;\n    }\n\n    .section-title {\n      color: var(--brown-dark);\n      font-size: 42px;\n      font-weight: 700;\n      margin-bottom: 15px;\n    }\n\n    .section-divider {\n      width: 100px;\n      height: 4px;\n      background: var(--caramel);\n      margin-bottom: 40px;\n    }\n\n    .section-divider.centered {\n      margin-left: auto;\n      margin-right: auto;\n    }\n\n    /* Hero Section */\n    .legacy-hero {\n      min-height: 90vh;\n      display: flex;\n      align-items: center;\n      background: var(--cream);\n    }\n\n    .hero-content {\n      display: grid;\n      grid-template-columns: 1fr 1fr;\n      gap: 60px;\n      width: 100%;\n      max-width: 1400px;\n      margin: 0 auto;\n      padding: 40px 60px;\n    }\n\n    .hero-image {\n      background: linear-gradient(135deg, var(--rose) 0%, var(--caramel) 100%);\n      padding: 40px;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      border-radius: 8px;\n    }\n\n    .hero-image img {\n      max-height: 500px;\n      max-width: 100%;\n      object-fit: contain;\n    }\n\n    .hero-text {\n      display: flex;\n      flex-direction: column;\n      justify-content: center;\n    }\n\n    .hero-subtitle {\n      color: var(--caramel);\n      font-size: 20px;\n      font-weight: 600;\n      letter-spacing: 3px;\n      margin-bottom: 20px;\n    }\n\n    .hero-title {\n      color: var(--brown-dark);\n      font-size: 56px;\n      font-weight: 700;\n      line-height: 1.1;\n      margin-bottom: 30px;\n    }\n\n    .hero-description {\n      font-size: 24px;\n      line-height: 1.5;\n      margin-bottom: 30px;\n    }\n\n    .hero-tagline {\n      color: var(--caramel);\n      font-size: 18px;\n      font-weight: 600;\n    }\n\n    /* Grid Layouts */\n    .two-column {\n      display: grid;\n      grid-template-columns: 1fr 1fr;\n      gap: 50px;\n    }\n\n    .three-column {\n      display: grid;\n      grid-template-columns: repeat(3, 1fr);\n      gap: 30px;\n    }\n\n    .sidebar-left {\n      display: grid;\n      grid-template-columns: 2fr 3fr;\n      gap: 50px;\n    }\n\n    .sidebar-right {\n      display: grid;\n      grid-template-columns: 3fr 2fr;\n      gap: 50px;\n    }\n\n    /* Card Styles */\n    .gradient-card {\n      background: linear-gradient(135deg, var(--rose) 0%, var(--caramel) 100%);\n      padding: 35px;\n      border-radius: 8px;\n    }\n\n    .caramel-card {\n      background: var(--caramel);\n      padding: 35px;\n      border-radius: 8px;\n    }\n\n    .dark-card {\n      background: var(--brown-dark);\n      padding: 35px;\n      border-radius: 8px;\n      color: var(--cream);\n    }\n\n    .dark-card .card-title {\n      color: var(--caramel);\n    }\n\n    .card-title {\n      color: var(--brown-dark);\n      font-size: 24px;\n      font-weight: 700;\n      margin-bottom: 15px;\n    }\n\n    .card-subtitle {\n      font-size: 16px;\n      font-weight: 600;\n      margin-bottom: 15px;\n    }\n\n    /* Timeline */\n    .timeline {\n      border-left: 4px solid var(--caramel);\n      padding-left: 40px;\n      margin-left: 20px;\n    }\n\n    .timeline-item {\n      position: relative;\n      margin-bottom: 40px;\n    }\n\n    .timeline-item::before {\n      content: '';\n      position: absolute;\n      left: -48px;\n      width: 20px;\n      height: 20px;\n      background: var(--caramel);\n      border: 4px solid var(--cream);\n    }\n\n    .timeline-year {\n      color: var(--caramel);\n      font-size: 28px;\n      font-weight: 700;\n      margin-bottom: 8px;\n    }\n\n    .timeline-title {\n      color: var(--brown-dark);\n      font-size: 18px;\n      font-weight: 600;\n    }\n\n    /* Feature List */\n    .feature-list {\n      list-style: none;\n      padding: 0;\n      margin: 0;\n    }\n\n    .feature-list li {\n      margin-bottom: 12px;\n      padding-left: 20px;\n      position: relative;\n    }\n\n    .feature-list li::before {\n      content: '\u2022';\n      color: var(--caramel);\n      font-weight: bold;\n      position: absolute;\n      left: 0;\n    }\n\n    /* Testimonial Cards */\n    .testimonial-card {\n      padding: 30px;\n      min-height: 260px;\n    }\n\n    .testimonial-name {\n      color: var(--brown-dark);\n      font-size: 20px;\n      font-weight: 700;\n      margin-bottom: 5px;\n    }\n\n    .testimonial-years {\n      font-size: 16px;\n      font-weight: 600;\n      margin-bottom: 15px;\n    }\n\n    .testimonial-quote {\n      font-style: italic;\n      font-size: 16px;\n      line-height: 1.6;\n    }\n\n    /* Image Styles */\n    .legacy-image {\n      width: 100%;\n      height: auto;\n      object-fit: contain;\n      border-radius: 4px;\n    }\n\n    .image-caption {\n      text-align: center;\n      font-style: italic;\n      margin-top: 15px;\n      color: var(--brown-dark);\n      font-size: 15px;\n    }\n\n    /* Placeholder Images */\n    .image-placeholder {\n      background: linear-gradient(135deg, #ddd 0%, #bbb 100%);\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      color: #666;\n      font-size: 14px;\n      text-align: center;\n      border-radius: 4px;\n      border: 2px dashed #999;\n    }\n\n    .image-placeholder.hero-placeholder {\n      width: 100%;\n      height: 400px;\n    }\n\n    .image-placeholder.standard {\n      width: 100%;\n      height: 300px;\n    }\n\n    .image-placeholder.postcard {\n      width: 100%;\n      height: 200px;\n    }\n\n    /* Highlight Box */\n    .highlight-box {\n      background: linear-gradient(90deg, var(--rose) 0%, var(--caramel) 100%);\n      padding: 30px;\n      border-radius: 8px;\n      margin-top: 30px;\n    }\n\n    .highlight-box p {\n      font-weight: 600;\n      font-size: 18px;\n      margin: 0;\n    }\n\n    /* Banner */\n    .banner {\n      background: var(--brown-dark);\n      padding: 40px;\n      text-align: center;\n      margin-top: 40px;\n    }\n\n    .banner p {\n      color: var(--caramel);\n      font-size: 26px;\n      font-weight: 700;\n      margin: 0;\n    }\n\n    /* CTA Button */\n    .cta-button {\n      display: inline-block;\n      background: var(--brown-dark);\n      color: var(--caramel);\n      padding: 18px 40px;\n      font-size: 18px;\n      font-weight: 600;\n      text-decoration: none;\n      border-radius: 4px;\n      transition: all 0.3s ease;\n      margin-top: 30px;\n    }\n\n    .cta-button:hover {\n      background: var(--caramel);\n      color: var(--brown-dark);\n    }\n\n    /* Postcard Grid */\n    .postcard-grid {\n      display: grid;\n      grid-template-columns: repeat(2, 1fr);\n      gap: 30px;\n    }\n\n    .postcard-item {\n      background: var(--cream);\n      border: 2px solid var(--caramel);\n      padding: 20px;\n      border-radius: 8px;\n      text-align: center;\n    }\n\n    .postcard-item img {\n      max-height: 200px;\n      object-fit: contain;\n    }\n\n    /* Milestone */\n    .milestone {\n      text-align: center;\n      margin-bottom: 50px;\n    }\n\n    .milestone-year {\n      color: var(--caramel);\n      font-size: 48px;\n      font-weight: 700;\n      margin-bottom: 12px;\n    }\n\n    .milestone-title {\n      color: var(--brown-dark);\n      font-size: 28px;\n      font-weight: 600;\n      margin-bottom: 20px;\n    }\n\n    .milestone-description {\n      font-size: 20px;\n      max-width: 900px;\n      margin: 0 auto;\n    }\n\n    /* Responsive */\n    @media (max-width: 1024px) {\n      .hero-content,\n      .two-column,\n      .sidebar-left,\n      .sidebar-right {\n        grid-template-columns: 1fr;\n      }\n\n      .three-column {\n        grid-template-columns: 1fr;\n      }\n\n      .legacy-section {\n        padding: 60px 30px;\n      }\n\n      .hero-title {\n        font-size: 40px;\n      }\n\n      .section-title {\n        font-size: 32px;\n      }\n    }\n\n    @media (max-width: 768px) {\n      .legacy-nav {\n        padding: 15px 20px;\n        gap: 8px 20px;\n      }\n\n      .legacy-nav a {\n        font-size: 12px;\n      }\n\n      .postcard-grid {\n        grid-template-columns: 1fr;\n      }\n    }\n  </style>\n\n\n\n  <!-- Navigation -->\n  <nav class=\"legacy-nav\">\n    <a href=\"#home\">Home</a>\n    <a href=\"#history\">Cupid History</a>\n    <a href=\"#dove-bar\">Dove Bar</a>\n    <a href=\"#transformation\">Brown Sugar Bakery</a>\n    <a href=\"#employees\">Our People</a>\n    <a href=\"#postcards\">Chicago Postcards</a>\n  </nav>\n\n  <!-- Hero Section -->\n  <section id=\"home\" class=\"legacy-hero\">\n    <div class=\"hero-content\">\n      <div class=\"hero-image\">\n        <!-- PLACEHOLDER: BSB-Postcard-Box-Main.png -->\n        <div class=\"image-placeholder hero-placeholder\">\n          <span>IMAGE: BSB-Postcard-Box-Main.png<br>(Chicago Postcard Collection Box)</span>\n        </div>\n      </div>\n      <div class=\"hero-text\">\n        <div class=\"hero-subtitle\">A TALE OF TWO SWEETHEARTS</div>\n        <h1 class=\"hero-title\">Sweet Chicago Legacy</h1>\n        <div class=\"section-divider\"></div>\n        <p class=\"hero-description\">\n          The Digital Story of<br>\n          <strong>Cupid Candies</strong> &amp;<br>\n          <strong>Brown Sugar Bakery</strong>\n        </p>\n        <div class=\"hero-tagline\">88 Years of Heritage \u2022 Innovation \u2022 Community</div>\n        <a href=\"/collections/nationwide-shipping-candies\" class=\"cta-button\">Shop Our Chocolates</a>\n      </div>\n    </div>\n  </section>\n\n  <!-- Mission Section -->\n  <section class=\"legacy-section\">\n    <h2 class=\"section-title\">Bridging 88 Years of Chicago Candy Heritage</h2>\n    <div class=\"section-divider\"></div>\n    \n    <div class=\"sidebar-left\">\n      <div class=\"gradient-card\" style=\"min-height: 400px; display: flex; flex-direction: column; justify-content: center;\">\n        <div style=\"color: var(--brown-dark); font-size: 18px; font-weight: 600; letter-spacing: 2px; margin-bottom: 20px;\">MISSION</div>\n        <p style=\"font-size: 20px; font-weight: 600; line-height: 1.6;\">\n          A comprehensive digital platform that honors the rich history of Cupid Candies (est. 1936) and celebrates Brown Sugar Bakery's innovative acquisition in 2020\n        </p>\n      </div>\n      \n      <div>\n        <div style=\"color: var(--brown-dark); font-size: 18px; font-weight: 600; letter-spacing: 2px; margin-bottom: 25px;\">KEY OBJECTIVES</div>\n        \n        <div style=\"margin-bottom: 20px;\">\n          <div style=\"color: var(--caramel); font-size: 17px; font-weight: 600; margin-bottom: 8px;\">\u2022 Tell the Complete Story</div>\n          <p style=\"margin-left: 20px;\">Document both iconic Chicago institutions and their intertwined histories</p>\n        </div>\n        \n        <div style=\"margin-bottom: 20px;\">\n          <div style=\"color: var(--caramel); font-size: 17px; font-weight: 600; margin-bottom: 8px;\">\u2022 Showcase the Passing of the Torch</div>\n          <p style=\"margin-left: 20px;\">Highlight the 2020 acquisition from Greek immigrant founders to Black woman entrepreneur</p>\n        </div>\n        \n        <div style=\"margin-bottom: 20px;\">\n          <div style=\"color: var(--caramel); font-size: 17px; font-weight: 600; margin-bottom: 8px;\">\u2022 Feature the Dove Bar Origin</div>\n          <p style=\"margin-left: 20px;\">Document how this iconic treat was manufactured at the Cupid factory</p>\n        </div>\n        \n        <div style=\"margin-bottom: 20px;\">\n          <div style=\"color: var(--caramel); font-size: 17px; font-weight: 600; margin-bottom: 8px;\">\u2022 Celebrate Employee Loyalty</div>\n          <p style=\"margin-left: 20px;\">Honor craftspeople with 30+ years of service and their dedication to quality</p>\n        </div>\n        \n        <div style=\"margin-bottom: 20px;\">\n          <div style=\"color: var(--caramel); font-size: 17px; font-weight: 600; margin-bottom: 8px;\">\u2022 Present the Chicago Postcard Series</div>\n          <p style=\"margin-left: 20px;\">Showcase 14 beautifully designed boxes celebrating iconic Chicago landmarks</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Historical Foundation Section -->\n  <section id=\"history\" class=\"legacy-section\" style=\"background: linear-gradient(180deg, var(--cream) 0%, rgba(232, 180, 184, 0.2) 100%);\">\n    <h2 class=\"section-title\">Chicago as Candy Capital: The Early Years</h2>\n    <div class=\"section-divider\"></div>\n    \n    <div class=\"sidebar-right\">\n      <div>\n        <div style=\"margin-bottom: 45px;\">\n          <div class=\"timeline-year\">Early 1900s</div>\n          <div class=\"timeline-title\">Greek Immigrant Legacy</div>\n          <p>Chicago was home to over 1,000 candy companies, many founded by Greek immigrants seeking the American Dream</p>\n        </div>\n        \n        <div style=\"margin-bottom: 45px;\">\n          <div class=\"timeline-year\">1936</div>\n          <div class=\"timeline-title\">Paul Stefanos' Vision</div>\n          <p>Founded Cupid Candies on Chicago's South Side at 79th and Ashland, starting with only fudge, toffee, and popcorn</p>\n        </div>\n        \n        <div style=\"margin-bottom: 45px;\">\n          <div class=\"timeline-year\">1940</div>\n          <div class=\"timeline-title\">Innovation Milestone</div>\n          <p>Paul Stefanos created the famous 3-layer meltaway candy, which became the most featured candy at Marshall Field's department store during holidays</p>\n        </div>\n        \n        <div class=\"highlight-box\">\n          <p>These early innovations established Cupid Candies as a cornerstone of Chicago's candy-making tradition</p>\n        </div>\n      </div>\n      \n      <div style=\"display: flex; flex-direction: column; justify-content: center; align-items: center;\">\n        <!-- PLACEHOLDER: meltaways.png -->\n        <div class=\"image-placeholder standard\">\n          <span>IMAGE: meltaways.png<br>(3-Layer Meltaway Candy)</span>\n        </div>\n        <p class=\"image-caption\">The legendary 3-layer meltaway candy created in 1940</p>\n      </div>\n    </div>\n  </section>\n\n  <!-- Growth and Legacy Section -->\n  <section class=\"legacy-section\">\n    <h2 class=\"section-title\" style=\"text-align: center;\">Growth and Legacy: 1956-2020</h2>\n    <div class=\"section-divider centered\"></div>\n    \n    <div class=\"milestone\">\n      <div class=\"milestone-year\">1956</div>\n      <div class=\"milestone-title\">Manufacturing Expansion</div>\n      <p class=\"milestone-description\">\n        Opened the Western Avenue factory, which <strong>remains operational today</strong> and became the manufacturing site for the legendary Dove Bar\n      </p>\n    </div>\n    \n    <div style=\"width: 200px; height: 2px; background: var(--caramel); margin: 50px auto;\"></div>\n    \n    <div class=\"milestone\">\n      <div class=\"milestone-year\">1936 - 2020</div>\n      <div class=\"milestone-title\">84-Year Family Legacy</div>\n      <div class=\"highlight-box\" style=\"max-width: 900px; margin: 0 auto;\">\n        <p style=\"text-align: center; font-size: 20px;\">\n          Remained family-owned and operated until 2020, representing authentic Chicago candy-making tradition\n        </p>\n      </div>\n    </div>\n  </section>\n\n  <!-- Dove Bar Section -->\n  <section id=\"dove-bar\" class=\"legacy-section\" style=\"background: linear-gradient(180deg, rgba(212, 165, 116, 0.1) 0%, var(--cream) 100%);\">\n    <h2 class=\"section-title\">The Dove Bar: A Chicago Icon Born at Cupid</h2>\n    <div class=\"section-divider\"></div>\n    \n    <div class=\"sidebar-left\" style=\"grid-template-columns: 1fr 2fr;\">\n      <!-- Timeline -->\n      <div class=\"timeline\">\n        <div class=\"timeline-item\">\n          <div class=\"timeline-year\">1956</div>\n          <div class=\"timeline-title\">Invention</div>\n        </div>\n        <div class=\"timeline-item\">\n          <div class=\"timeline-year\">1956-1984</div>\n          <div class=\"timeline-title\">Local Secret</div>\n        </div>\n        <div class=\"timeline-item\">\n          <div class=\"timeline-year\">1984</div>\n          <div class=\"timeline-title\">National Launch</div>\n        </div>\n        <div class=\"timeline-item\">\n          <div class=\"timeline-year\">1986</div>\n          <div class=\"timeline-title\">Mars Acquisition</div>\n        </div>\n      </div>\n      \n      <!-- Narrative -->\n      <div>\n        <div style=\"margin-bottom: 35px;\">\n          <h3 class=\"card-title\">The Creator</h3>\n          <p><strong style=\"color: var(--caramel);\">Leo Stefanos</strong> (Paul's brother) invented the Dove Bar in 1956 at his shop, Dove Candies &amp; Ice Cream, located at 60th and Pulaski. Inspired by watching his son chase an ice cream truck, Leo created a hand-dipped high-quality vanilla ice cream bar covered in rich, dark chocolate.</p>\n        </div>\n        \n        <div style=\"margin-bottom: 35px;\">\n          <h3 class=\"card-title\">Manufacturing at Cupid</h3>\n          <p>The Dove Bar was <strong style=\"color: var(--caramel);\">manufactured at the Cupid Candies factory</strong> on Western Avenue, bringing together the expertise of both Stefanos brothers. This connection between the two family businesses ensured the highest quality chocolate coating for each bar.</p>\n        </div>\n        \n        <div style=\"margin-bottom: 35px;\">\n          <h3 class=\"card-title\">From Local to National</h3>\n          <p>For nearly three decades, the Dove Bar remained a cherished local secret enjoyed by South Side Chicagoans. In 1984, it became a nationwide sensation, introducing America to the premium ice cream bar experience.</p>\n        </div>\n        \n        <div class=\"highlight-box\">\n          <h3 class=\"card-title\" style=\"margin-bottom: 10px;\">Chicago's Culinary Export</h3>\n          <p style=\"margin: 0;\">Acquired by Mars, Inc. in 1986, the Dove Bar remains one of Chicago's most famous culinary exports, forever linking the Stefanos family name to an American icon.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- 2020 Transformation Section -->\n  <section id=\"transformation\" class=\"legacy-section\">\n    <h2 class=\"section-title\">The 2020 Transformation</h2>\n    <div class=\"section-divider\"></div>\n    \n    <div class=\"two-column\">\n      <!-- Photo -->\n      <div class=\"gradient-card\" style=\"padding: 30px;\">\n        <!-- PLACEHOLDER: john_stephanie_legacy.png -->\n        <div class=\"image-placeholder standard\">\n          <span>IMAGE: john_stephanie_legacy.png<br>(Three Generations Legacy Photo)</span>\n        </div>\n        <p class=\"image-caption\" style=\"color: var(--brown-text);\">\n          Three generations united: Stephanie Hart with John Stefanos, beneath the watchful portrait of founder Paul Stefanos\n        </p>\n      </div>\n      \n      <!-- Content -->\n      <div>\n        <div style=\"margin-bottom: 28px;\">\n          <h3 style=\"color: var(--caramel); font-size: 20px; font-weight: 700; margin-bottom: 10px;\">Stephanie Hart's Background</h3>\n          <p>After a 20-year career in tech, founded Brown Sugar Bakery in 2002, creating an iconic Black woman-owned institution on Chicago's South Side</p>\n        </div>\n        \n        <div style=\"margin-bottom: 28px;\">\n          <h3 style=\"color: var(--caramel); font-size: 20px; font-weight: 700; margin-bottom: 10px;\">Historic Acquisition</h3>\n          <p>In 2020, with a $500,000 grant from the state of Illinois, Hart purchased the 84-year-old Cupid Candies factory and name</p>\n        </div>\n        \n        <div style=\"margin-bottom: 28px;\">\n          <h3 style=\"color: var(--caramel); font-size: 20px; font-weight: 700; margin-bottom: 10px;\">Passing of the Torch</h3>\n          <p>John Stefanos passed away September 26, 2020, the night before the Oak Lawn store closed, knowing his legacy would continue</p>\n        </div>\n        \n        <div style=\"margin-bottom: 28px;\">\n          <h3 style=\"color: var(--caramel); font-size: 20px; font-weight: 700; margin-bottom: 10px;\">Continuity of Excellence</h3>\n          <p>Hart retained the factory's dedicated staff, including many with over 30 years of service, ensuring preservation of traditional chocolate-making expertise</p>\n        </div>\n        \n        <div class=\"highlight-box\">\n          <p style=\"margin: 0;\">Hart became the only Black woman-owned chocolate manufacturer in America, bridging Greek immigrant heritage with modern entrepreneurship</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Valentine Gelata Section -->\n  <section class=\"legacy-section\" style=\"background: rgba(232, 180, 184, 0.15);\">\n    <h2 class=\"section-title\">Master of Transition</h2>\n    <div class=\"section-divider\"></div>\n    \n    <div class=\"sidebar-left\">\n      <div>\n        <!-- PLACEHOLDER: valentine_gelata.png -->\n        <div class=\"image-placeholder standard\">\n          <span>IMAGE: valentine_gelata.png<br>(Valentine Gelata at Factory)</span>\n        </div>\n        <p class=\"image-caption\">Valentine Gelata at the Cupid Candies factory</p>\n      </div>\n      \n      <div>\n        <div style=\"margin-bottom: 25px;\">\n          <div style=\"color: var(--caramel); font-size: 18px; font-weight: 600; margin-bottom: 8px;\">\n            Student of John Stefanos \u2022 Expert in Confections\n          </div>\n          <p>Valentine Gelata played a crucial role in bridging the old and new eras, bringing decades of expertise to the transition</p>\n        </div>\n        \n        <div class=\"highlight-box\" style=\"margin-bottom: 25px; margin-top: 0;\">\n          <p style=\"font-style: italic; margin: 0; font-weight: 400;\">\n            \"With the creative help of Stephanie Hart and Susan Oleary, we were able to go from an idea to develop a line of Chocolates to Products on the shelf at Nordstrom Michigan Ave. Chicago in less than 30 days!!!!\"\n          </p>\n        </div>\n        \n        <div style=\"margin-bottom: 20px;\">\n          <h3 class=\"card-title\">The Chicago Chocolate Philosophy</h3>\n          <p>\"Our employees did not graduate from Le Cordon Bleu. We do not create shiny, hard perfectly tempered European chocolate on purpose, rather, we rely on the traditions of <strong>Chicago based American Chocolate\u2014soft, perfectly set, silky smooth</strong> with a flavor that takes you back to simpler times.\"</p>\n        </div>\n        \n        <p>\"Our standards are high and our process is built on <strong>formulas and traditions that date back decades</strong>. Many of our employee/creators have been loyal to us for over 30 years and we are also training new creators.\"</p>\n        \n        <div class=\"banner\" style=\"margin-top: 25px; border-radius: 8px;\">\n          <p style=\"font-size: 22px;\">\"The Cupid Candies Factory is BACK!!!\"</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- Employee Loyalty Section -->\n  <section id=\"employees\" class=\"legacy-section\">\n    <h2 class=\"section-title\">The Heart of Cupid's Quality</h2>\n    <div class=\"section-divider\"></div>\n    \n    <div class=\"three-column\" style=\"margin-bottom: 40px;\">\n      <!-- Hazel Harris -->\n      <div class=\"gradient-card testimonial-card\">\n        <div class=\"testimonial-name\">Hazel Harris</div>\n        <div class=\"testimonial-years\">31 Years of Service</div>\n        <p class=\"testimonial-quote\">\"I run a little bit of everything around here. It's pretty fun to have chocolate every day so that's a good thing in life.\"</p>\n      </div>\n      \n      <!-- Guadalupe Barranco -->\n      <div class=\"caramel-card testimonial-card\">\n        <div class=\"testimonial-name\">Guadalupe Barranco</div>\n        <div class=\"testimonial-years\">26 Years of Service</div>\n        <p class=\"testimonial-quote\">\"A long time ago, John taught me everything I know here.\"</p>\n        <p style=\"margin-top: 12px; font-size: 15px;\">Originally from Mexico City, personally trained by John Stefanos</p>\n      </div>\n      \n      <!-- Monica Biliskov -->\n      <div class=\"gradient-card testimonial-card\" style=\"background: linear-gradient(135deg, var(--caramel) 0%, var(--rose) 100%);\">\n        <div class=\"testimonial-name\">Monica Biliskov</div>\n        <div class=\"testimonial-years\">29 Years of Service</div>\n        <p class=\"testimonial-quote\">\"They're good people to work for. It's nice to work for a family business.\"</p>\n      </div>\n    </div>\n    \n    <!-- Cultural Heritage -->\n    <div class=\"dark-card\">\n      <h3 class=\"card-title\">Cultural Heritage &amp; Master Craftsmanship</h3>\n      <div class=\"two-column\">\n        <p style=\"color: var(--cream);\">Mexican immigrant workers carrying on the tradition established by Greek immigrant founders, showcasing Chicago's rich immigrant candy-making legacy that spans generations.</p>\n        <p style=\"color: var(--cream);\">These employees are guardians of secret recipes and traditional techniques that cannot be replicated by machines, ensuring every chocolate maintains exceptional quality.</p>\n      </div>\n    </div>\n  </section>\n\n  <!-- Chicago Postcard Series Section -->\n  <section id=\"postcards\" class=\"legacy-section\" style=\"background: linear-gradient(180deg, var(--cream) 0%, rgba(232, 180, 184, 0.2) 100%);\">\n    <h2 class=\"section-title\">Love Letter to the City</h2>\n    <div class=\"section-divider\"></div>\n    \n    <div class=\"postcard-grid\" style=\"margin-bottom: 50px;\">\n      <div class=\"postcard-item\">\n        <!-- PLACEHOLDER: BSB-Postcard-art-institute.png -->\n        <div class=\"image-placeholder postcard\">\n          <span>IMAGE: BSB-Postcard-art-institute.png<br>(Art Institute Postcard Box)</span>\n        </div>\n      </div>\n      <div class=\"postcard-item\">\n        <!-- PLACEHOLDER: BSB-Train-Car.png -->\n        <div class=\"image-placeholder postcard\">\n          <span>IMAGE: BSB-Train-Car.png<br>(Chicago L Train Postcard Box)</span>\n        </div>\n      </div>\n    </div>\n    \n    <div class=\"two-column\">\n      <div>\n        <div style=\"margin-bottom: 30px;\">\n          <h3 style=\"color: var(--caramel); font-size: 20px; font-weight: 700; margin-bottom: 10px;\">The Concept</h3>\n          <p style=\"font-style: italic;\">\"Chicago is more than a city\u2014it's a feeling, a collection of moments that take your breath away\"</p>\n        </div>\n        \n        <div style=\"margin-bottom: 30px;\">\n          <h3 style=\"color: var(--caramel); font-size: 20px; font-weight: 700; margin-bottom: 10px;\">Design Philosophy</h3>\n          <p>Each box features stunning vintage-style illustrations of Chicago's most treasured locations, making them keepsakes beyond just packaging</p>\n        </div>\n        \n        <div>\n          <h3 style=\"color: var(--caramel); font-size: 20px; font-weight: 700; margin-bottom: 10px;\">Product Integration</h3>\n          <p>Inside each postcard box are signature handmade chocolates crafted at the historic Cupid Candies factory using traditional methods</p>\n        </div>\n      </div>\n      \n      <div class=\"gradient-card\" style=\"display: flex; flex-direction: column; justify-content: center; min-height: 300px;\">\n        <h3 class=\"card-title\" style=\"text-align: center; margin-bottom: 20px;\">A Collection of Chicago Icons</h3>\n        <p style=\"text-align: center; font-size: 18px; line-height: 1.7;\">From the Art Institute's iconic lions to the beloved L Train, from Buckingham Fountain's summer spray to the Zoo's winter lights\u2014each design celebrates a cherished Chicago landmark</p>\n        <p style=\"text-align: center; font-size: 20px; font-weight: 600; margin-top: 30px; color: var(--brown-dark);\">14 unique designs capturing the spirit of Chicago</p>\n      </div>\n    </div>\n    \n    <!-- Designs List -->\n    <div class=\"gradient-card\" style=\"max-width: 800px; margin: 50px auto 0; text-align: center;\">\n      <h3 class=\"card-title\">Chicago Postcard Collection</h3>\n      <p style=\"font-size: 18px; line-height: 2;\">\n        Art Institute Lions \u2022 Cloud Gate (The Bean) \u2022 Buckingham Fountain (summer &amp; winter) \u2022 Magnificent Mile \u2022 Lakefront Skyline (2 variations) \u2022 Historic Bridges \u2022 Lincoln Park Zoo (summer &amp; winter) \u2022 Museum Campus \u2022 Chicago Flag \u2022 The Chicago L Train\n      </p>\n    </div>\n    \n    <div class=\"dark-card\" style=\"max-width: 900px; margin: 40px auto 0; text-align: center;\">\n      <h3 class=\"card-title\">Perfect for Every Occasion</h3>\n      <p style=\"font-size: 18px; color: var(--cream);\">Perfect for sending to those who miss home, welcoming visitors, or celebrating Chicago pride with authentic handmade chocolates</p>\n    </div>\n  </section>\n\n  <!-- Impact Section -->\n  <section class=\"legacy-section\">\n    <h2 class=\"section-title\">Celebrating Chicago's Candy Legacy</h2>\n    <div class=\"section-divider\"></div>\n    \n    <div class=\"three-column\" style=\"margin-bottom: 40px;\">\n      <div class=\"gradient-card\" style=\"background: linear-gradient(180deg, var(--rose) 0%, var(--caramel) 100%);\">\n        <h3 class=\"card-title\">Story Preservation</h3>\n        <p><strong>88 Years Documented</strong></p>\n        <p>Complete timeline from 1936 founding through 2020 acquisition</p>\n        <p>Employee testimonials spanning 30+ years</p>\n        <p>Three generations preserved in photos and stories</p>\n      </div>\n      \n      <div class=\"caramel-card\">\n        <h3 class=\"card-title\">Brand Unification</h3>\n        <p><strong>Two Legacies, One Story</strong></p>\n        <p>Cupid Candies heritage seamlessly integrated with Brown Sugar Bakery vision</p>\n        <p>Chicago Postcard Series bridges tradition and innovation</p>\n      </div>\n      \n      <div class=\"gradient-card\" style=\"background: linear-gradient(180deg, var(--caramel) 0%, var(--rose) 100%);\">\n        <h3 class=\"card-title\">Cultural Significance</h3>\n        <p><strong>Immigrant Entrepreneur Legacy</strong></p>\n        <p>Greek immigrant founders to Black woman-owned manufacturer</p>\n        <p>Chicago as candy capital narrative preserved</p>\n      </div>\n    </div>\n    \n    <div class=\"two-column\">\n      <div class=\"dark-card\">\n        <h3 class=\"card-title\">Educational &amp; Community Value</h3>\n        <ul class=\"feature-list\" style=\"color: var(--cream);\">\n          <li>Authentic employee voices and experiences documented</li>\n          <li>Chicago chocolate-making philosophy explained</li>\n          <li>Historical context connecting past and present</li>\n          <li>Community stories celebrating loyalty and craftsmanship</li>\n        </ul>\n      </div>\n      \n      <div class=\"highlight-box\" style=\"margin-top: 0;\">\n        <h3 class=\"card-title\">Future-Ready Platform</h3>\n        <ul class=\"feature-list\">\n          <li>Comprehensive digital presence for e-commerce growth</li>\n          <li>Mobile-optimized for modern consumers</li>\n          <li>Scalable architecture for product expansion</li>\n          <li>Foundation for continued brand storytelling</li>\n        </ul>\n      </div>\n    </div>\n  </section>\n\n  <!-- Conclusion Section -->\n  <section class=\"legacy-section\" style=\"background: linear-gradient(180deg, rgba(212, 165, 116, 0.1) 0%, var(--cream) 100%);\">\n    <h2 class=\"section-title\" style=\"text-align: center;\">A Sweet Legacy Continues</h2>\n    <div class=\"section-divider centered\"></div>\n    \n    <div class=\"highlight-box\" style=\"max-width: 1000px; margin: 0 auto 50px;\">\n      <h3 class=\"card-title\" style=\"text-align: center; font-size: 26px;\">Mission Accomplished</h3>\n      <p style=\"text-align: center; font-size: 18px; max-width: 900px; margin: 0 auto;\">\n        A comprehensive digital platform that honors 88 years of Chicago candy-making heritage while celebrating the future under Brown Sugar Bakery's stewardship\n      </p>\n    </div>\n    \n    <div class=\"two-column\" style=\"margin-bottom: 50px;\">\n      <div>\n        <h3 style=\"color: var(--caramel); font-size: 24px; font-weight: 700; margin-bottom: 20px;\">Key Achievements</h3>\n        <div style=\"line-height: 2;\">\n          <p><strong>Complete Story:</strong> From 1936 founding through 2020 acquisition</p>\n          <p><strong>Employee Showcase:</strong> Testimonials from 30+ year veterans</p>\n          <p><strong>Product Features:</strong> Meltaways, turtles, Dove Bar history</p>\n          <p><strong>Chicago Celebration:</strong> 14 postcard designs with product photos</p>\n          <p><strong>Visual Journey:</strong> 23-image gallery spanning generations</p>\n          <p><strong>Engaging Experience:</strong> Modern, responsive, accessible design</p>\n        </div>\n      </div>\n      \n      <div>\n        <h3 style=\"color: var(--caramel); font-size: 24px; font-weight: 700; margin-bottom: 20px;\">Legacy Impact</h3>\n        <div style=\"line-height: 2;\">\n          <p><strong>Story Preservation:</strong> Three generations documented for posterity</p>\n          <p><strong>Brand Unification:</strong> Seamless connection between past and present</p>\n          <p><strong>Cultural Significance:</strong> Honoring immigrant entrepreneurship</p>\n          <p><strong>Educational Value:</strong> Chicago candy capital history preserved</p>\n          <p><strong>Community Connection:</strong> Authentic stories of dedicated craftspeople</p>\n          <p><strong>Future-Ready:</strong> Platform for continued growth and storytelling</p>\n        </div>\n      </div>\n    </div>\n    \n    <div class=\"banner\" style=\"border-radius: 8px;\">\n      <p style=\"font-size: 28px; line-height: 1.5;\">From Chicago, with love\u2014and a little brown sugar.</p>\n    </div>\n    \n    <div style=\"text-align: center; margin-top: 50px;\">\n      <a href=\"/collections/nationwide-shipping-candies\" class=\"cta-button\">Order Our Handmade Chocolates</a>\n    </div>\n  </section>\n\n  <script>\n    // Smooth scroll for navigation links\n    document.querySelectorAll('.legacy-nav a[href^=\"#\"]').forEach(anchor => {\n      anchor.addEventListener('click', function (e) {\n        e.preventDefault();\n        const target = document.querySelector(this.getAttribute('href'));\n        if (target) {\n          target.scrollIntoView({\n            behavior: 'smooth',\n            block: 'start'\n          });\n        }\n      });\n    });\n  </script>",
