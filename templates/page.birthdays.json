    "birthday_faq": {
      "type": "faq-accordion",
      "blocks": {
        "q1": {
          "type": "qa",
          "settings": {
            "question": "How far in advance should I order a birthday cake?",
            "answer": "<p>Please order at least 48 hours in advance for pickup at 75th Street. Custom designs may need a little more lead time — give us a call at 773-570-7676 if you're not sure.</p>"
          }
        },
        "q2": {
          "type": "qa",
          "settings": {
            "question": "Can you write a custom message on the cake?",
            "answer": "<p>Yes — and it's free. Every cake on the site has an \"Add cake writing to your order\" option. Tell us the name and we'll pipe it on. Multiple lines, special characters, even simple icons are usually fine — just leave a note at checkout if you want something specific.</p>"
          }
        },
        "q4": {
          "type": "qa",
          "settings": {
            "question": "What sizes do you offer?",
            "answer": "<p>Our standard birthday cakes serve 8–10 (single layer), 12–16 (two layer), and 20–25 (three layer). Need something bigger — or smaller? Reach out and we'll quote a custom size for your party.</p>"
          }
        },
        "q5": {
          "type": "qa",
          "settings": {
            "question": "Can you do candles or special decorations?",
            "answer": "<p>Just ask when you order — we're happy to add a candle or a few simple flourishes when you pick up.</p>"
          }
        },
        "q6": {
          "type": "qa",
          "settings": {
            "question": "What flavors are most popular for birthdays?",
            "answer": "<p>Caramel is the lead Supreme — our number one cake, and what our regulars come back for year after year. German chocolate, pineapple, and strawberry are her backup, and they show up. If you can't choose, half-and-half lets you have two flavors in one.</p>"
          }
        }
      },
      "block_order": ["q1", "q2", "q4", "q5", "q6"],
      "settings": {
        "eyebrow": "QUESTIONS",
        "heading": "Birthday cake FAQ",
        "subheading": "",
        "background_color": "#fffaf2",
        "text_color": "#570522"
