  .delivery-partner-card p {
    font-size: 1.2em;
    font-weight: 500;
    margin-top: 10px;
  }
  
  .delivery-partners-heading {
    font-size: 1.8em; /* Smaller than the default h1 size */
  }
  
  .delivery-partners-container {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 30px;
    max-width: 800px;
    margin: 0 auto;
