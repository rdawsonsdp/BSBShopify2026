<style>
  .delivery-partner-card {
    padding: 30px;
    margin: 15px;
    border-radius: 8px;
    background-color: transparent;
    transition: transform 0.3s ease;
  }

  .delivery-partner-card:hover {
    transform: translateY(-5px);
  }

  .delivery-logo {
    max-width: 200px;
    margin-bottom: 15px;
  }

  .delivery-partner-card a {
    text-decoration: none;
    color: inherit;
