{"sections":{"main":{"type":"template--page","disabled":true,"settings":{}},"advanced_layout_custom_html_nK9kqa":{"type":"advanced-layout--custom-html","blocks":{"html_aQBgw9":{"type":"html","settings":{"code":"<body>\n\n\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Sweet Chicago Legacy - Cupid Candies &amp; Brown Sugar Bakery<\/title>\n    <link href=\"https:\/\/cdn.jsdelivr.net\/npm\/tailwindcss@2.2.19\/dist\/tailwind.min.css\" rel=\"stylesheet\">\n    <link href=\"https:\/\/fonts.googleapis.com\/css2?family=Playfair+Display:wght@400;600;700&amp;display=swap\" rel=\"stylesheet\">\n    <style>\n        * {\n            box-sizing: border-box;\n        }\n        \n        body {\n            margin: 0;\n            padding: 0;\n            font-family: 'Playfair Display', serif;\n            background: #fffaf2;\n            overflow-x: hidden;\n        }\n        \n        .section-container {\n            max-width: 1280px;\n            margin: 0 auto;\n            padding: 80px 40px;\n        }\n        \n        .section-divider {\n            width: 100px;\n            height: 3px;\n            background: #D4A574;\n            margin: 20px auto 40px;\n        }\n        \n        .smooth-scroll {\n            scroll-behavior: smooth;\n        }\n        \n        .sticky-nav {\n            position: sticky;\n            top: 0;\n            background: rgba(255, 248, 240, 0.95);\n            backdrop-filter: blur(10px);\n            z-index: 1000;\n            box-shadow: 0 2px 10px rgba(74, 44, 42, 0.1);\n        }\n        \n        .nav-link {\n            color: #4A2C2A;\n            text-decoration: none;\n            padding: 15px 20px;\n            display: inline-block;\n            transition: color 0.3s ease;\n            font-size: 15px;\n            min-height: 44px;\n            min-width: 44px;\n        }\n        \n        .nav-link:hover {\n            color: #D4A574;\n        }\n        \n        .hero-section {\n            min-height: 100vh;\n            display: flex;\n            align-items: center;\n            background: linear-gradient(135deg, #E8B4B8 0%, #D4A574 100%);\n        }\n        \n        .hero-grid {\n            display: grid;\n            grid-template-columns: 1fr 1fr;\n            gap: 60px;\n            align-items: center;\n        }\n        \n        .two-col-grid {\n            display: grid;\n            grid-template-columns: 1fr 1fr;\n            gap: 50px;\n        }\n        \n        .three-col-grid {\n            display: grid;\n            grid-template-columns: repeat(3, 1fr);\n            gap: 30px;\n        }\n        \n        .mission-grid {\n            display: grid;\n            grid-template-columns: 2fr 3fr;\n            gap: 60px;\n        }\n        \n        .history-grid {\n            display: grid;\n            grid-template-columns: 3fr 2fr;\n            gap: 60px;\n        }\n        \n        .timeline-grid {\n            display: grid;\n            grid-template-columns: 1fr 2fr;\n            gap: 80px;\n        }\n        \n        .timeline-dot {\n            width: 20px;\n            height: 20px;\n            background: #D4A574;\n            border: 4px solid #fffaf2;\n            border-radius: 50%;\n            position: absolute;\n            left: -37px;\n        }\n        \n        img {\n            max-width: 100%;\n            height: auto;\n        }\n        \n        \/* Tablet Styles *\/\n        @media (max-width: 1024px) {\n            .section-container {\n                padding: 60px 30px;\n            }\n            \n            .hero-grid,\n            .two-col-grid,\n            .mission-grid,\n            .history-grid,\n            .timeline-grid {\n                gap: 40px;\n            }\n            \n            h1 {\n                font-size: 48px !important;\n            }\n            \n            h2 {\n                font-size: 36px !important;\n            }\n            \n            h3 {\n                font-size: 28px !important;\n            }\n        }\n        \n        \/* Mobile Styles *\/\n        @media (max-width: 768px) {\n            .section-container {\n                padding: 40px 20px;\n            }\n            \n            .nav-link {\n                padding: 12px 8px;\n                font-size: 12px;\n            }\n            \n            .hero-section {\n                min-height: auto;\n                padding: 40px 0;\n            }\n            \n            .hero-grid,\n            .two-col-grid,\n            .three-col-grid,\n            .mission-grid,\n            .history-grid,\n            .timeline-grid {\n                grid-template-columns: 1fr;\n                gap: 30px;\n            }\n            \n            .section-divider {\n                margin: 15px auto 30px;\n            }\n            \n            \/* Center hero divider on mobile *\/\n            .hero-grid .section-divider {\n                margin-left: auto !important;\n                margin-right: auto !important;\n            }\n            \n            \/* Center hero text on mobile *\/\n            .hero-grid > div {\n                text-align: center;\n            }\n            \n            h1 {\n                font-size: 36px !important;\n                line-height: 1.2 !important;\n            }\n            \n            h2 {\n                font-size: 28px !important;\n                line-height: 1.3 !important;\n            }\n            \n            h3 {\n                font-size: 24px !important;\n                line-height: 1.3 !important;\n            }\n            \n            .timeline-dot {\n                display: none;\n            }\n            \n            \/* Make all padded boxes more mobile-friendly *\/\n            [style*=\"padding: 50px\"],\n            [style*=\"padding: 40px\"],\n            [style*=\"padding: 35px\"],\n            [style*=\"padding: 30px\"] {\n                padding: 25px !important;\n            }\n            \n            \/* Adjust font sizes in content *\/\n            [style*=\"font-size: 28px\"] {\n                font-size: 20px !important;\n            }\n            \n            [style*=\"font-size: 26px\"] {\n                font-size: 20px !important;\n            }\n            \n            [style*=\"font-size: 24px\"] {\n                font-size: 18px !important;\n            }\n            \n            [style*=\"font-size: 22px\"] {\n                font-size: 17px !important;\n            }\n            \n            [style*=\"font-size: 20px\"] {\n                font-size: 16px !important;\n            }\n            \n            [style*=\"font-size: 18px\"] {\n                font-size: 16px !important;\n            }\n            \n            \/* Adjust margins and spacing *\/\n            [style*=\"margin-bottom: 60px\"],\n            [style*=\"margin-bottom: 50px\"] {\n                margin-bottom: 30px !important;\n            }\n            \n            [style*=\"margin-top: 60px\"],\n            [style*=\"margin-top: 50px\"] {\n                margin-top: 30px !important;\n            }\n            \n            [style*=\"gap: 60px\"] {\n                gap: 25px !important;\n            }\n            \n            [style*=\"gap: 50px\"] {\n                gap: 25px !important;\n            }\n            \n            [style*=\"gap: 40px\"] {\n                gap: 20px !important;\n            }\n        }\n        \n        \/* Small Mobile Styles *\/\n        @media (max-width: 480px) {\n            .section-container {\n                padding: 30px 15px;\n            }\n            \n            .nav-link {\n                padding: 10px 6px;\n                font-size: 11px;\n            }\n            \n            h1 {\n                font-size: 28px !important;\n            }\n            \n            h2 {\n                font-size: 24px !important;\n            }\n            \n            h3 {\n                font-size: 20px !important;\n            }\n            \n            [style*=\"padding: 50px\"],\n            [style*=\"padding: 40px\"],\n            [style*=\"padding: 35px\"],\n            [style*=\"padding: 30px\"],\n            [style*=\"padding: 25px\"] {\n                padding: 20px !important;\n            }\n        }\n    <\/style>\n\n\n\n    <!-- Sticky Navigation -->\n    <nav class=\"sticky-nav\">\n        <div class=\"section-container\" style=\"padding: 0 40px;\">\n            <div style=\"display: flex; justify-content: center; flex-wrap: wrap; gap: 10px;\">\n                <a href=\"#hero\" class=\"nav-link\">Home<\/a>\n                <a href=\"#history\" class=\"nav-link\">History<\/a>\n                <a href=\"#dove-bar\" class=\"nav-link\">Dove Bar<\/a>\n                <a href=\"#people\" class=\"nav-link\">Our People<\/a>\n                <a href=\"#transformation\" class=\"nav-link\">2020 Transformation<\/a>\n                <a href=\"#postcards\" class=\"nav-link\">Postcard Series<\/a>\n            <\/div>\n        <\/div>\n    <\/nav>\n\n    <!-- Hero Section -->\n    <section id=\"hero\" class=\"hero-section\">\n        <div class=\"section-container\">\n            <div class=\"hero-grid\">\n                <!-- Left side - Image -->\n                <div style=\"text-align: center;\">\n                    <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0688\/2505\/5479\/files\/BSB-Postcard-Box-Main.webp?v=1767749109\" alt=\"Chicago Postcard Collection\" style=\"max-width: 100%; height: auto; object-fit: contain;\">\n                <\/div>\n                \n                <!-- Right side - Title -->\n                <div>\n                    <h1 style=\"color: #2C1810; font-size: 64px; font-weight: 700; line-height: 1.1; margin-bottom: 30px;\">\n                        A Tale of Two Sweethearts\n                    <\/h1>\n                    <div class=\"section-divider\" style=\"margin-left: 0;\"><\/div>\n                    <div style=\"color: #4A2C2A; font-size: 24px; font-weight: 400; margin-bottom: 30px;\">\n                        The Story of Cupid Candies and Brown Sugar Bakery\n                    <\/div>\n                    <p style=\"color: #4A2C2A; font-size: 20px; line-height: 1.6; margin-top: 30px;\">\n                        In the heart of Chicago, a city renowned for its rich culinary history, a sweet story of legacy and innovation unfolds. This is the tale of two beloved local institutions: <strong>Cupid Candies<\/strong>, a South Side icon since 1936, and <strong>Brown Sugar Bakery<\/strong>, a celebrated purveyor of Southern-style sweets. In 2020, these two stories intertwined when Stephanie Hart acquired the historic Cupid Candies factory, ushering in a new era for Chicago confectionery.\n                    <\/p>\n                <\/div>\n            <\/div>\n        <\/div>\n    <\/section>\n\n    <!-- Historical Foundation Section -->\n    <section id=\"history\" style=\"background: linear-gradient(180deg, #fffaf2 0%, #F5EDE3 100%);\">\n        <div class=\"section-container\">\n            <h2 style=\"color: #4A2C2A; font-size: 42px; font-weight: 700; text-align: center; margin-bottom: 15px;\">\n                Chicago as Candy Capital: The Early Years\n            <\/h2>\n            <div class=\"section-divider\"><\/div>\n            \n            <div class=\"history-grid\" style=\"margin-top: 50px;\">\n                <!-- Left Column - Timeline -->\n                <div>\n                    <div style=\"margin-bottom: 45px;\">\n                        <div style=\"color: #D4A574; font-size: 32px; font-weight: 700; margin-bottom: 10px;\">\n                            Early 1900s\n                        <\/div>\n                        <div style=\"color: #4A2C2A; font-size: 20px; font-weight: 600; margin-bottom: 8px;\">\n                            Greek Immigrant Legacy\n                        <\/div>\n                        <p style=\"color: #2C1810; font-size: 17px; line-height: 1.6;\">\n                            Chicago was home to over 1,000 candy companies, many founded by Greek immigrants seeking the American Dream\n                        <\/p>\n                    <\/div>\n                    \n                    <div style=\"margin-bottom: 45px;\">\n                        <div style=\"color: #D4A574; font-size: 32px; font-weight: 700; margin-bottom: 10px;\">\n                            1936\n                        <\/div>\n                        <div style=\"color: #4A2C2A; font-size: 20px; font-weight: 600; margin-bottom: 8px;\">\n                            Paul Stefanos' Vision\n                        <\/div>\n                        <p style=\"color: #2C1810; font-size: 17px; line-height: 1.6;\">\n                            Founded Cupid Candies on Chicago's South Side at 79th and Ashland, starting with only fudge, toffee, and popcorn\n                        <\/p>\n                    <\/div>\n                    \n                    <div style=\"margin-bottom: 45px;\">\n                        <div style=\"color: #D4A574; font-size: 32px; font-weight: 700; margin-bottom: 10px;\">\n                            1940\n                        <\/div>\n                        <div style=\"color: #4A2C2A; font-size: 20px; font-weight: 600; margin-bottom: 8px;\">\n                            Innovation Milestone\n                        <\/div>\n                        <p style=\"color: #2C1810; font-size: 17px; line-height: 1.6;\">\n                            Paul Stefanos created the famous 3-layer meltaway candy, which became the most featured candy at Marshall Field's department store during holidays\n                        <\/p>\n                    <\/div>\n                    \n                    <div style=\"background: linear-gradient(90deg, #E8B4B8 0%, #D4A574 100%); padding: 30px; border-radius: 8px;\">\n                        <p style=\"color: #2C1810; font-size: 18px; font-weight: 600; line-height: 1.5;\">\n                            These early innovations established Cupid Candies as a cornerstone of Chicago's candy-making tradition\n                        <\/p>\n                    <\/div>\n                <\/div>\n                \n                <!-- Right Column - Image -->\n                <div style=\"text-align: center; display: flex; flex-direction: column; justify-content: center;\">\n                    <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0688\/2505\/5479\/files\/meltaways.png?v=1767749110\" alt=\"3-Layer Meltaway Candy\" style=\"max-width: 100%; height: auto; object-fit: contain; max-height: 500px;\">\n                    <p style=\"color: #4A2C2A; font-size: 16px; text-align: center; margin-top: 20px; font-style: italic;\">\n                        The legendary 3-layer meltaway candy created in 1940\n                    <\/p>\n                <\/div>\n            <\/div>\n            \n            <!-- Growth and Legacy Timeline -->\n            <div style=\"margin-top: 80px; padding-top: 60px; border-top: 3px solid #D4A574;\">\n                <h3 style=\"color: #4A2C2A; font-size: 38px; font-weight: 700; text-align: center; margin-bottom: 50px;\">\n                    Growth and Legacy: 1956-2020\n                <\/h3>\n                \n                <!-- 1956 Manufacturing Expansion -->\n                <div style=\"margin-bottom: 60px;\">\n                    <div style=\"text-align: center; margin-bottom: 20px;\">\n                        <div style=\"color: #D4A574; font-size: 52px; font-weight: 700; margin-bottom: 12px;\">\n                            1956\n                        <\/div>\n                        <div style=\"color: #4A2C2A; font-size: 28px; font-weight: 600; margin-bottom: 15px;\">\n                            Manufacturing Expansion\n                        <\/div>\n                    <\/div>\n                    \n                    <div style=\"max-width: 900px; margin: 0 auto;\">\n                        <p style=\"color: #2C1810; font-size: 22px; line-height: 1.6; text-align: center;\">\n                            Opened the Western Avenue factory, which <span style=\"font-weight: 600; color: #4A2C2A;\">remains operational today<\/span> and became the manufacturing site for the legendary Dove Bar\n                        <\/p>\n                    <\/div>\n                <\/div>\n                \n                <div style=\"width: 200px; height: 2px; background: #D4A574; margin: 40px auto;\"><\/div>\n                \n                <!-- 84-Year Family Legacy -->\n                <div>\n                    <div style=\"text-align: center; margin-bottom: 20px;\">\n                        <div style=\"color: #D4A574; font-size: 52px; font-weight: 700; margin-bottom: 12px;\">\n                            1936 - 2020\n                        <\/div>\n                        <div style=\"color: #4A2C2A; font-size: 28px; font-weight: 600; margin-bottom: 15px;\">\n                            84-Year Family Legacy\n                        <\/div>\n                    <\/div>\n                    \n                    <div style=\"background: linear-gradient(90deg, #E8B4B8 0%, #D4A574 100%); padding: 40px; max-width: 900px; margin: 0 auto; border-radius: 8px;\">\n                        <p style=\"color: #2C1810; font-size: 24px; font-weight: 600; line-height: 1.6; text-align: center;\">\n                            Remained family-owned and operated until 2020, representing authentic Chicago candy-making tradition\n                        <\/p>\n                    <\/div>\n                <\/div>\n            <\/div>\n        <\/div>\n    <\/section>\n\n    <!-- Dove Bar Connection Section -->\n    <section id=\"dove-bar\" style=\"background: #fffaf2;\">\n        <div class=\"section-container\">\n            <h2 style=\"color: #4A2C2A; font-size: 42px; font-weight: 700; text-align: center; margin-bottom: 15px;\">\n                The Dove Bar: A Chicago Icon Born at Cupid\n            <\/h2>\n            <div class=\"section-divider\"><\/div>\n            \n            <div class=\"timeline-grid\" style=\"margin-top: 50px;\">\n                <!-- Left Column - Timeline -->\n                <div>\n                    <div style=\"border-left: 4px solid #D4A574; padding-left: 30px; margin-left: 20px;\">\n                        <div style=\"margin-bottom: 50px; position: relative;\">\n                            <div class=\"timeline-dot\"><\/div>\n                            <div style=\"color: #D4A574; font-size: 32px; font-weight: 700; margin-bottom: 8px;\">1956<\/div>\n                            <div style=\"color: #4A2C2A; font-size: 18px; font-weight: 600;\">Invention<\/div>\n                        <\/div>\n                        \n                        <div style=\"margin-bottom: 50px; position: relative;\">\n                            <div class=\"timeline-dot\"><\/div>\n                            <div style=\"color: #D4A574; font-size: 32px; font-weight: 700; margin-bottom: 8px;\">1956-1984<\/div>\n                            <div style=\"color: #4A2C2A; font-size: 18px; font-weight: 600;\">Local Secret<\/div>\n                        <\/div>\n                        \n                        <div style=\"margin-bottom: 50px; position: relative;\">\n                            <div class=\"timeline-dot\"><\/div>\n                            <div style=\"color: #D4A574; font-size: 32px; font-weight: 700; margin-bottom: 8px;\">1984<\/div>\n                            <div style=\"color: #4A2C2A; font-size: 18px; font-weight: 600;\">National Launch<\/div>\n                        <\/div>\n                        \n                        <div style=\"position: relative;\">\n                            <div class=\"timeline-dot\"><\/div>\n                            <div style=\"color: #D4A574; font-size: 32px; font-weight: 700; margin-bottom: 8px;\">1986<\/div>\n                            <div style=\"color: #4A2C2A; font-size: 18px; font-weight: 600;\">Mars Acquisition<\/div>\n                        <\/div>\n                    <\/div>\n                <\/div>\n                \n                <!-- Right Column - Narrative -->\n                <div>\n                    <div style=\"margin-bottom: 35px;\">\n                        <div style=\"color: #4A2C2A; font-size: 22px; font-weight: 700; margin-bottom: 12px;\">\n                            The Creator\n                        <\/div>\n                        <p style=\"color: #2C1810; font-size: 17px; line-height: 1.6;\">\n                            <strong style=\"color: #D4A574;\">Leo Stefanos<\/strong> (Paul's brother) invented the Dove Bar in 1956 at his shop, Dove Candies &amp; Ice Cream, located at 60th and Pulaski. Inspired by watching his son chase an ice cream truck, Leo created a hand-dipped high-quality vanilla ice cream bar covered in rich, dark chocolate.\n                        <\/p>\n                    <\/div>\n                    \n                    <div style=\"margin-bottom: 35px;\">\n                        <div style=\"color: #4A2C2A; font-size: 22px; font-weight: 700; margin-bottom: 12px;\">\n                            Manufacturing at Cupid\n                        <\/div>\n                        <p style=\"color: #2C1810; font-size: 17px; line-height: 1.6;\">\n                            The Dove Bar was <strong style=\"color: #D4A574;\">manufactured at the Cupid Candies factory<\/strong> on Western Avenue, bringing together the expertise of both Stefanos brothers. This connection between the two family businesses ensured the highest quality chocolate coating for each bar.\n                        <\/p>\n                    <\/div>\n                    \n                    <div style=\"margin-bottom: 35px;\">\n                        <div style=\"color: #4A2C2A; font-size: 22px; font-weight: 700; margin-bottom: 12px;\">\n                            From Local to National\n                        <\/div>\n                        <p style=\"color: #2C1810; font-size: 17px; line-height: 1.6;\">\n                            For nearly three decades, the Dove Bar remained a cherished local secret enjoyed by South Side Chicagoans. In 1984, it became a nationwide sensation, introducing America to the premium ice cream bar experience.\n                        <\/p>\n                    <\/div>\n                    \n                    <div style=\"background: linear-gradient(90deg, #E8B4B8 0%, #D4A574 100%); padding: 30px; border-radius: 8px;\">\n                        <div style=\"color: #4A2C2A; font-size: 22px; font-weight: 700; margin-bottom: 10px;\">\n                            Chicago's Culinary Export\n                        <\/div>\n                        <p style=\"color: #2C1810; font-size: 18px; line-height: 1.6; font-weight: 600;\">\n                            Acquired by Mars, Inc. in 1986, the Dove Bar remains one of Chicago's most famous culinary exports, forever linking the Stefanos family name to an American icon.\n                        <\/p>\n                    <\/div>\n                <\/div>\n            <\/div>\n        <\/div>\n    <\/section>\n\n    <!-- Employee Loyalty Section -->\n    <section id=\"people\" style=\"background: linear-gradient(180deg, #F5EDE3 0%, #fffaf2 100%);\">\n        <div class=\"section-container\">\n            <h2 style=\"color: #4A2C2A; font-size: 42px; font-weight: 700; text-align: center; margin-bottom: 15px;\">\n                The Heart of Cupid's Quality\n            <\/h2>\n            <div class=\"section-divider\"><\/div>\n            \n            <!-- Employee Testimonials -->\n            <div class=\"three-col-grid\" style=\"margin-top: 50px; margin-bottom: 40px;\">\n                <!-- Hazel Harris -->\n                <div>\n                    <div style=\"background: linear-gradient(135deg, #E8B4B8 0%, #D4A574 100%); padding: 30px; min-height: 260px; border-radius: 8px;\">\n                        <div style=\"color: #4A2C2A; font-size: 22px; font-weight: 700; margin-bottom: 5px;\">\n                            Hazel Harris\n                        <\/div>\n                        <div style=\"color: #2C1810; font-size: 17px; font-weight: 600; margin-bottom: 15px;\">\n                            31 Years of Service\n                        <\/div>\n                        <p style=\"color: #2C1810; font-size: 16px; line-height: 1.6; font-style: italic;\">\n                            \"I run a little bit of everything around here. It's pretty fun to have chocolate every day so that's a good thing in life.\"\n                        <\/p>\n                    <\/div>\n                <\/div>\n                \n                <!-- Guadalupe Barranco -->\n                <div>\n                    <div style=\"background: #D4A574; padding: 30px; min-height: 260px; border-radius: 8px;\">\n                        <div style=\"color: #4A2C2A; font-size: 22px; font-weight: 700; margin-bottom: 5px;\">\n                            Guadalupe Barranco\n                        <\/div>\n                        <div style=\"color: #2C1810; font-size: 17px; font-weight: 600; margin-bottom: 15px;\">\n                            26 Years of Service\n                        <\/div>\n                        <p style=\"color: #2C1810; font-size: 16px; line-height: 1.6; font-style: italic;\">\n                            \"A long time ago, John taught me everything I know here.\"\n                        <\/p>\n                        <p style=\"color: #2C1810; font-size: 15px; line-height: 1.5; margin-top: 12px;\">\n                            Originally from Mexico City, personally trained by John Stefanos\n                        <\/p>\n                    <\/div>\n                <\/div>\n                \n                <!-- Monica Biliskov -->\n                <div>\n                    <div style=\"background: linear-gradient(135deg, #D4A574 0%, #E8B4B8 100%); padding: 30px; min-height: 260px; border-radius: 8px;\">\n                        <div style=\"color: #4A2C2A; font-size: 22px; font-weight: 700; margin-bottom: 5px;\">\n                            Monica Biliskov\n                        <\/div>\n                        <div style=\"color: #2C1810; font-size: 17px; font-weight: 600; margin-bottom: 15px;\">\n                            29 Years of Service\n                        <\/div>\n                        <p style=\"color: #2C1810; font-size: 16px; line-height: 1.6; font-style: italic;\">\n                            \"They're good people to work for. It's nice to work for a family business.\"\n                        <\/p>\n                    <\/div>\n                <\/div>\n            <\/div>\n            \n            <!-- Cultural Heritage Section -->\n            <div style=\"background: #4A2C2A; padding: 40px; border-radius: 8px;\">\n                <div style=\"color: #D4A574; font-size: 24px; font-weight: 700; margin-bottom: 20px; text-align: center;\">\n                    Cultural Heritage &amp; Master Craftsmanship\n                <\/div>\n                <div class=\"two-col-grid\" style=\"gap: 40px;\">\n                    <div>\n                        <p style=\"color: #fffaf2; font-size: 17px; line-height: 1.6;\">\n                            Mexican immigrant workers carrying on the tradition established by Greek immigrant founders, showcasing Chicago's rich immigrant candy-making legacy that spans generations.\n                        <\/p>\n                    <\/div>\n                    <div>\n                        <p style=\"color: #fffaf2; font-size: 17px; line-height: 1.6;\">\n                            These employees are guardians of secret recipes and traditional techniques that cannot be replicated by machines, ensuring every chocolate maintains exceptional quality.\n                        <\/p>\n                    <\/div>\n                <\/div>\n            <\/div>\n\n            <!-- Valentine Gelata Section -->\n            <div style=\"margin-top: 80px; padding-top: 60px; border-top: 3px solid #D4A574;\">\n                <h3 style=\"color: #4A2C2A; font-size: 38px; font-weight: 700; text-align: center; margin-bottom: 50px;\">\n                    Master of Transition\n                <\/h3>\n                \n                <div class=\"mission-grid\" style=\"gap: 60px;\">\n                    <!-- Left Column - Photo -->\n                    <div style=\"text-align: center;\">\n                        <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0688\/2505\/5479\/files\/valentine_gelata.png?v=1767749110\" alt=\"Valentine Gelata in the chocolate factory\" style=\"max-width: 100%; height: auto; object-fit: contain; max-height: 450px;\">\n                        <p style=\"color: #4A2C2A; font-size: 16px; text-align: center; margin-top: 15px; font-style: italic;\">\n                            Valentine Gelata at the Cupid Candies factory\n                        <\/p>\n                    <\/div>\n                    \n                    <!-- Right Column - Content -->\n                    <div>\n                        <div style=\"margin-bottom: 25px;\">\n                            <div style=\"color: #D4A574; font-size: 18px; font-weight: 600; margin-bottom: 8px;\">\n                                Student of John Stefanos • Expert in Confections\n                            <\/div>\n                            <p style=\"color: #2C1810; font-size: 16px; line-height: 1.5;\">\n                                Valentine Gelata played a crucial role in bridging the old and new eras, bringing decades of expertise to the transition\n                            <\/p>\n                        <\/div>\n                        \n                        <div style=\"background: linear-gradient(90deg, #E8B4B8 0%, #D4A574 100%); padding: 25px; margin-bottom: 25px; border-radius: 8px;\">\n                            <p style=\"color: #2C1810; font-size: 15px; line-height: 1.6; font-style: italic;\">\n                                \"With the creative help of Stephanie Hart and Susan Oleary, we were able to go from an idea to develop a line of Chocolates to Products on the shelf at Nordstrom Michigan Ave. Chicago in less than 30 days!!!!\"\n                            <\/p>\n                        <\/div>\n                        \n                        <div style=\"margin-bottom: 20px;\">\n                            <div style=\"color: #4A2C2A; font-size: 18px; font-weight: 600; margin-bottom: 10px;\">\n                                The Chicago Chocolate Philosophy\n                            <\/div>\n                            <p style=\"color: #2C1810; font-size: 15px; line-height: 1.6;\">\n                                \"Our employees did not graduate from Le Cordon Bleu. We do not create shiny, hard perfectly tempered European chocolate on purpose, rather, we rely on the traditions of <span style=\"font-weight: 600;\">Chicago based American Chocolate—soft, perfectly set, silky smooth<\/span> with a flavor that takes you back to simpler times.\"\n                            <\/p>\n                        <\/div>\n                        \n                        <div style=\"margin-bottom: 20px;\">\n                            <p style=\"color: #2C1810; font-size: 15px; line-height: 1.6;\">\n                                \"Our standards are high and our process is built on <span style=\"font-weight: 600;\">formulas and traditions that date back decades<\/span>. Many of our employee\/creators have been loyal to us for over 30 years and we are also training new creators.\"\n                            <\/p>\n                        <\/div>\n                        \n                        <div style=\"margin-top: 25px; padding: 25px; background: #4A2C2A; border-radius: 8px;\">\n                            <p style=\"color: #D4A574; font-size: 24px; font-weight: 700; text-align: center; letter-spacing: 1px;\">\n                                \"The Cupid Candies Factory is BACK!!!\"\n                            <\/p>\n                        <\/div>\n                    <\/div>\n                <\/div>\n            <\/div>\n        <\/div>\n    <\/section>\n\n    <!-- 2020 Transformation Section -->\n    <section id=\"transformation\" style=\"background: #fffaf2;\">\n        <div class=\"section-container\">\n            <h2 style=\"color: #4A2C2A; font-size: 42px; font-weight: 700; text-align: center; margin-bottom: 15px;\">\n                The 2020 Transformation\n            <\/h2>\n            <div class=\"section-divider\"><\/div>\n            \n            <div class=\"two-col-grid\" style=\"gap: 60px; margin-top: 50px;\">\n                <!-- Left Column - Photo -->\n                <div>\n                    <div style=\"background: linear-gradient(135deg, #E8B4B8 0%, #D4A574 100%); padding: 30px; border-radius: 8px;\">\n                        <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0688\/2505\/5479\/files\/john_stephanie_legacy.png?v=1767749110\" alt=\"Three Generations Legacy\" style=\"width: 100%; height: auto; object-fit: contain; max-height: 420px;\">\n                        <p style=\"color: #2C1810; font-size: 15px; text-align: center; margin-top: 20px; font-style: italic; line-height: 1.4;\">\n                            Three generations united: Stephanie Hart with John Stefanos, beneath the watchful portrait of founder Paul Stefanos\n                        <\/p>\n                    <\/div>\n                <\/div>\n                \n                <!-- Right Column - Content -->\n                <div>\n                    <div style=\"margin-bottom: 28px;\">\n                        <div style=\"color: #D4A574; font-size: 20px; font-weight: 700; margin-bottom: 10px;\">\n                            Stephanie Hart's Background\n                        <\/div>\n                        <p style=\"color: #2C1810; font-size: 16px; line-height: 1.5;\">\n                            After a 20-year career in tech, founded Brown Sugar Bakery in 2002, creating an iconic Black woman-owned institution on Chicago's South Side\n                        <\/p>\n                    <\/div>\n                    \n                    <div style=\"margin-bottom: 28px;\">\n                        <div style=\"color: #D4A574; font-size: 20px; font-weight: 700; margin-bottom: 10px;\">\n                            Historic Acquisition\n                        <\/div>\n                        <p style=\"color: #2C1810; font-size: 16px; line-height: 1.5;\">\n                            In 2020, with a $500,000 grant from the state of Illinois, Hart purchased the 84-year-old Cupid Candies factory and name\n                        <\/p>\n                    <\/div>\n                    \n                    <div style=\"margin-bottom: 28px;\">\n                        <div style=\"color: #D4A574; font-size: 20px; font-weight: 700; margin-bottom: 10px;\">\n                            Passing of the Torch\n                        <\/div>\n                        <p style=\"color: #2C1810; font-size: 16px; line-height: 1.5;\">\n                            John Stefanos passed away September 26, 2020, the night before the Oak Lawn store closed, knowing his legacy would continue\n                        <\/p>\n                    <\/div>\n                    \n                    <div style=\"margin-bottom: 28px;\">\n                        <div style=\"color: #D4A574; font-size: 20px; font-weight: 700; margin-bottom: 10px;\">\n                            Continuity of Excellence\n                        <\/div>\n                        <p style=\"color: #2C1810; font-size: 16px; line-height: 1.5;\">\n                            Hart retained the factory's dedicated staff, including many with over 30 years of service, ensuring preservation of traditional chocolate-making expertise\n                        <\/p>\n                    <\/div>\n                    \n                    <div style=\"background: linear-gradient(90deg, #D4A574 0%, #E8B4B8 100%); padding: 25px; margin-top: 25px; border-radius: 8px;\">\n                        <p style=\"color: #2C1810; font-size: 17px; font-weight: 600; line-height: 1.5;\">\n                            Hart became the only Black woman-owned chocolate manufacturer in America, bridging Greek immigrant heritage with modern entrepreneurship\n                        <\/p>\n                    <\/div>\n                <\/div>\n            <\/div>\n        <\/div>\n    <\/section>\n\n    <!-- Postcard Series Section -->\n    <section id=\"postcards\" style=\"background: linear-gradient(180deg, #F5EDE3 0%, #fffaf2 100%);\">\n        <div class=\"section-container\">\n            <h2 style=\"color: #4A2C2A; font-size: 42px; font-weight: 700; text-align: center; margin-bottom: 15px;\">\n                Love Letter to the City\n            <\/h2>\n            <div class=\"section-divider\"><\/div>\n            \n            <!-- Postcard Images -->\n            <div class=\"two-col-grid\" style=\"gap: 40px; margin-bottom: 50px;\">\n                <div style=\"text-align: center;\">\n                    <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0688\/2505\/5479\/files\/BSB-Postcard-art-institute.webp?v=1767749109\" alt=\"Art Institute Postcard Box\" style=\"width: 100%; height: auto; object-fit: contain; max-height: 300px;\">\n                <\/div>\n                <div style=\"text-align: center;\">\n                    <img src=\"https:\/\/cdn.shopify.com\/s\/files\/1\/0688\/2505\/5479\/files\/BSB-Postcard-art-institute.webp?v=1767749109\" alt=\"Chicago L Train Postcard Box\" style=\"width: 100%; height: auto; object-fit: contain; max-height: 300px;\">\n                <\/div>\n            <\/div>\n            \n            <!-- Content Grid -->\n            <div class=\"two-col-grid\" style=\"gap: 50px;\">\n                <!-- Left Column -->\n                <div>\n                    <div style=\"margin-bottom: 30px;\">\n                        <div style=\"color: #D4A574; font-size: 20px; font-weight: 700; margin-bottom: 10px;\">\n                            The Concept\n                        <\/div>\n                        <p style=\"color: #2C1810; font-size: 17px; line-height: 1.6; font-style: italic;\">\n                            \"Chicago is more than a city—it's a feeling, a collection of moments that take your breath away\"\n                        <\/p>\n                    <\/div>\n                    \n                    <div style=\"margin-bottom: 30px;\">\n                        <div style=\"color: #D4A574; font-size: 20px; font-weight: 700; margin-bottom: 10px;\">\n                            Design Philosophy\n                        <\/div>\n                        <p style=\"color: #2C1810; font-size: 17px; line-height: 1.6;\">\n                            Each box features stunning vintage-style illustrations of Chicago's most treasured locations, making them keepsakes beyond just packaging\n                        <\/p>\n                    <\/div>\n                    \n                    <div>\n                        <div style=\"color: #D4A574; font-size: 20px; font-weight: 700; margin-bottom: 10px;\">\n                            Product Integration\n                        <\/div>\n                        <p style=\"color: #2C1810; font-size: 17px; line-height: 1.6;\">\n                            Inside each postcard box are signature handmade chocolates crafted at the historic Cupid Candies factory using traditional methods\n                        <\/p>\n                    <\/div>\n                <\/div>\n                \n                <!-- Right Column -->\n                <div>\n                    <div style=\"background: linear-gradient(135deg, #E8B4B8 0%, #D4A574 100%); padding: 40px; min-height: 400px; display: flex; flex-direction: column; justify-content: center; border-radius: 8px;\">\n                        <div style=\"color: #4A2C2A; font-size: 24px; font-weight: 700; margin-bottom: 20px; text-align: center;\">\n                            A Collection of Chicago Icons\n                        <\/div>\n                        <p style=\"color: #2C1810; font-size: 18px; line-height: 1.7; text-align: center;\">\n                            From the Art Institute's iconic lions to the beloved L Train, from Buckingham Fountain's summer spray to the Zoo's winter lights—each design celebrates a cherished Chicago landmark\n                        <\/p>\n                        <div style=\"margin-top: 30px; text-align: center;\">\n                            <p style=\"color: #4A2C2A; font-size: 20px; font-weight: 600;\">\n                                14 unique designs capturing the spirit of Chicago\n                            <\/p>\n                        <\/div>\n                    <\/div>\n                <\/div>\n            <\/div>\n\n            <!-- 14 Designs List -->\n            <div style=\"margin-top: 60px;\">\n                <h3 style=\"color: #4A2C2A; font-size: 32px; font-weight: 700; text-align: center; margin-bottom: 30px;\">\n                    14 Designs Celebrating Chicago\n                <\/h3>\n                \n                <div style=\"max-width: 800px; margin: 0 auto 30px;\">\n                    <div style=\"background: linear-gradient(135deg, #E8B4B8 0%, #D4A574 100%); padding: 40px; border-radius: 8px;\">\n                        <div style=\"color: #2C1810; font-size: 20px; line-height: 1.6; text-align: center;\">\n                            <div style=\"font-weight: 600; margin-bottom: 10px;\">Chicago Postcard Collection<\/div>\n                            <div>Art Institute Lions<\/div>\n                            <div>Cloud Gate (The Bean)<\/div>\n                            <div>Buckingham Fountain (summer &amp; winter)<\/div>\n                            <div>Magnificent Mile<\/div>\n                            <div>Lakefront Skyline (2 variations)<\/div>\n                            <div>Historic Bridges<\/div>\n                            <div>Lincoln Park Zoo (summer &amp; winter)<\/div>\n                            <div>Museum Campus<\/div>\n                            <div>Chicago Flag<\/div>\n                            <div>The Chicago L Train<\/div>\n                        <\/div>\n                    <\/div>\n                <\/div>\n                \n                <!-- Purpose Section -->\n                <div style=\"max-width: 900px; margin: 0 auto;\">\n                    <div style=\"background: #4A2C2A; padding: 30px; border-radius: 8px;\">\n                        <div style=\"color: #D4A574; font-size: 24px; font-weight: 700; margin-bottom: 15px; text-align: center;\">\n                            Perfect for Every Occasion\n                        <\/div>\n                        <p style=\"color: #fffaf2; font-size: 20px; line-height: 1.7; text-align: center; margin: 0;\">\n                            Perfect for sending to those who miss home, welcoming visitors, or celebrating Chicago pride with authentic handmade chocolates\n                        <\/p>\n                    <\/div>\n                <\/div>\n            <\/div>\n        <\/div>\n    <\/section>\n\n\n    <script>\n        \/\/ Smooth scroll for navigation links\n        document.querySelectorAll('a[href^=\"#\"]').forEach(anchor => {\n            anchor.addEventListener('click', function (e) {\n                e.preventDefault();\n                const target = document.querySelector(this.getAttribute('href'));\n                if (target) {\n                    target.scrollIntoView({\n                        behavior: 'smooth',\n                        block: 'start'\n                    });\n                }\n            });\n        });\n    <\/script>\n\n\n<\/body>","width":"100%"}}},"block_order":["html_aQBgw9"],"name":"Custom HTML","settings":{}},"1767835270ed63576b":{"type":"_blocks","blocks":{"ai_gen_block_ff03132_Pz66jq":{"type":"ai_gen_block_ff03132","settings":{"columns_desktop":4,"columns_tablet":3,"columns_mobile":"2","grid_gap":20,"image_fit":"contain","image_padding":10,"image_background_color":"#ffffff","border_radius":8,"enable_border":false,"border_width":2,"border_color":"#5b2512","show_product_info":true,"overlay_opacity":0.7,"overlay_text_color":"#ffffff","product_1":"mint-melt-a-ways","image_1":"shopify:\/\/shop_images\/BSB-Postcard-art-institute.webp","product_2":"","image_2":"shopify:\/\/shop_images\/BSB-Postcard-Box-Main.webp","product_3":"","image_3":"shopify:\/\/shop_images\/BSB-Train-Car.webp","product_4":"","image_4":"shopify:\/\/shop_images\/BSB-Postcard-Mag-Mile.png","product_5":"","image_5":"shopify:\/\/shop_images\/BSB-Postcard-Millinum-plaza.png","product_6":"","image_6":"shopify:\/\/shop_images\/BSB-Postcard-Lakefront.png","product_7":"","image_7":"shopify:\/\/shop_images\/BSB-Postcard-Mag-Lakefront.png","product_8":"","image_8":"shopify:\/\/shop_images\/BSB-Postcard-fountain.png","product_9":"","image_9":"shopify:\/\/shop_images\/BSB-Postcard-Bridges_2ce9f2a9-f6c5-450a-adc1-74f8bcaccc13.png","product_10":"","product_11":"","product_12":""},"blocks":{}}},"block_order":["ai_gen_block_ff03132_Pz66jq"],"settings":{}},"candy_featured":{"type":"collection--featured-collection","blocks":{"product_card_title":{"type":"product-card-title","settings":{}},"product_card_price":{"type":"product-card-price","settings":{}}},"block_order":["product_card_title","product_card_price"],"settings":{"collection":"candy-collection","title":"Shop our classic candy collection.","subheading":"","grid":3,"rows":5,"show_view_all":true}}},"order":["main","advanced_layout_custom_html_nK9kqa","1767835270ed63576b","candy_featured"]}